---
/**
 * DocsLayout.astro — Shared layout for all documentation sub-pages.
 * 3-column: [chapter nav | main content | section TOC]
 */
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  chapterId: 'students' | 'creators' | 'contributors' | 'architecture';
}

const { title, description, chapterId } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const CHAPTERS = [
  {
    id: 'students',
    num: '01',
    label: 'For Students',
    icon: '📚',
    color: '#38BDF8',
    desc: 'Enroll, test, earn certificates',
  },
  {
    id: 'creators',
    num: '02',
    label: 'Course Creators',
    icon: '🛠️',
    color: '#a78bfa',
    desc: 'Build and publish courses',
  },
  {
    id: 'contributors',
    num: '03',
    label: 'Code Contributors',
    icon: '🔧',
    color: '#34d399',
    desc: 'Engine and site internals',
  },
  {
    id: 'architecture',
    num: '04',
    label: 'Architecture',
    icon: '🏗️',
    color: '#fb923c',
    desc: 'System design & reference',
  },
];

const current = CHAPTERS.find(c => c.id === chapterId)!;
---

<Base title={`${title} — Docs`} description={description}>
  <div class="docs-page">
    <!-- ── Left: Chapter navigation ──────────────────────────────────── -->
    <aside class="docs-chapnav" id="docs-chapnav">
      <div class="docs-chapnav__header">
        <a href={`${base}/docs`} class="docs-chapnav__back">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          Documentation
        </a>
      </div>
      <nav class="docs-chapnav__list">
        {CHAPTERS.map(ch => (
          <a
            href={`${base}/docs/${ch.id}`}
            class={`docs-chapnav__item ${ch.id === chapterId ? 'active' : ''}`}
            style={ch.id === chapterId ? `--ch-color:${ch.color}` : ''}
          >
            <span class="docs-chapnav__num">{ch.num}</span>
            <span class="docs-chapnav__text">
              <span class="docs-chapnav__name">{ch.label}</span>
              <span class="docs-chapnav__desc">{ch.desc}</span>
            </span>
          </a>
        ))}
      </nav>
    </aside>

    <!-- ── Center: Main content ──────────────────────────────────────── -->
    <main class="docs-main" id="docs-main">
      <!-- Chapter header band -->
      <div class="docs-ch-header" style={`--ch-color:${current.color}`}>
        <div class="docs-ch-header__crumbs">
          <a href={`${base}/`}>~</a>
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          <a href={`${base}/docs`}>docs</a>
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          <span>{chapterId}</span>
        </div>
        <div class="docs-ch-header__badge">
          <span class="docs-ch-header__num">{current.num}</span>
          <span class="docs-ch-header__icon">{current.icon}</span>
        </div>
        <h1 class="docs-ch-header__title">{current.label}</h1>
        <p class="docs-ch-header__sub">{description}</p>
      </div>

      <!-- Content -->
      <div class="docs-content">
        <slot />
      </div>

      <!-- Chapter navigation footer -->
      <div class="docs-ch-footer">
        {(() => {
          const idx = CHAPTERS.findIndex(c => c.id === chapterId);
          const prev = CHAPTERS[idx - 1];
          const next = CHAPTERS[idx + 1];
          return (
            <div class="docs-ch-footer__inner">
              {prev ? (
                <a href={`${base}/docs/${prev.id}`} class="docs-ch-footer__link docs-ch-footer__link--prev">
                  <span class="docs-ch-footer__dir">← Previous</span>
                  <span class="docs-ch-footer__name">{prev.label}</span>
                </a>
              ) : <div />}
              {next ? (
                <a href={`${base}/docs/${next.id}`} class="docs-ch-footer__link docs-ch-footer__link--next">
                  <span class="docs-ch-footer__dir">Next →</span>
                  <span class="docs-ch-footer__name">{next.label}</span>
                </a>
              ) : <div />}
            </div>
          );
        })()}
      </div>
    </main>

    <!-- ── Right: Section TOC ────────────────────────────────────────── -->
    <aside class="docs-sectoc" id="docs-sectoc">
      <div class="docs-sectoc__label">On this page</div>
      <slot name="toc" />
    </aside>
  </div>
</Base>

<style is:global>
/* ── Docs page layout ─────────────────────────────────────────────────── */
.docs-page {
  display: grid;
  grid-template-columns: 220px 1fr 180px;
  grid-template-areas: "chapnav main sectoc";
  gap: 0;
  min-height: calc(100vh - 56px);
  align-items: start;
}
@media (max-width: 1140px) {
  .docs-page {
    grid-template-columns: 200px 1fr;
    grid-template-areas: "chapnav main";
  }
  .docs-sectoc { display: none; }
}
@media (max-width: 780px) {
  .docs-page {
    grid-template-columns: 1fr;
    grid-template-areas: "main";
  }
  .docs-chapnav { display: none; }
}

/* ── Left sidebar: chapter nav ────────────────────────────────────────── */
.docs-chapnav {
  grid-area: chapnav;
  position: sticky;
  top: 56px;
  height: calc(100vh - 56px);
  overflow-y: auto;
  scrollbar-width: thin;
  border-right: 1px solid var(--border-default);
  padding: 1.5rem 0;
  background: var(--bg-surface);
}
.docs-chapnav__header {
  padding: 0 1.25rem 1rem;
  border-bottom: 1px solid var(--border-default);
  margin-bottom: 0.75rem;
}
.docs-chapnav__back {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-family: var(--font-mono);
  font-size: 0.75rem;
  color: var(--text-muted);
  text-decoration: none;
  transition: color 0.15s;
}
.docs-chapnav__back:hover { color: var(--text-primary); }
.docs-chapnav__list { display: flex; flex-direction: column; gap: 4px; padding: 0 0.75rem; }
.docs-chapnav__item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 12px;
  border-radius: 8px;
  text-decoration: none;
  transition: background 0.15s, color 0.15s;
  border: 1px solid transparent;
}
.docs-chapnav__item:hover {
  background: var(--bg-raised);
}
.docs-chapnav__item.active {
  background: color-mix(in srgb, var(--ch-color) 10%, var(--bg-raised));
  border-color: color-mix(in srgb, var(--ch-color) 30%, transparent);
}
.docs-chapnav__num {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  font-weight: 700;
  color: var(--text-muted);
  background: var(--bg-base);
  border: 1px solid var(--border-default);
  border-radius: 4px;
  padding: 1px 6px;
  flex-shrink: 0;
  line-height: 1.4;
}
.docs-chapnav__item.active .docs-chapnav__num {
  color: var(--ch-color);
  border-color: color-mix(in srgb, var(--ch-color) 40%, transparent);
}
.docs-chapnav__text { display: flex; flex-direction: column; gap: 1px; min-width: 0; }
.docs-chapnav__name {
  font-size: 0.82rem;
  font-weight: 600;
  color: var(--text-secondary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.docs-chapnav__item.active .docs-chapnav__name { color: var(--ch-color); }
.docs-chapnav__desc {
  font-size: 0.7rem;
  color: var(--text-muted);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ── Center: Main content ─────────────────────────────────────────────── */
.docs-main { grid-area: main; min-width: 0; }

/* Chapter header band */
.docs-ch-header {
  padding: 2.5rem 2.5rem 2rem;
  border-bottom: 1px solid var(--border-default);
  background: color-mix(in srgb, var(--ch-color) 5%, var(--bg-surface));
}
.docs-ch-header__crumbs {
  display: flex;
  align-items: center;
  gap: 4px;
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--text-muted);
  margin-bottom: 1.25rem;
}
.docs-ch-header__crumbs a { color: var(--text-muted); text-decoration: none; }
.docs-ch-header__crumbs a:hover { color: var(--ch-color); }
.docs-ch-header__badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 0.75rem;
}
.docs-ch-header__num {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  font-weight: 700;
  color: var(--ch-color);
  background: color-mix(in srgb, var(--ch-color) 15%, transparent);
  border: 1px solid color-mix(in srgb, var(--ch-color) 35%, transparent);
  border-radius: 4px;
  padding: 2px 8px;
}
.docs-ch-header__icon { font-size: 1.4rem; }
.docs-ch-header__title {
  font-size: 2rem;
  font-weight: 800;
  color: var(--text-primary);
  margin: 0 0 0.5rem;
  letter-spacing: -0.02em;
}
.docs-ch-header__sub {
  font-size: 0.95rem;
  color: var(--text-secondary);
  margin: 0;
  line-height: 1.6;
  max-width: 600px;
}

/* Content wrapper */
.docs-content {
  padding: 2rem 2.5rem;
}

/* ── Right sidebar: section TOC ───────────────────────────────────────── */
.docs-sectoc {
  grid-area: sectoc;
  position: sticky;
  top: 56px;
  height: calc(100vh - 56px);
  overflow-y: auto;
  scrollbar-width: thin;
  border-left: 1px solid var(--border-default);
  padding: 1.5rem 1rem;
  background: var(--bg-surface);
}
.docs-sectoc__label {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--text-muted);
  margin-bottom: 0.75rem;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid var(--border-default);
}
.docs-toc-link {
  display: block;
  font-size: 0.78rem;
  color: var(--text-muted);
  text-decoration: none;
  padding: 3px 8px;
  border-radius: 4px;
  margin-bottom: 2px;
  border-left: 2px solid transparent;
  transition: color 0.12s, border-color 0.12s, background 0.12s;
}
.docs-toc-link:hover { color: var(--text-secondary); background: var(--bg-raised); }
.docs-toc-link.active {
  color: var(--text-primary);
  border-left-color: var(--accent-blue, #38BDF8);
  background: var(--bg-raised);
}

/* ── Chapter footer navigation ────────────────────────────────────────── */
.docs-ch-footer {
  padding: 1.5rem 2.5rem;
  border-top: 1px solid var(--border-default);
  background: var(--bg-surface);
}
.docs-ch-footer__inner {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
}
.docs-ch-footer__link {
  display: flex;
  flex-direction: column;
  gap: 2px;
  text-decoration: none;
  padding: 10px 14px;
  border-radius: 8px;
  border: 1px solid var(--border-default);
  background: var(--bg-raised);
  transition: border-color 0.15s, background 0.15s;
  min-width: 160px;
}
.docs-ch-footer__link:hover { border-color: var(--accent-blue, #38BDF8); }
.docs-ch-footer__link--next { align-items: flex-end; }
.docs-ch-footer__dir {
  font-size: 0.7rem;
  font-family: var(--font-mono);
  color: var(--text-muted);
}
.docs-ch-footer__name {
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--text-primary);
}

/* ── Section content styles (shared) ─────────────────────────────────── */
.docs-section {
  margin-bottom: 3rem;
  scroll-margin-top: 80px;
}
.docs-section-title {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 1.15rem;
  font-weight: 700;
  color: var(--text-primary);
  margin: 0 0 1rem;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid var(--border-default);
}
.docs-section-badge {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  font-weight: 700;
  padding: 2px 7px;
  border-radius: 4px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.docs-section p, .docs-section li {
  font-size: 0.9rem;
  color: var(--text-secondary);
  line-height: 1.7;
  margin-bottom: 0.5rem;
}
.docs-section ul, .docs-section ol { padding-left: 1.4rem; margin: 0.5rem 0; }
.docs-section li { margin-bottom: 0.3rem; }
.docs-section code {
  font-family: var(--font-mono);
  font-size: 0.8em;
  background: var(--bg-raised);
  border: 1px solid var(--border-default);
  border-radius: 3px;
  padding: 1px 5px;
  color: var(--text-primary);
}
.docs-section a { color: var(--accent-blue, #38BDF8); text-decoration: none; }
.docs-section a:hover { text-decoration: underline; }
.docs-section strong { color: var(--text-primary); }

/* Code blocks */
.docs-pre {
  background: var(--bg-surface);
  border: 1px solid var(--border-default);
  border-radius: 8px;
  overflow: hidden;
  margin: 0.75rem 0;
}
.docs-pre__bar {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 7px 14px;
  background: var(--bg-raised);
  border-bottom: 1px solid var(--border-default);
}
.docs-pre__dot {
  width: 10px; height: 10px; border-radius: 50%;
}
.docs-pre__dot:nth-child(1) { background: #ef4444; opacity: 0.7; }
.docs-pre__dot:nth-child(2) { background: #f59e0b; opacity: 0.7; }
.docs-pre__dot:nth-child(3) { background: #22c55e; opacity: 0.7; }
.docs-pre__lang {
  margin-left: auto;
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}
.docs-pre code {
  display: block;
  font-family: var(--font-mono);
  font-size: 0.78rem;
  background: none;
  border: none;
  padding: 1rem 1.25rem;
  color: var(--text-secondary);
  white-space: pre;
  overflow-x: auto;
}

/* Callouts */
.docs-callout {
  display: flex;
  gap: 10px;
  padding: 0.75rem 1rem;
  border-radius: 8px;
  font-size: 0.85rem;
  margin: 1rem 0;
  line-height: 1.6;
}
.docs-callout__icon { font-size: 1rem; flex-shrink: 0; margin-top: 1px; }
.docs-callout__body { color: var(--text-secondary); }
.docs-callout--info {
  background: color-mix(in srgb, #38BDF8 8%, var(--bg-surface));
  border: 1px solid color-mix(in srgb, #38BDF8 25%, transparent);
}
.docs-callout--warn {
  background: color-mix(in srgb, #fbbf24 8%, var(--bg-surface));
  border: 1px solid color-mix(in srgb, #fbbf24 25%, transparent);
}
.docs-callout--tip {
  background: color-mix(in srgb, #34d399 8%, var(--bg-surface));
  border: 1px solid color-mix(in srgb, #34d399 25%, transparent);
}
.docs-callout--danger {
  background: color-mix(in srgb, #ef4444 8%, var(--bg-surface));
  border: 1px solid color-mix(in srgb, #ef4444 25%, transparent);
}

/* Tables */
.docs-table-wrap { overflow-x: auto; margin: 0.75rem 0; border-radius: 8px; border: 1px solid var(--border-default); }
.docs-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.82rem;
}
.docs-table thead tr { background: var(--bg-raised); }
.docs-table th {
  text-align: left;
  padding: 0.6rem 0.9rem;
  border-bottom: 1px solid var(--border-default);
  font-family: var(--font-mono);
  font-size: 0.7rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  white-space: nowrap;
}
.docs-table td {
  padding: 0.55rem 0.9rem;
  border-bottom: 1px solid var(--border-default);
  color: var(--text-secondary);
  vertical-align: top;
}
.docs-table tr:last-child td { border-bottom: none; }
.docs-table tr:hover td { background: var(--bg-raised); }
.docs-table td code { font-size: 0.75em; }

/* Checklist */
.docs-checklist { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 6px; }
.docs-checklist li {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  font-size: 0.875rem;
  color: var(--text-secondary);
  padding: 6px 10px;
  border-radius: 6px;
  border: 1px solid var(--border-default);
  background: var(--bg-surface);
}
.docs-checklist li::before {
  content: '☐';
  font-size: 1rem;
  color: var(--text-muted);
  flex-shrink: 0;
  line-height: 1.4;
}

/* Step list */
.docs-steps { display: flex; flex-direction: column; gap: 0; position: relative; }
.docs-step {
  display: grid;
  grid-template-columns: 32px 1fr;
  gap: 12px;
  position: relative;
  padding-bottom: 1.5rem;
}
.docs-step:last-child { padding-bottom: 0; }
.docs-step__line {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0;
}
.docs-step__num {
  width: 32px; height: 32px;
  border-radius: 50%;
  background: color-mix(in srgb, var(--ch-color, #38BDF8) 15%, var(--bg-raised));
  border: 2px solid color-mix(in srgb, var(--ch-color, #38BDF8) 40%, transparent);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-mono);
  font-size: 0.72rem;
  font-weight: 700;
  color: var(--ch-color, #38BDF8);
  flex-shrink: 0;
  z-index: 1;
}
.docs-step__connector {
  flex: 1;
  width: 2px;
  background: var(--border-default);
  margin: 4px 0;
}
.docs-step:last-child .docs-step__connector { display: none; }
.docs-step__body { padding-top: 4px; }
.docs-step__title {
  font-size: 0.9rem;
  font-weight: 700;
  color: var(--text-primary);
  margin: 0 0 4px;
}
.docs-step__desc {
  font-size: 0.85rem;
  color: var(--text-secondary);
  margin: 0;
  line-height: 1.6;
}
</style>

<script is:inline>
  // Highlight active right-sidebar TOC link on scroll
  (function () {
    const tocLinks = document.querySelectorAll('.docs-toc-link');
    if (!tocLinks.length) return;
    const sections = Array.from(document.querySelectorAll('.docs-section[id]'));

    function update() {
      const y = window.scrollY + 110;
      let active = sections[0];
      for (const s of sections) {
        if (s.offsetTop <= y) active = s;
      }
      tocLinks.forEach(l => {
        l.classList.toggle('active', l.getAttribute('href') === '#' + active?.id);
      });
    }
    window.addEventListener('scroll', update, { passive: true });
    update();
  })();
</script>
