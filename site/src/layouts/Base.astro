---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import BuildStatusBar from '../components/BuildStatusBar.astro';
import CommandPalette from '../components/CommandPalette.astro';
import OC from '../data/oc';

interface Props {
  title?: string;
  description?: string;
  currentPath?: string;
}

const {
  title = 'OpenCourses',
  description = 'Open-source curriculum, version-controlled and community-built. Every course is a repo.',
  currentPath = '/',
} = Astro.props;

const fullTitle = title === 'OpenCourses' ? title : `${title} — OpenCourses`;
const siteUrl = Astro.site?.toString() ?? 'https://manojpisini.github.io/opencourses';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const ocData = {
  COURSES: OC.COURSES.map(c => ({
    slug: c.slug, title: c.title, description: c.description,
    track: c.track, difficulty: c.difficulty, tags: c.tags || [],
    modules: c.modules, duration: c.duration,
  })),
  TRACKS: OC.TRACKS,
  CONTRIBUTORS: OC.CONTRIBUTORS,
  TRACK_COLORS: OC.TRACK_COLORS,
  GRAPH: OC.GRAPH,
  BASE_URL: base,
};
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="OpenCourses" />
    <meta property="og:image" content={`${siteUrl}${base}/og-image.svg`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={`${siteUrl}${base}/og-image.svg`} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=JetBrains+Mono:wght@400;500;600;700&family=Sora:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{fullTitle}</title>
    <script is:inline>
      (function(){try{var s=localStorage.getItem('oc-theme'),p=window.matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light';document.documentElement.dataset.theme=s||p;}catch(e){}})();
    </script>
  </head>
  <body>
    <BuildStatusBar />
    <Navbar currentPath={currentPath} />
    <main class="app-main">
      <slot />
    </main>
    <Footer />
    <CommandPalette />
    <!-- Inject OC data for client-side scripts -->
    <script is:inline define:vars={{ ocData }}>
      window.OC_COURSES      = ocData.COURSES;
      window.OC_TRACKS       = ocData.TRACKS;
      window.OC_CONTRIBUTORS = ocData.CONTRIBUTORS;
      window.OC_TRACK_COLORS = ocData.TRACK_COLORS;
      window.OC_GRAPH        = ocData.GRAPH;
      window.OC_BASE         = ocData.BASE_URL;
    </script>
    <!-- Global JS (theme, Ctrl+K, build bar) -->
    <script is:inline src={`${base}/js/oc.js`}></script>
  </body>
</html>
