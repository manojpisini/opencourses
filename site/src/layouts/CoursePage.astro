---
import Base from './Base.astro';
import TrackBadge from '../components/ui/TrackBadge.astro';
import TagChip from '../components/ui/TagChip.astro';
import ProgressRing from '../components/ui/ProgressRing.astro';
import CourseYAMLPanel from '../components/features/CourseYAMLPanel.astro';
import DiffView from '../components/ui/DiffView.astro';

interface Props {
  course: {
    slug: string;
    title: string;
    description: string;
    track: string;
    difficulty: string;
    modules: number;
    duration: string;
    updatedAt: string;
    status: string;
    tags: string[];
    stars: number;
    version: string;
    maintainer: string;
    repo: string;
    prerequisites: string[];
    language: string;
  };
}

const { course } = Astro.props;

const updatedDate = new Date(course.updatedAt);
const daysSince = Math.floor((Date.now() - updatedDate.getTime()) / 86400000);
const updatedLabel = daysSince === 0 ? 'Today' : daysSince === 1 ? '1d ago' : `${daysSince}d ago`;
---

<Base title={course.title} description={course.description}>
  <!-- Course header -->
  <div class="border-b border-[var(--border-subtle)]">
    <div class="container py-8">
      <nav class="flex items-center gap-2 text-sm text-[var(--text-muted)] mb-4 font-mono">
        <a href="/courses" class="hover:text-[var(--text-primary)] transition-colors">Courses</a>
        <span>›</span>
        <TrackBadge track={course.track} />
        <span>›</span>
        <span class="text-[var(--text-secondary)]">{course.title}</span>
      </nav>

      <div class="flex items-start justify-between gap-6 flex-wrap">
        <div>
          <div class="flex items-center gap-3 mb-3 flex-wrap">
            <h1 class="font-display text-4xl font-bold tracking-tight text-[var(--text-primary)]">
              {course.title}
            </h1>
            <span class="font-mono text-sm text-[var(--text-muted)] bg-[var(--bg-raised)] px-2 py-0.5 rounded border border-[var(--border-default)]">
              {course.version}
            </span>
          </div>
          <div class="flex items-center gap-4 text-sm text-[var(--text-muted)] flex-wrap">
            <span class="difficulty-badge" data-level={course.difficulty}>[{course.difficulty.toUpperCase()}]</span>
            <span class="font-mono">{course.modules} modules</span>
            <span class="font-mono">⏱ {course.duration}</span>
            <span class="font-mono">Updated {updatedLabel}</span>
            <span class="font-mono">★ {course.stars}</span>
          </div>
          <div class="flex gap-2 mt-3 flex-wrap">
            {course.tags.map(tag => <TagChip tag={tag} href={`/courses?tag=${tag}`} />)}
          </div>
        </div>

        <div class="flex gap-3">
          <a
            href={`https://github.com/${course.repo}`}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-secondary text-sm"
          >
            Fork on GitHub ↗
          </a>
          <a
            href={`https://github.com/${course.repo}/issues/new`}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-primary text-sm"
          >
            Enroll
          </a>
        </div>
      </div>

      <div class="flex gap-6 mt-4 border-t border-[var(--border-subtle)] pt-4">
        <button id="source-toggle" data-view="rendered" class="text-sm font-mono text-[var(--text-muted)] hover:text-[var(--text-primary)] transition-colors">
          Source
        </button>
        <a
          href={`https://github.com/${course.repo}/edit/main/README.md`}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm font-mono text-[var(--text-muted)] hover:text-[var(--text-primary)] transition-colors"
        >
          Suggest Edit ↗
        </a>
      </div>
    </div>
  </div>

  <!-- Course body -->
  <div class="container py-10">
    <div class="flex gap-10 items-start" style="flex-wrap: wrap;">
      <!-- Main content -->
      <div class="flex-1 min-w-0" style="min-width: 320px;">
        <div id="rendered-content">
          <slot />
        </div>
        <div id="source-content" hidden class="diff-view p-4 text-sm font-mono text-[var(--text-secondary)]">
          <p>Source view — raw Markdown content would be displayed here.</p>
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="w-72 flex-shrink-0 flex flex-col gap-6">
        <!-- YAML Panel -->
        <CourseYAMLPanel course={course} />

        <!-- Progress -->
        <div class="bg-[var(--bg-surface)] border border-[var(--border-default)] rounded-card p-4">
          <div class="flex items-center justify-between mb-3">
            <span class="text-sm font-mono text-[var(--text-muted)] uppercase tracking-widest">Progress</span>
            <ProgressRing percent={0} size={48} />
          </div>
          <p class="text-sm text-[var(--text-muted)] font-mono">0 / {course.modules} modules</p>
          <p class="text-xs text-[var(--text-muted)] mt-1">Progress saved locally</p>
        </div>

        <!-- Related / contribute -->
        <div class="bg-[var(--bg-surface)] border border-[var(--border-default)] rounded-card p-4">
          <p class="text-sm font-mono text-[var(--text-muted)] uppercase tracking-widest mb-3">Contribute</p>
          <div class="flex flex-col gap-2">
            <a href={`https://github.com/${course.repo}/fork`} target="_blank" rel="noopener" class="text-sm text-[var(--accent-blue)] hover:underline font-mono">Fork on GitHub →</a>
            <a href={`https://github.com/${course.repo}/issues/new`} target="_blank" rel="noopener" class="text-sm text-[var(--accent-blue)] hover:underline font-mono">Open Issue →</a>
          </div>
        </div>
      </aside>
    </div>
  </div>

  <script>
    const toggle = document.getElementById('source-toggle');
    const rendered = document.getElementById('rendered-content');
    const source = document.getElementById('source-content');
    toggle?.addEventListener('click', () => {
      const isSource = toggle.dataset.view === 'source';
      toggle.dataset.view = isSource ? 'rendered' : 'source';
      toggle.textContent = isSource ? 'Source' : 'Rendered';
      if (rendered) rendered.hidden = !isSource;
      if (source) source.hidden = isSource;
    });
  </script>
</Base>
