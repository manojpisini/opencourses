---
import StatCard from '../ui/StatCard.astro';
import stats from '../../data/stats.json';
---

<section class="hero">
  <div class="relative z-10">
    <h1 class="hero__title">
      Learning,<br />
      in the open.
    </h1>
    <p class="hero__subtitle">
      Open-source curriculum, version-controlled and community-built.
      Courses live in Git. Grades run in Actions. Certificates are signed with GPG.
    </p>
    <div class="hero__ctas">
      <a href="/courses" class="btn-primary">
        Explore Courses ›
      </a>
      <a href="/tracks" class="btn-secondary">
        View Tracks
      </a>
    </div>
  </div>

  <div class="hero__stats">
    <StatCard number={stats.courses} label="Courses" />
    <StatCard number={stats.contributors} label="Contributors" />
    <StatCard number={stats.stars.toLocaleString()} label="Stars" />
    <StatCard number={stats.certified} label="Certified" />
  </div>
</section>
