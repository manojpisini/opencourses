---
import CourseCard from '../ui/CourseCard.astro';
import courses from '../../data/courses.json';

const featured = courses
  .filter(c => c.status === 'added' || c.stars > 300)
  .sort((a, b) => b.stars - a.stars)
  .slice(0, 6);
---

<section>
  <div class="container">
    <div class="flex items-center justify-between mb-6">
      <h2 class="font-display text-2xl font-bold text-[var(--text-primary)]">Featured Courses</h2>
      <a href="/courses" class="text-sm font-mono text-[var(--accent-blue)] hover:underline">
        View all {courses.length} →
      </a>
    </div>
    <div class="courses-rail">
      {featured.map((course, i) => (
        <CourseCard
          title={course.title}
          description={course.description}
          slug={course.slug}
          difficulty={course.difficulty as any}
          modules={course.modules}
          duration={course.duration}
          updatedAt={course.updatedAt}
          status={course.status as any}
          tags={course.tags}
          track={course.track}
          stars={course.stars}
          index={i}
        />
      ))}
    </div>
  </div>
</section>
