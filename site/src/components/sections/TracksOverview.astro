---
import courses from '../../data/courses.json';

const trackColors: Record<string, string> = {
  foundations: '#4f9eff',
  languages:   '#a78bfa',
  web:         '#4f9eff',
  devops:      '#34d399',
  data:        '#f5c542',
  craft:       '#fb923c',
  architecture:'#e879f9',
  security:    '#f87171',
  emerging:    '#22d3ee',
};

const trackEmoji: Record<string, string> = {
  foundations: '🟢',
  languages:   '💜',
  web:         '🔵',
  devops:      '🚀',
  data:        '📊',
  craft:       '🔨',
  architecture:'🏗',
  emerging:    '⚡',
};

// Aggregate tracks from courses
const trackMap = new Map<string, { count: number; difficulties: string[] }>();

for (const course of courses) {
  const t = course.track;
  if (!trackMap.has(t)) trackMap.set(t, { count: 0, difficulties: [] });
  const entry = trackMap.get(t)!;
  entry.count++;
  entry.difficulties.push(course.difficulty);
}

const tracks = Array.from(trackMap.entries()).map(([name, data]) => ({
  name,
  count: data.count,
  color: trackColors[name] ?? '#4f9eff',
  emoji: trackEmoji[name] ?? '📚',
}));
---

<section class="bg-[var(--bg-surface)] border-y border-[var(--border-subtle)]">
  <div class="container">
    <div class="flex items-center justify-between mb-6">
      <h2 class="font-display text-2xl font-bold text-[var(--text-primary)]">Learning Tracks</h2>
      <a href="/tracks" class="text-sm font-mono text-[var(--accent-blue)] hover:underline">Curriculum Map →</a>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
      {tracks.map(track => (
        <a
          href={`/courses?track=${track.name}`}
          class="flex items-center gap-3 p-3 rounded-card border border-[var(--border-default)] bg-[var(--bg-base)] hover:border-[var(--accent-blue)] hover:bg-[var(--bg-raised)] transition-all group"
          style={`--track-color: ${track.color}`}
        >
          <span class="text-lg">{track.emoji}</span>
          <div class="min-w-0">
            <div class="text-sm font-medium text-[var(--text-primary)] capitalize truncate group-hover:text-[var(--accent-blue)] transition-colors">
              {track.name}
            </div>
            <div class="text-xs font-mono text-[var(--text-muted)]">{track.count} course{track.count !== 1 ? 's' : ''}</div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
