---
import changelog from '../../data/changelog.json';

const recent = changelog.slice(0, 3);

const typeIcon: Record<string, string> = {
  added: '+', removed: '-', modified: '~',
};
const typeColor: Record<string, string> = {
  added: 'var(--git-added)', removed: 'var(--git-attention)', modified: 'var(--git-modified)',
};
---

<section class="bg-[var(--bg-surface)] border-y border-[var(--border-subtle)]">
  <div class="container">
    <div class="flex items-center justify-between mb-6">
      <h2 class="font-display text-2xl font-bold text-[var(--text-primary)]">Recent Updates</h2>
      <a href="/changelog" class="text-sm font-mono text-[var(--accent-blue)] hover:underline">Full changelog →</a>
    </div>

    <div class="flex flex-col gap-4">
      {recent.map(entry => (
        <div class="bg-[var(--bg-base)] border border-[var(--border-default)] rounded-card p-4">
          <div class="flex items-center gap-3 mb-3">
            <a href={`/courses/${entry.slug}`} class="font-medium text-[var(--text-primary)] hover:text-[var(--accent-blue)] transition-colors">
              {entry.course}
            </a>
            <span class="font-mono text-xs text-[var(--text-muted)] bg-[var(--bg-raised)] px-2 py-0.5 rounded border border-[var(--border-default)]">
              {entry.version}
            </span>
            <span class="font-mono text-xs text-[var(--text-muted)] ml-auto">
              {new Date(entry.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
            </span>
          </div>
          <ul class="flex flex-col gap-1">
            {entry.changes.slice(0, 3).map(change => (
              <li class="flex items-start gap-2 text-sm">
                <span class="font-mono font-bold flex-shrink-0" style={`color: ${typeColor[change.type]}`}>
                  {typeIcon[change.type]}
                </span>
                <span class="text-[var(--text-secondary)]">{change.text}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
