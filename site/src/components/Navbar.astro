---
interface Props { currentPath: string; }
const { currentPath } = Astro.props;

const NAV_ITEMS = [
  { path: '/courses', label: 'Courses' },
  { path: '/tracks', label: 'Tracks' },
  { path: '/docs', label: 'Docs' },
  { path: '/contributors', label: 'Contributors' },
  { path: '/leaderboard', label: 'Leaderboard' },
  { path: '/changelog', label: 'Changelog' },
  { path: '/about', label: 'About' },
];
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<header class="navbar">
  <div class="container navbar__inner">
    <a href={`${base}/`} class="wordmark" aria-label="OpenCourses home">
      <svg class="wordmark__icon-svg" width="24" height="24" viewBox="0 0 40 40"
           fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect width="40" height="40" rx="9" fill="#38BDF8"/>
        <rect x="5.5" y="5.5" width="29" height="29" rx="5" fill="#0a1e1e"/>
        <rect x="10" y="11" width="20" height="2.5" rx="1.25" fill="#38BDF8"/>
        <rect x="10" y="16" width="13" height="2.5" rx="1.25" fill="#2DD4BF"/>
        <rect x="10" y="21" width="16" height="2.5" rx="1.25" fill="#38BDF8" opacity="0.6"/>
        <rect x="10" y="26" width="9"  height="2.5" rx="1.25" fill="#2DD4BF" opacity="0.5"/>
        <rect x="23.5" y="22.5" width="9" height="9" rx="2.5" fill="#38BDF8"/>
        <path d="M26 25 L28 27 M28 25 L26 27"
              stroke="#0a1e1e" stroke-width="1.2" stroke-linecap="round"/>
      </svg>
      <span class="wordmark__text"><span class="wordmark__open">Open</span><span class="wordmark__courses">Courses</span></span>
    </a>
    <nav class="nav-links">
      {NAV_ITEMS.map(n => (
        <a
          href={`${base}${n.path}`}
          class="nav-link"
          aria-current={currentPath.startsWith(n.path) ? 'page' : undefined}
        >
          {n.label}
        </a>
      ))}
    </nav>
    <div class="nav-actions">
      <a href={`${base}/support`} class="support-pill">
        Support
      </a>
      <button class="search-trigger" id="cmd-trigger" aria-label="Search (Ctrl+K)">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
        <span>Search courses…</span>
        <span class="search-trigger__kbd">⌘K</span>
      </button>
      <button class="icon-btn" id="theme-toggle" aria-label="Toggle theme">
        <span id="theme-icon">☀</span>
      </button>
      <a href="https://github.com/manojpisini/opencourses" class="icon-btn" target="_blank" rel="noopener" aria-label="GitHub">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2c-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.27-1.68-1.27-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.69 1.25 3.34.96.1-.74.4-1.25.72-1.54-2.55-.29-5.23-1.28-5.23-5.69 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.17 1.18a11 11 0 0 1 5.78 0c2.2-1.49 3.17-1.18 3.17-1.18.62 1.58.23 2.75.11 3.04.74.81 1.18 1.84 1.18 3.1 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.06.78 2.14v3.17c0 .31.21.67.8.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5Z"/></svg>
      </a>
    </div>
  </div>
</header>
