---
interface DiffLine {
  type: 'added' | 'removed' | 'context';
  text: string;
}

interface Props {
  lines: DiffLine[];
  title?: string;
}

const { lines, title } = Astro.props;
---

<div class="diff-view">
  {title && (
    <div class="px-4 py-2 border-b border-[var(--border-subtle)] text-xs font-mono text-[var(--text-muted)]">
      {title}
    </div>
  )}
  <div class="p-2">
    {lines.map(line => (
      <div class={`diff-line diff-line--${line.type}`}>
        <span class="diff-line__marker">
          {line.type === 'added' ? '+' : line.type === 'removed' ? '-' : ' '}
        </span>
        <span>{line.text}</span>
      </div>
    ))}
  </div>
</div>
