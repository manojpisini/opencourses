---
interface Props {
  title: string;
  description: string;
  slug: string;
  difficulty: 'beginner' | 'intermediate' | 'advanced' | 'draft';
  modules: number;
  duration: string;
  updatedAt: string;
  status: 'added' | 'modified' | 'attention' | 'stable';
  tags: string[];
  track: string;
  stars?: number;
  index?: number;
}

const {
  title, description, slug, difficulty, modules,
  duration, updatedAt, status, tags, track, stars = 0, index = 0,
} = Astro.props;

const statusSymbols: Record<string, string> = {
  added: '+', modified: '~', attention: '!', stable: '·',
};

const updatedDate = new Date(updatedAt);
const daysSince = Math.floor((Date.now() - updatedDate.getTime()) / 86400000);
const updatedLabel = daysSince === 0 ? 'Today'
  : daysSince === 1 ? '1d ago'
  : daysSince < 7 ? `${daysSince}d ago`
  : daysSince < 30 ? `${Math.floor(daysSince / 7)}w ago`
  : `${Math.floor(daysSince / 30)}mo ago`;
---

<a
  href={`/courses/${slug}`}
  class="course-card"
  data-level={difficulty}
  style={`--index: ${index}`}
  aria-label={`${title} — ${difficulty} course`}
>
  <div class="flex items-start justify-between gap-3">
    <div class="flex items-center gap-2 min-w-0">
      <span class="git-status flex-shrink-0" data-status={status} title={status}>
        {statusSymbols[status]}
      </span>
      <h3 class="font-display font-semibold text-[var(--text-primary)] text-lg leading-tight truncate">
        {title}
      </h3>
    </div>
    <span class="difficulty-badge flex-shrink-0" data-level={difficulty}>
      [{difficulty.toUpperCase()}]
    </span>
  </div>

  <p class="text-sm text-[var(--text-secondary)] line-clamp-2 leading-relaxed">
    {description}
  </p>

  <div class="border-t border-[var(--border-subtle)] pt-3 flex items-center justify-between gap-2">
    <div class="flex items-center gap-3 text-xs font-mono text-[var(--text-muted)] flex-wrap">
      <span>📦 {modules} modules</span>
      <span>⏱ {duration}</span>
      <span>🕐 {updatedLabel}</span>
    </div>
    {stars > 0 && (
      <span class="text-xs font-mono text-[var(--text-muted)] flex-shrink-0">★ {stars}</span>
    )}
  </div>
</a>
