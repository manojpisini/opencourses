---
interface Props {
  login: string;
  avatarUrl: string;
  size?: 'xs' | 'sm' | 'md' | 'lg' | 'xl';
  showTooltip?: boolean;
}

const { login, avatarUrl, size = 'md', showTooltip = true } = Astro.props;
---

<a
  href={`https://github.com/${login}`}
  target="_blank"
  rel="noopener noreferrer"
  class={`contributor-avatar contributor-avatar--${size}`}
  title={showTooltip ? `@${login}` : undefined}
  aria-label={`@${login} on GitHub`}
>
  <img src={avatarUrl} alt={login} loading="lazy" width="64" height="64" />
</a>
