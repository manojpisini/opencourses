---
interface Props {
  course: {
    slug: string;
    title: string;
    track: string;
    difficulty: string;
    duration: string;
    modules: number;
    language: string;
    maintainer: string;
    updatedAt: string;
    version: string;
    repo: string;
  };
}

const { course } = Astro.props;
const updated = new Date(course.updatedAt).toISOString().split('T')[0];
---

<details class="yaml-panel" open>
  <summary>
    <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor" style="transition: transform 150ms">
      <path d="M2 4l4 4 4-4"/>
    </svg>
    Course Metadata
  </summary>
  <pre><code
    ><span class="yaml-comment"># {course.slug}</span>
<span class="yaml-key">title</span>:        <span class="yaml-value">{course.title}</span>
<span class="yaml-key">track</span>:        <span class="yaml-value">{course.track}</span>
<span class="yaml-key">difficulty</span>:   <span class="yaml-value">{course.difficulty}</span>
<span class="yaml-key">duration</span>:     <span class="yaml-value">{course.duration}</span>
<span class="yaml-key">modules</span>:      <span class="yaml-num">{course.modules}</span>
<span class="yaml-key">language</span>:     <span class="yaml-value">{course.language}</span>
<span class="yaml-key">maintainer</span>:   <span class="yaml-value">@{course.maintainer}</span>
<span class="yaml-key">updated</span>:      <span class="yaml-value">{updated}</span>
<span class="yaml-key">version</span>:      <span class="yaml-tag">{course.version}</span>
<span class="yaml-key">repo</span>:         <span class="yaml-value">{course.repo}</span></code></pre>
</details>
