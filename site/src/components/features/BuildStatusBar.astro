---

<div class="build-status-bar" id="build-status-bar" data-status="success" aria-hidden="true"></div>

<script>
  async function fetchBuildStatus() {
    try {
      const res = await fetch(
        'https://api.github.com/repos/opencourse/engine/actions/runs?per_page=1',
        { headers: { Accept: 'application/vnd.github+json' } }
      );
      if (!res.ok) return;
      const data = await res.json();
      const run = data.workflow_runs?.[0];
      if (!run) return;
      const bar = document.getElementById('build-status-bar');
      if (!bar) return;
      const statusMap: Record<string, string> = {
        completed: run.conclusion === 'success' ? 'success' : 'failure',
        in_progress: 'running',
        queued: 'running',
        failure: 'failure',
        cancelled: 'warning',
      };
      bar.dataset.status = statusMap[run.status] ?? 'success';
    } catch {
      // silently fail — non-critical UI
    }
  }

  fetchBuildStatus();
</script>
