---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<footer class="app-footer">
  <div class="container">
    <div class="app-footer__grid">
      <div>
        <a href={`${base}/`} class="wordmark" aria-label="OpenCourses home">
          <svg class="wordmark__icon-svg" width="20" height="20" viewBox="0 0 40 40"
               fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect width="40" height="40" rx="9" fill="#38BDF8"/>
            <rect x="5.5" y="5.5" width="29" height="29" rx="5" fill="#0a1e1e"/>
            <rect x="10" y="11" width="20" height="2.5" rx="1.25" fill="#38BDF8"/>
            <rect x="10" y="16" width="13" height="2.5" rx="1.25" fill="#2DD4BF"/>
            <rect x="10" y="21" width="16" height="2.5" rx="1.25" fill="#38BDF8" opacity="0.6"/>
            <rect x="10" y="26" width="9"  height="2.5" rx="1.25" fill="#2DD4BF" opacity="0.5"/>
            <rect x="23.5" y="22.5" width="9" height="9" rx="2.5" fill="#38BDF8"/>
            <path d="M26 25 L28 27 M28 25 L26 27"
                  stroke="#0a1e1e" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
          <span class="wordmark__text"><span class="wordmark__open">Open</span><span class="wordmark__courses">Courses</span></span>
        </a>
        <p style="color:var(--text-secondary);font-size:14px;margin-top:12px;max-width:320px">
          Open-source curriculum, version-controlled. Built by the community, for the community.
        </p>
      </div>
      <div>
        <h4>Learn</h4>
        <ul>
          <li><a href={`${base}/courses`}>All courses</a></li>
          <li><a href={`${base}/tracks`}>Tracks</a></li>
          <li><a href={`${base}/docs`}>Documentation</a></li>
          <li><a href={`${base}/changelog`}>Changelog</a></li>
        </ul>
      </div>
      <div>
        <h4>Community</h4>
        <ul>
          <li><a href={`${base}/contributors`}>Contributors</a></li>
          <li><a href={`${base}/leaderboard`}>Leaderboard</a></li>
          <li><a href={`${base}/about`}>About</a></li>
          <li><a href="https://github.com/manojpisini/opencourses" target="_blank" rel="noopener">GitHub</a></li>
        </ul>
      </div>
      <div>
        <h4>Meta</h4>
        <ul>
          <li><a href="https://github.com/manojpisini/opencourses/blob/main/LICENSE" target="_blank" rel="noopener">MIT License</a></li>
          <li><a href={`${base}/sitemap.xml`}>Sitemap</a></li>
          <li><a href="https://github.com/manojpisini/opencourses/issues">Issues</a></li>
        </ul>
      </div>
    </div>
    <div class="app-footer__bar">
      <span class="deploy-badge">Live · Built on push</span>
      <span>manojpisini.github.io/opencourses · v1.0.0</span>
    </div>
  </div>
</footer>
