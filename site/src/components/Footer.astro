---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<footer class="app-footer">
  <div class="container">
    <div class="app-footer__grid">
      <div>
        <a href={`${base}/`} class="wordmark" aria-label="OpenCourses home">
          <img class="wordmark__logo wordmark__logo--dark" src={`${base}/brand/Full%20Logo%20-%20Stacked%20-%20Dark.svg`} width="132" height="53" alt="OpenCourses" />
          <img class="wordmark__logo wordmark__logo--light" src={`${base}/brand/Full%20Logo%20-%20Stacked%20-%20Light.svg`} width="132" height="53" alt="OpenCourses" />
        </a>
        <p style="color:var(--text-secondary);font-size:14px;margin-top:12px;max-width:320px">
          Open-source curriculum, version-controlled. Built by the community, for the community.
        </p>
      </div>
      <div>
        <h4>Learn</h4>
        <ul>
          <li><a href={`${base}/courses`}>All courses</a></li>
          <li><a href={`${base}/tracks`}>Tracks</a></li>
          <li><a href={`${base}/docs`}>Documentation</a></li>
          <li><a href={`${base}/changelog`}>Changelog</a></li>
        </ul>
      </div>
      <div>
        <h4>Community</h4>
        <ul>
          <li><a href={`${base}/support`}>Support OpenCourses</a></li>
          <li><a href={`${base}/contributors`}>Contributors</a></li>
          <li><a href={`${base}/leaderboard`}>Leaderboard</a></li>
          <li><a href={`${base}/about`}>About</a></li>
          <li><a href="https://github.com/manojpisini/opencourses" target="_blank" rel="noopener">GitHub</a></li>
        </ul>
      </div>
      <div>
        <h4>Meta</h4>
        <ul>
          <li><a href="https://github.com/manojpisini/opencourses/blob/main/LICENSE" target="_blank" rel="noopener">MIT License</a></li>
          <li><a href={`${base}/sitemap.xml`}>Sitemap</a></li>
          <li><a href="https://github.com/manojpisini/opencourses/issues">Issues</a></li>
        </ul>
      </div>
    </div>
    <div class="app-footer__bar">
      <span class="deploy-badge">Live · Built on push</span>
      <span><a href={`${base}/support`}>Donate / Help / Contribute</a> · manojpisini.github.io/opencourses · v1.0.0</span>
    </div>
  </div>
</footer>
