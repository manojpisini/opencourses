---
import OC from '../data/oc';

interface Props {
  login: string;
  size?: 'xs' | 'sm' | 'md' | 'lg' | 'xl' | '2xl';
}
const { login, size = 'md' } = Astro.props;

const c        = OC.CONTRIBUTORS.find(x => x.login === login);
const hue      = c ? c.hue : (login.charCodeAt(0) * 7) % 360;
const hue2     = (hue + 40) % 360;
const name     = c ? c.name : login || '?';
const initials = name.split(' ').map((s: string) => s[0]).slice(0, 2).join('').toUpperCase();
const bg       = `linear-gradient(135deg,hsl(${hue} 70% 38%) 0%,hsl(${hue2} 60% 24%) 100%)`;
const ghSrc    = `https://github.com/${login}.png?size=160`;
---

<!--
  Tries GitHub profile picture; on error hides the <img> and
  reveals the coloured-initials SVG fallback.
-->
<span class={`avatar avatar--${size}`} title={`@${login}`}>
  <img
    class="avatar__photo"
    src={ghSrc}
    alt={`@${login}`}
    loading="lazy"
    decoding="async"
    onerror="this.hidden=true;this.nextElementSibling.removeAttribute('hidden')"
  />
  <svg class="avatar__fallback" viewBox="0 0 100 100"
    style={`background:${bg}`} hidden aria-hidden="true">
    <circle cx="20" cy="30" r="14" fill="rgba(255,255,255,0.12)" />
    <circle cx="78" cy="72" r="22" fill="rgba(0,0,0,0.18)" />
    <text x="50" y="56" text-anchor="middle" font-size="34"
      font-family="system-ui,sans-serif" font-weight="700"
      fill="rgba(255,255,255,0.92)">{initials}</text>
  </svg>
</span>
