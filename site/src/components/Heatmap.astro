---
import OC from '../data/oc';

const weeks = OC.activity;
const cellSize = 11;
const cellGap = 3;
const W = weeks.length * (cellSize + cellGap);
const monthLabels = ['May','Jun','Jul','Aug','Sep','Oct','Nov','Dec','Jan','Feb','Mar','Apr'];

function colorFor(c: number): string {
  if (c === 0) return 'var(--bg-raised)';
  if (c <= 2) return 'rgba(var(--accent-blue-rgb), 0.3)';
  if (c <= 5) return 'rgba(var(--accent-blue-rgb), 0.6)';
  return 'rgba(var(--accent-blue-rgb), 1)';
}
---
<div class="heatmap">
  <svg class="heatmap__svg" viewBox={`0 0 ${W} ${cellSize * 8 + 14}`}>
    {monthLabels.map((m, i) => (
      <text x={i * (W / 12) + 4} y="10" font-family="var(--font-mono)" font-size="9" fill="var(--text-muted)">{m}</text>
    ))}
    <g transform="translate(0,14)">
      {weeks.map((days, wi) =>
        days.map((c, di) => (
          <rect
            x={wi * (cellSize + cellGap)}
            y={di * (cellSize + cellGap)}
            width={cellSize}
            height={cellSize}
            rx="2"
            fill={colorFor(c)}
          >
            <title>{c} update{c !== 1 ? 's' : ''}</title>
          </rect>
        ))
      )}
    </g>
  </svg>
  <div class="heatmap__legend">
    <span>Less</span>
    {[0, 1, 4, 8].map(c => <span class="heatmap__legend-cell" style={`background:${colorFor(c)}`} />)}
    <span>More</span>
  </div>
</div>
