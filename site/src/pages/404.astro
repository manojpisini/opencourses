---
import Base from '../layouts/Base.astro';
import CourseCard from '../components/CourseCard.astro';
import OC from '../data/oc';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const suggestions = OC.COURSES.slice(0, 3);
---

<Base title="404 — Not Found">
  <div class="container" style="padding-top:6rem;padding-bottom:6rem;text-align:center">
    <div style="font-family:var(--font-mono);font-size:6rem;font-weight:900;color:var(--text-primary);opacity:0.1;line-height:1;letter-spacing:-0.06em">
      404
    </div>
    <h1 style="margin-top:-2rem;margin-bottom:0.5rem;font-size:1.5rem;font-weight:700;color:var(--text-primary)">
      This course doesn't exist yet.
    </h1>
    <p style="color:var(--text-secondary);margin-bottom:2rem">Maybe you can create it.</p>

    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
      <a
        href="https://github.com/manojpisini/opencourses/issues/new"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-primary"
      >
        Suggest a Course →
      </a>
      <a href={`${base}/`} class="btn btn-secondary">Go Home</a>
    </div>

    <div class="section-divider" style="max-width:32rem;margin-left:auto;margin-right:auto"></div>

    <p style="font-family:var(--font-mono);font-size:0.8rem;color:var(--text-muted);margin-bottom:1.5rem">
      Or maybe you were looking for one of these:
    </p>
    <div class="course-grid" style="max-width:56rem;margin-left:auto;margin-right:auto;text-align:left">
      {suggestions.map(course => (
        <CourseCard course={course} />
      ))}
    </div>
  </div>
</Base>
