---
import Base from '../layouts/Base.astro';
import Avatar from '../components/Avatar.astro';
import OC from '../data/oc';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const maintainers = OC.CONTRIBUTORS.filter(c => c.role.startsWith('Maintainer') || c.role === 'Lead Maintainer');
const showLeadCard = !maintainers.find(m => m.login === 'manojpisini');

const stack = [
  { name: 'Astro 4',        role: 'Site framework — zero-JS by default, islands architecture' },
  { name: 'Custom CSS',     role: 'Styling — design token system, no utility framework' },
  { name: 'Vanilla JS',     role: 'Track map, catalog filter, command palette' },
  { name: 'Bun',            role: 'Runtime & package manager for the engine scripts' },
  { name: 'GitHub Actions', role: 'Data pipeline, grading, certification, deploy' },
  { name: 'GitHub Pages',   role: 'Hosting — free, native org pages support' },
  { name: 'GitHub API',     role: 'Live data — stars, forks, contributors, commit activity' },
  { name: 'Docker',         role: 'Isolated sandbox for grading code submissions' },
];
---

<Base title="About" description="What OpenCourses is, how it works, and who builds it.">
  <div class="container">
    <div class="page-head">
      <div class="page-head__crumbs">
        <a href={`${base}/`}>~</a>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        <span>about</span>
      </div>
      <h1 class="page-head__title">About OpenCourses</h1>
      <p class="page-head__sub">Free, open-source developer education. Version-controlled by design.</p>
    </div>

    <!-- Docs callout -->
    <div class="about-docs-callout">
      <span class="about-docs-callout__label">📖 Looking for guides?</span>
      <span class="about-docs-callout__text">
        Step-by-step instructions for students, course creators, and code contributors are in the
        <a href={`${base}/docs`}>Documentation →</a>
      </span>
    </div>

    <div class="container-narrow">
      <!-- What it is -->
      <section class="section" id="what">
        <div class="section-head">
          <h2 class="section-head__title">What OpenCourses Is</h2>
        </div>
        <div class="prose">
          <p>
            OpenCourses is a free, open-source developer education platform built entirely on GitHub infrastructure.
            No login. No proprietary LMS. No vendor lock-in.
          </p>
          <p>
            Courses live in Git repositories. Every piece of content has a commit history.
            Every contributor is credited like an open-source maintainer.
            The entire site regenerates automatically on every push.
          </p>
          <p>
            Enrollment, grading, certification, and the leaderboard all run through GitHub Issues and Actions —
            your GitHub <code>@username</code> is the only identity you need.
            It is the first course platform that feels <em>version-controlled by design</em>.
          </p>
        </div>
      </section>

      <div class="section-divider"></div>

      <!-- Maintainers -->
      <section class="section" id="maintainers">
        <div class="section-head">
          <h2 class="section-head__title">Maintainers</h2>
        </div>
        <div style="display:flex;flex-wrap:wrap;gap:12px">
          {/* Lead maintainer is always shown, even when CONTRIBUTORS is empty */}
          {showLeadCard && (
            <a
              href={`${base}/contributors/manojpisini`}
              class="contributor-card"
              style="text-decoration:none"
            >
              <Avatar login="manojpisini" size="md" />
              <div>
                <div class="contributor-card__name">Manoj Pisini</div>
                <div class="contributor-card__role">@manojpisini · Lead Maintainer</div>
              </div>
            </a>
          )}
          {maintainers.map(m => (
            <a
              href={`${base}/contributors/${m.login}`}
              class="contributor-card"
              style="text-decoration:none"
            >
              <Avatar login={m.login} size="md" />
              <div>
                <div class="contributor-card__name">{m.name}</div>
                <div class="contributor-card__role">@{m.login} · {m.role}</div>
              </div>
            </a>
          ))}
        </div>
      </section>

      <div class="section-divider"></div>

      <!-- Tech stack -->
      <section class="section" id="stack">
        <div class="section-head">
          <h2 class="section-head__title">Tech Stack</h2>
        </div>
        <ul class="prose" style="list-style:none;padding:0;display:flex;flex-direction:column;gap:0.75rem">
          {stack.map(item => (
            <li style="display:flex;align-items:flex-start;gap:0.75rem;font-size:0.9rem">
              <code style="font-family:var(--font-mono);color:var(--accent-blue);background:var(--bg-raised);border:1px solid var(--border-default);border-radius:4px;padding:2px 8px;white-space:nowrap;flex-shrink:0">
                {item.name}
              </code>
              <span style="color:var(--text-secondary);margin-top:2px">{item.role}</span>
            </li>
          ))}
        </ul>
      </section>

      <div class="section-divider"></div>

      <!-- License -->
      <section class="section" id="license">
        <div class="section-head">
          <h2 class="section-head__title">License</h2>
        </div>
        <div class="prose">
          <p>
            <strong>Course content</strong> —
            <a href="https://creativecommons.org/licenses/by/4.0/" target="_blank" rel="noopener">CC BY 4.0</a>.
            Use it, fork it, translate it. Credit required.
          </p>
          <p>
            <strong>Engine &amp; site code</strong> —
            <a href="https://opensource.org/licenses/MIT" target="_blank" rel="noopener">MIT</a>.
            Fork it, run your own instance.
          </p>
        </div>
      </section>
    </div>
  </div>
</Base>

<style>
  .about-docs-callout {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem 0.75rem;
    padding: 0.75rem 1rem;
    margin-bottom: 2rem;
    background: var(--bg-surface);
    border: 1px solid var(--border-default);
    border-left: 3px solid var(--accent-blue, #4f9eff);
    border-radius: 6px;
    font-size: 0.875rem;
  }
  .about-docs-callout__label {
    font-weight: 600;
    color: var(--text-primary);
    white-space: nowrap;
  }
  .about-docs-callout__text {
    color: var(--text-secondary);
  }
  .about-docs-callout__text a {
    color: var(--accent-blue, #4f9eff);
    text-decoration: none;
    font-weight: 500;
  }
  .about-docs-callout__text a:hover { text-decoration: underline; }
</style>
