---
import Base from '../layouts/Base.astro';
import Avatar from '../components/Avatar.astro';
import OC from '../data/oc';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const maintainers = OC.CONTRIBUTORS.filter(c => c.role.startsWith('Maintainer')).slice(0, 4);

const howItWorks = [
  { step: '01', title: 'Enroll',    desc: 'Open an enrollment issue. Your GitHub @username is your sole identity — no separate login needed.' },
  { step: '02', title: 'Learn',     desc: 'Work through the course content: lessons, readings, and exercises defined in course.md.' },
  { step: '03', title: 'Test',      desc: 'Open a quiz-submit issue with your answers. Supports MCQ, multi-select, true/false, short-answer, and code.' },
  { step: '04', title: 'Graded',    desc: 'GitHub Actions scores your submission algorithmically — no AI. Code questions run in an isolated Docker sandbox.' },
  { step: '05', title: 'Complete',  desc: 'Pass all chapter tests. If a final exam is required, it unlocks automatically. Your rank appears on the leaderboard.' },
  { step: '06', title: 'Certified', desc: 'Receive a GPG-signed SVG certificate as a GitHub Release, compliant with Open Badges 3.0.' },
];

const contributeSteps = [
  'Copy engine/courses/template/ to engine/courses/<your-slug>/ and edit course.md.',
  'Define lessons, chapter tests, and optional projects. course.md is the single source of truth.',
  'Add dynamic test generators to assets/tests/ for code questions — students never see the same inputs twice.',
  'Keep reference solutions in assets/solutions/ (gitignored — never used by the grader).',
  'Open a PR — the course-publish workflow validates course.md on merge and emits course.json.',
];

const improveSteps = [
  'Find an issue at github.com/manojpisini/opencourses — look for "help wanted".',
  'Fork the repo and make changes on a feature branch.',
  'Open a PR with a clear description of what changed and why.',
  'A maintainer will review within 7 days.',
];

const stack = [
  { name: 'Astro 4', role: 'Site framework — zero-JS by default, islands architecture' },
  { name: 'Custom CSS', role: 'Styling — design token system, no utility framework' },
  { name: 'Vanilla JS', role: 'Knowledge graph, catalog filter, command palette' },
  { name: 'GitHub Actions', role: 'Data pipeline, OG image generation, deploy' },
  { name: 'GitHub Pages', role: 'Hosting — free, native org pages support' },
  { name: 'GitHub API', role: 'Live data — stars, forks, contributors, build status' },
];
---

<Base title="About" description="What OpenCourses is, how it works, and how to contribute.">
  <div class="container">
    <div class="page-head">
      <div class="page-head__crumbs">
        <a href={`${base}/`}>~</a>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        <span>about</span>
      </div>
      <h1 class="page-head__title">About OpenCourses</h1>
      <p class="page-head__sub">Free, open-source developer education. Version-controlled by design.</p>
    </div>

    <div class="container-narrow">
      <!-- What it is -->
      <section class="section" id="what">
        <div class="section-head">
          <h2 class="section-head__title">What OpenCourses Is</h2>
        </div>
        <div class="prose">
          <p>
            OpenCourses is a free, open-source developer education platform built entirely on GitHub infrastructure.
            No login. No proprietary LMS. No vendor lock-in.
          </p>
          <p>
            Courses live in Git repositories. Every piece of content has a commit history.
            Every contributor is credited like an open-source maintainer.
            The entire site regenerates automatically on every push.
          </p>
          <p>
            It is not a MOOC. It is not a wiki. It is the first course platform that feels
            <em>version-controlled by design</em>.
          </p>
        </div>
      </section>

      <div class="section-divider"></div>

      <!-- How it works -->
      <section class="section" id="how-it-works">
        <div class="section-head">
          <h2 class="section-head__title">How It Works</h2>
        </div>
        <ol class="prose" style="list-style:none;padding:0;display:flex;flex-direction:column;gap:1rem">
          {howItWorks.map(item => (
            <li style="display:flex;gap:1rem;align-items:flex-start">
              <code style="font-family:var(--font-mono);font-size:0.75rem;color:var(--text-muted);background:var(--bg-raised);border:1px solid var(--border-default);border-radius:4px;padding:2px 8px;flex-shrink:0;margin-top:2px">
                {item.step}
              </code>
              <div>
                <strong style="color:var(--text-primary)">{item.title}</strong>
                <span style="color:var(--text-secondary);margin-left:0.5rem">— {item.desc}</span>
              </div>
            </li>
          ))}
        </ol>
      </section>

      <div class="section-divider"></div>

      <!-- Contribute a course -->
      <section class="section" id="contribute">
        <div class="section-head">
          <h2 class="section-head__title">How to Contribute a Course</h2>
        </div>
        <ol class="prose">
          {contributeSteps.map(step => (
            <li style="color:var(--text-secondary)">{step}</li>
          ))}
        </ol>
      </section>

      <div class="section-divider"></div>

      <!-- Improve existing -->
      <section class="section" id="improve">
        <div class="section-head">
          <h2 class="section-head__title">How to Improve an Existing Course</h2>
        </div>
        <ol class="prose">
          {improveSteps.map(step => (
            <li style="color:var(--text-secondary)">{step}</li>
          ))}
        </ol>
      </section>

      <div class="section-divider"></div>

      <!-- Maintainers -->
      <section class="section" id="maintainers">
        <div class="section-head">
          <h2 class="section-head__title">Maintainers</h2>
        </div>
        <div style="display:flex;flex-wrap:wrap;gap:12px">
          {maintainers.map(m => (
            <a
              href={`${base}/contributors/${m.login}`}
              class="contributor-card"
              style="text-decoration:none"
            >
              <Avatar login={m.login} size="md" />
              <div>
                <div class="contributor-card__name">{m.name}</div>
                <div class="contributor-card__role">@{m.login}</div>
              </div>
            </a>
          ))}
        </div>
      </section>

      <div class="section-divider"></div>

      <!-- Tech stack -->
      <section class="section" id="stack">
        <div class="section-head">
          <h2 class="section-head__title">Tech Stack</h2>
        </div>
        <ul class="prose" style="list-style:none;padding:0;display:flex;flex-direction:column;gap:0.75rem">
          {stack.map(item => (
            <li style="display:flex;align-items:flex-start;gap:0.75rem;font-size:0.9rem">
              <code style="font-family:var(--font-mono);color:var(--accent-blue);background:var(--bg-raised);border:1px solid var(--border-default);border-radius:4px;padding:2px 8px;white-space:nowrap;flex-shrink:0">
                {item.name}
              </code>
              <span style="color:var(--text-secondary);margin-top:2px">{item.role}</span>
            </li>
          ))}
        </ul>
      </section>

      <div class="section-divider"></div>

      <!-- License -->
      <section class="section" id="license">
        <div class="section-head">
          <h2 class="section-head__title">License</h2>
        </div>
        <div class="prose">
          <p>
            <strong>Course content</strong> —
            <a href="https://creativecommons.org/licenses/by/4.0/" target="_blank" rel="noopener">CC BY 4.0</a>.
            Use it, fork it, translate it. Credit required.
          </p>
          <p>
            <strong>Engine code</strong> —
            <a href="https://opensource.org/licenses/MIT" target="_blank" rel="noopener">MIT</a>.
            Fork it, run your own instance.
          </p>
        </div>
      </section>
    </div>
  </div>
</Base>
