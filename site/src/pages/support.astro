---
import Base from '../layouts/Base.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const fundingLinks = [
  { label: 'Ko-fi', href: '', note: 'Link coming soon' },
  { label: 'Buy Me a Coffee', href: '', note: 'Link coming soon' },
  { label: 'Gumroad', href: '', note: 'Link coming soon' },
  { label: 'GitHub Sponsors', href: '', note: 'Link coming soon' },
  { label: 'Open Collective', href: '', note: 'Link coming soon' },
  { label: 'Patreon', href: '', note: 'Link coming soon' },
];

const supportActions = [
  {
    title: 'Fund the work',
    label: 'Funding links coming soon',
    description: 'Help cover hosting, course tooling, certificates, automation, and platform maintenance.',
  },
  {
    title: 'Contribute',
    label: 'Open GitHub repo',
    href: 'https://github.com/manojpisini/opencourses',
    description: 'Improve courses, report content gaps, fix docs, or help with the platform.',
  },
  {
    title: 'Help learners',
    label: 'Open help requests',
    href: 'https://github.com/manojpisini/opencourses/issues?q=is%3Aissue+label%3Ahelp-wanted',
    description: 'Answer questions, review submissions, and keep the learning path moving.',
  },
  {
    title: 'Share OpenCourses',
    label: 'Copy and share',
    description: 'Tell learners and builders about the project while the supporter accounts are being connected.',
  },
];

const socials = [
  { label: 'GitHub', value: '@manojpisini', href: 'https://github.com/manojpisini' },
  { label: 'Website', value: 'link coming soon' },
  { label: 'Dev.to', value: 'link coming soon' },
  { label: 'Hashnode', value: 'link coming soon' },
  { label: 'Medium', value: 'link coming soon' },
  { label: 'Substack', value: 'link coming soon' },
  { label: 'X', value: 'link coming soon' },
  { label: 'Email', value: 'link coming soon' },
];
---

<Base
  title="Support OpenCourses"
  description="Donate, help, contribute, or find the main maintainer and developer social links for OpenCourses."
  currentPath="/support"
>
  <div class="container support-page">
    <div class="page-head">
      <div class="page-head__crumbs">
        <a href={`${base}/`}>~</a>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        <span>support</span>
      </div>
      <h1 class="page-head__title">Support OpenCourses</h1>
      <p class="page-head__sub">Help keep free, version-controlled developer education alive. Links can be connected here as accounts are added.</p>
    </div>

    <section class="support-hero">
      <div class="support-hero__mark" aria-hidden="true">
        <img src={`${base}/brand/Square.svg`} width="56" height="56" alt="" />
      </div>
      <div>
        <div class="support-hero__eyebrow">Open source, free forever</div>
        <h2>Donate, help, contribute, or buy me a coffee.</h2>
        <p>OpenCourses is maintained in public by Manoj Pisini. Financial links are placeholders for now; contribution and help links are active.</p>
      </div>
    </section>

    <section class="funding-buttons" aria-label="Funding links">
      {fundingLinks.map(link => (
        link.href ? (
          <a class="funding-button" href={link.href} target="_blank" rel="noopener">
            <span>{link.label}</span>
            <strong>Open</strong>
          </a>
        ) : (
          <span class="funding-button funding-button--disabled">
            <span>{link.label}</span>
            <strong>{link.note}</strong>
          </span>
        )
      ))}
    </section>

    <section class="support-grid" aria-label="Support options">
      {supportActions.map(action => (
        action.href ? (
          <a class="support-card" href={action.href} target="_blank" rel="noopener">
            <span class="support-card__title">{action.title}</span>
            <span class="support-card__desc">{action.description}</span>
            <span class="support-card__action">{action.label}</span>
          </a>
        ) : (
          <div class="support-card support-card--disabled">
            <span class="support-card__title">{action.title}</span>
            <span class="support-card__desc">{action.description}</span>
            <span class="support-card__action">{action.label}</span>
          </div>
        )
      ))}
    </section>

    <section class="maintainer-socials" aria-labelledby="maintainer-social-title">
      <div>
        <div class="support-hero__eyebrow">Main maintainer / developer</div>
        <h2 id="maintainer-social-title">Manoj Pisini</h2>
        <p>Lead Maintainer and Lead Developer of OpenCourses. Social links are kept as placeholders until the final accounts are connected.</p>
      </div>
      <div class="social-list">
        {socials.map(social => (
          social.href ? (
            <a class="social-chip" href={social.href} target="_blank" rel="noopener">
              <span>{social.label}</span>
              <strong>{social.value}</strong>
            </a>
          ) : (
            <span class="social-chip social-chip--disabled">
              <span>{social.label}</span>
              <strong>{social.value}</strong>
            </span>
          )
        ))}
      </div>
    </section>
  </div>
</Base>

<style>
  .support-page {
    padding-bottom: 4rem;
  }
  .support-page .page-head {
    margin-bottom: 2rem;
  }
  .support-hero,
  .maintainer-socials {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.25rem;
    align-items: center;
    padding: 1.5rem;
    background: var(--bg-surface);
    border: 1px solid color-mix(in srgb, #4C1BC9 24%, var(--border-default));
    border-radius: 10px;
  }
  .support-hero__mark {
    width: 64px;
    height: 64px;
    display: grid;
    place-items: center;
    border-radius: 8px;
    background: color-mix(in srgb, #4C1BC9 10%, var(--bg-base));
    border: 1px solid color-mix(in srgb, #4C1BC9 26%, transparent);
  }
  .support-hero__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: #7C3AED;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.35rem;
  }
  .support-hero h2,
  .maintainer-socials h2 {
    margin: 0;
    font-size: clamp(1.35rem, 2vw, 2rem);
    letter-spacing: 0;
  }
  .support-hero p,
  .maintainer-socials p {
    max-width: 760px;
    margin: 0.65rem 0 0;
    color: var(--text-secondary);
    line-height: 1.6;
  }
  .funding-buttons {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 0.75rem;
    margin: 1.5rem 0 1.75rem;
  }
  .funding-button {
    display: flex;
    min-height: 58px;
    flex-direction: column;
    justify-content: center;
    gap: 3px;
    padding: 0.8rem 0.95rem;
    border: 1px solid color-mix(in srgb, #7C3AED 30%, var(--border-default));
    border-radius: 8px;
    background:
      linear-gradient(135deg, color-mix(in srgb, #7C3AED 8%, transparent), transparent 46%),
      var(--bg-surface);
    color: inherit;
    text-decoration: none;
  }
  .funding-button span {
    font-weight: 800;
    color: var(--text-primary);
  }
  .funding-button strong {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .funding-button--disabled {
    opacity: 0.88;
  }
  .support-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
    margin: 1.75rem 0;
  }
  .support-card {
    display: flex;
    min-height: 160px;
    flex-direction: column;
    gap: 0.8rem;
    padding: 1rem;
    background: var(--bg-surface);
    border: 1px solid var(--border-default);
    border-left: 3px solid #7C3AED;
    border-radius: 8px;
    color: inherit;
    text-decoration: none;
    transition: border-color 150ms, background 150ms, transform 150ms;
  }
  .support-card:hover {
    border-color: color-mix(in srgb, #7C3AED 48%, var(--border-default));
    background: var(--bg-raised);
    transform: translateY(-2px);
  }
  .support-card--disabled {
    border-left-color: #4C1BC9;
  }
  .support-card__title {
    font-size: 1rem;
    font-weight: 800;
    color: var(--text-primary);
  }
  .support-card__desc {
    flex: 1;
    color: var(--text-secondary);
    line-height: 1.55;
    font-size: 0.9rem;
  }
  .support-card__action {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: #7C3AED;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .maintainer-socials {
    grid-template-columns: minmax(240px, 0.9fr) 1.1fr;
  }
  .social-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }
  .social-chip {
    display: inline-flex;
    flex-direction: column;
    gap: 2px;
    min-width: 128px;
    padding: 0.75rem 0.9rem;
    border: 1px solid var(--border-default);
    border-radius: 8px;
    background: var(--bg-base);
    color: inherit;
    text-decoration: none;
  }
  .social-chip span {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .social-chip strong {
    font-size: 0.85rem;
    color: var(--text-primary);
  }
  .social-chip--disabled strong {
    color: var(--text-muted);
  }
  @media (max-width: 720px) {
    .support-hero,
    .maintainer-socials {
      grid-template-columns: 1fr;
    }
  }
</style>
