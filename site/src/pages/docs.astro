            <div class="docs-table-wrap">
              <table class="docs-table">
                <thead><tr><th>Secret</th><th>Used By</th><th>Description</th></tr></thead>
                <tbody>
                  <tr><td><code>GITHUB_TOKEN</code></td><td>All workflows</td><td>Auto-provided by GitHub Actions. Read/write access to the repo.</td></tr>
                  <tr><td><code>COURSE_BOT_TOKEN</code></td><td><code>issue-cert.yml</code></td><td>Personal access token for the bot account. Needed to push release assets.</td></tr>
                  <tr><td><code>GPG_SIGNING_KEY</code></td><td><code>issue-cert.yml</code></td><td>Base64-encoded GPG private key for signing certificates.</td></tr>
                  <tr><td><code>GPG_KEY_ID</code></td><td><code>issue-cert.yml</code></td><td>ID of the GPG key (used with <code>--local-user</code>).</td></tr>
                </tbody>
              </table>
            </div>
          </section>

