---
import Base from '../layouts/Base.astro';
import OC from '../data/oc';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const tracks = OC.TRACKS;
---

<Base title="Changelog" description="Complete history of curriculum updates across all OpenCourses.">
  <div class="container">
    <div class="page-head">
      <div class="page-head__crumbs">
        <a href={`${base}/`}>~</a>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        <span>changelog</span>
      </div>
      <h1 class="page-head__title">Changelog</h1>
      <p class="page-head__sub">Every curriculum update, version-controlled and transparent.</p>
    </div>

    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:2rem">
      <span style="font-family:var(--font-mono);font-size:0.8rem;color:var(--text-muted)">
        {OC.CHANGELOG.reduce((n, m) => n + m.entries.length, 0)} entries across {OC.CHANGELOG.length} months
      </span>
      <select id="track-filter" class="sort-dropdown">
        <option value="all">All tracks</option>
        {tracks.map(t => <option value={t.slug}>{t.name}</option>)}
      </select>
    </div>

    <div class="changelog-list" id="changelog-list">
      {OC.CHANGELOG.map(monthGroup => (
        <div class="changelog-month">
          <div class="changelog-month__label">{monthGroup.month}</div>
          <div class="changelog-entries">
            {monthGroup.entries.map(entry => {
              // Derive track from slug by matching against courses
              const course = OC.COURSES.find(c => c.slug === entry.slug);
              const trackSlug = course?.track ?? 'unknown';
              return (
                <div class="changelog-entry" data-track={trackSlug}>
                  <div class="changelog-entry__head">
                    <a href={`${base}/courses/${entry.slug}`} class="changelog-entry__title">
                      {entry.course}
                    </a>
                    <span class="version-tag">{entry.version}</span>
                    <span class="changelog-entry__date">{entry.date}</span>
                  </div>
                  <div>
                    {entry.changes.map(change => (
                      <div class={`change-line change-line--${change.type}`}>
                        <span class="change-line__marker">
                          {change.type === 'added' ? '+' : change.type === 'removed' ? '-' : '~'}
                        </span>
                        <span>{change.text}</span>
                      </div>
                    ))}
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </div>
  </div>
</Base>

<script is:inline>
  (function () {
    const filter = document.getElementById('track-filter');
    filter?.addEventListener('change', function () {
      const val = this.value;
      document.querySelectorAll('#changelog-list [data-track]').forEach(function (el) {
        el.style.display = (val === 'all' || el.dataset.track === val) ? '' : 'none';
      });
      // Hide/show month headers if all entries inside are hidden
      document.querySelectorAll('.changelog-month').forEach(function (month) {
        const entries = month.querySelectorAll('.changelog-entry');
        const anyVisible = [...entries].some(e => e.style.display !== 'none');
        month.style.display = anyVisible ? '' : 'none';
      });
    });
  })();
</script>
