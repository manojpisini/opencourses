---
import Base from '../../layouts/Base.astro';
import OC from '../../data/oc';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const sorted = OC.TRACKS;
---

<Base title="Curriculum Tracks" description="Navigate OpenCourses curriculum by learning track.">
  <div class="container">
    <div class="page-head">
      <div class="page-head__crumbs">
        <a href={`${base}/`}>~</a>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        <span>tracks</span>
      </div>
      <h1 class="page-head__title">Curriculum Map</h1>
      <p class="page-head__sub">Explore the knowledge graph — courses organized by prerequisite dependencies and learning tracks.</p>
    </div>

    <!-- Knowledge Graph -->
    <div class="section">
      <div class="section-head">
        <h2 class="section-head__title">Knowledge Graph</h2>
      </div>

      <div class="graph-wrap">
        <svg id="graph-svg" class="graph-svg"></svg>

        <!-- Toolbar: filter + reset — absolute inside wrap -->
        <div class="graph-toolbar">
          <select id="graph-track-filter">
            <option value="all">All tracks</option>
            {sorted.map(t => <option value={t.slug}>{t.name}</option>)}
          </select>
          <button id="graph-reset" class="btn btn-ghost btn-sm">Reset</button>
        </div>

        <!-- Detail card — slides in top-right on node click -->
        <div id="graph-detail" class="graph-detail" hidden>
          <button id="graph-detail-close" class="graph-detail__close">✕</button>
          <h3 id="graph-detail-title" class="graph-detail__title"></h3>
          <p id="graph-detail-meta" class="graph-detail__meta"></p>
          <p id="graph-detail-desc" class="graph-detail__desc"></p>
          <a id="graph-detail-link" class="btn btn-primary btn-sm" style="margin-top:0.25rem" href="#">View course →</a>
        </div>
      </div>
    </div>

    <div class="section-divider"></div>

    <!-- Track cards -->
    <div class="section">
      <div class="section-head">
        <h2 class="section-head__title">All Tracks</h2>
        <p class="section-head__sub">{OC.TRACKS.length} tracks, {OC.COURSES.length} courses total.</p>
      </div>

      <div class="tracks-page">
        {sorted.map(track => {
          const trackCourses = OC.COURSES.filter(c => c.track === track.slug);
          const color = OC.TRACK_COLORS[track.slug] ?? '#4f9eff';
          return (
            <a
              href={`${base}/courses?track=${track.slug}`}
              class="track-card"
              style={`--track-color:${color}`}
            >
              <div class="track-card__stripe"></div>
              <div class="track-card__body">
                <div class="track-card__head">
                  <h3 class="track-card__name">{track.name}</h3>
                  <span class="track-card__count">{trackCourses.length} courses</span>
                </div>
                <p class="track-card__desc">{track.description}</p>
                <div class="track-card__samples">
                  {trackCourses.slice(0, 3).map(c => (
                    <span class="track-card__sample">{c.title}</span>
                  ))}
                  {trackCourses.length > 3 && (
                    <span class="track-card__sample track-card__sample--more">+{trackCourses.length - 3} more</span>
                  )}
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </div>
</Base>

<script is:inline define:vars={{ graphData: { nodes: OC.GRAPH.nodes, links: OC.GRAPH.links }, trackColors: OC.TRACK_COLORS, ocCourses: OC.COURSES }}>
  window.OC_GRAPH = graphData;
  window.OC_TRACK_COLORS = trackColors;
  window.OC_COURSES = ocCourses;
</script>
<script is:inline src={`${base}/js/graph.js`}></script>
