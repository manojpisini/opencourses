---
/**
 * [slug].astro — Udemy/Coursera-style course player.
 *
 * For courses with a course-detail.json (published via parse-course), renders
 * the full interactive player: embedded videos, code blocks, reading links,
 * exercise instructions, etc.
 *
 * For courses that only have a summary entry in OC.COURSES (no detail file),
 * falls back to a minimal info page.
 */
import Base from '../../layouts/Base.astro';
import TrackBadge from '../../components/TrackBadge.astro';
import DifficultyBadge from '../../components/DifficultyBadge.astro';
import Avatar from '../../components/Avatar.astro';
import OC from '../../data/oc';
import type { CourseDetailJson } from '../../types/course';

// ── Load all course-detail JSON files at build time ───────────────────────────
const detailModules = import.meta.glob<{ default: CourseDetailJson }>(
  '../../data/course-details/*.json',
  { eager: true },
);

const detailMap = new Map<string, CourseDetailJson>();
for (const [, mod] of Object.entries(detailModules)) {
  const d = mod.default ?? (mod as unknown as CourseDetailJson);
  if (d?.id) detailMap.set(d.id, d);
}

// ── Static paths ──────────────────────────────────────────────────────────────
export function getStaticPaths() {
  const detailMods = import.meta.glob<{ default: CourseDetailJson }>(
    '../../data/course-details/*.json',
    { eager: true },
  );

  const paths: Array<{ params: { slug: string }; props: { detail: CourseDetailJson | null; slugFallback: string } }> = [];
  const seen = new Set<string>();

  for (const [, mod] of Object.entries(detailMods)) {
    const d = mod.default ?? (mod as unknown as CourseDetailJson);
    if (!d?.id) continue;
    paths.push({ params: { slug: d.id }, props: { detail: d, slugFallback: d.id } });
    seen.add(d.id);
  }

  // Add any OC.COURSES that don't have a detail file yet
  for (const c of OC.COURSES) {
    if (!seen.has(c.slug)) {
      paths.push({ params: { slug: c.slug }, props: { detail: null, slugFallback: c.slug } });
    }
  }

  return paths;
}

interface Props {
  detail: CourseDetailJson | null;
  slugFallback: string;
}

const { detail, slugFallback } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Fallback summary from OC.COURSES
const summaryFallback = OC.COURSES.find(c => c.slug === slugFallback);

// Helpers
function fmtDuration(mins: number): string {
  if (!mins) return '—';
  if (mins < 60) return `${mins}m`;
  const h = Math.floor(mins / 60);
  const m = mins % 60;
  return m ? `${h}h ${m}m` : `${h}h`;
}

function lessonIcon(type: string): string {
  const icons: Record<string, string> = {
    video: '▶',
    reading: '📖',
    code: '💻',
    exercise: '🛠',
    reference: '📋',
    quiz: '📝',
    discussion: '💬',
    project: '🚀',
    live: '🔴',
  };
  return icons[type] ?? '•';
}

// Build flat lesson list with chapter info for navigation
const flatLessons: Array<{ chIdx: number; lIdx: number; lesson: CourseDetailJson['chapters'][number]['lessons'][number]; chapterId: string }> = [];
if (detail) {
  for (let ci = 0; ci < detail.chapters.length; ci++) {
    const ch = detail.chapters[ci]!;
    for (let li = 0; li < ch.lessons.length; li++) {
      flatLessons.push({ chIdx: ci, lIdx: li, lesson: ch.lessons[li]!, chapterId: ch.id });
    }
  }
}

const title  = detail?.title  ?? summaryFallback?.title  ?? slugFallback;
const tagline = detail?.tagline ?? summaryFallback?.description ?? '';
const color  = detail?.cover.color_primary ?? summaryFallback?.tags?.[0] ? '#4f9eff' : '#4f9eff';
const totalH = detail ? `${detail.effort.total_hours}h` : (summaryFallback?.duration ?? '—');
---

<Base
  title={title}
  description={tagline}
  currentPath={`/courses/${slugFallback}`}
>
  {detail ? (
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- FULL COURSE PLAYER                                                      -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <div class="cp-root">

      <!-- ── Top bar ──────────────────────────────────────────────────────── -->
      <header class="cp-topbar">
        <a href={`${base}/courses`} class="cp-topbar__back">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          Courses
        </a>
        <div class="cp-topbar__title">{detail.title}</div>
        <div class="cp-topbar__meta">
          <TrackBadge track={detail.track} />
          <DifficultyBadge level={detail.level} />
          <span class="cp-topbar__duration">{totalH}</span>
        </div>
        <!-- Progress bar (driven by JS) -->
        <div class="cp-topbar__progress" id="cp-progress-wrap">
          <div class="cp-topbar__progress-bar" id="cp-progress-bar" style="width:0%"></div>
        </div>
        <span class="cp-topbar__progress-label" id="cp-progress-label">0 / {flatLessons.length}</span>
      </header>

      <!-- ── Player body: sidebar + content ───────────────────────────────── -->
      <div class="cp-body">

        <!-- Sidebar: chapter / lesson tree -->
        <nav class="cp-sidebar" id="cp-sidebar">
          <div class="cp-sidebar__inner">
            <!-- Course info mini card -->
            <div class="cp-sidebar__course-info">
              {detail.cover.thumbnail && (
                <img src={detail.cover.thumbnail} alt={detail.title} class="cp-sidebar__thumb" loading="lazy" />
              )}
              <div class="cp-sidebar__course-meta">
                <div class="cp-sidebar__course-title">{detail.title}</div>
                <div class="cp-sidebar__course-sub">
                  {detail.totalChapters} chapters · {detail.totalLessons} lessons
                </div>
              </div>
            </div>

            <!-- Chapter list -->
            {detail.chapters.map((ch, ci) => (
              <div class="cp-chapter" id={`cp-ch-${ch.id}`}>
                <button class="cp-chapter__head" data-ch-toggle={ci}>
                  <svg class="cp-chapter__chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                  <span class="cp-chapter__num">{String(ci + 1).padStart(2, '0')}</span>
                  <span class="cp-chapter__title">{ch.title}</span>
                  <span class="cp-chapter__count">{ch.lessonCount}</span>
                </button>
                <div class="cp-chapter__lessons" data-ch-lessons={ci}>
                  {ch.lessons.map((lesson, li) => {
                    const globalIdx = flatLessons.findIndex(fl => fl.chapterId === ch.id && fl.lIdx === li);
                    return (
                      <button
                        class="cp-lesson-btn"
                        data-lesson={globalIdx}
                        data-lesson-id={lesson.id}
                        id={`cp-lessonbtn-${globalIdx}`}
                      >
                        <span class="cp-lesson-btn__icon">{lessonIcon(lesson.type)}</span>
                        <span class="cp-lesson-btn__title">{lesson.title}</span>
                        {lesson.duration_minutes > 0 && (
                          <span class="cp-lesson-btn__dur">{fmtDuration(lesson.duration_minutes)}</span>
                        )}
                        <span class="cp-lesson-btn__check" id={`cp-check-${globalIdx}`}></span>
                      </button>
                    );
                  })}
                  <!-- Chapter test pill -->
                  <div class="cp-chapter-test-pill">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                    Chapter Test · {ch.test_summary.question_count}q · {ch.test_summary.passing_score}% pass
                  </div>
                </div>
              </div>
            ))}

            <!-- Final Test / Assignment pills -->
            {detail.final_test && (
              <div class="cp-final-pill cp-final-pill--test">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                Final Test · {detail.final_test.question_count}q
              </div>
            )}
            {detail.final_assignment && (
              <div class="cp-final-pill cp-final-pill--assign">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                Final Assignment
              </div>
            )}

            <!-- Enroll CTA -->
            <a
              href={`https://github.com/manojpisini/opencourses/issues/new?template=enroll.yml&title=[Enrolled]+@YOUR_USERNAME+—+${detail.id}&labels=enrollment-request`}
              class="cp-enroll-btn"
              target="_blank"
              rel="noopener"
            >
              Enroll via GitHub Issues
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </a>
          </div>
        </nav>

        <!-- Sidebar toggle (mobile) -->
        <button class="cp-sidebar-toggle" id="cp-sidebar-toggle" aria-label="Toggle course outline">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>

        <!-- ── Main content area ─────────────────────────────────────────── -->
        <main class="cp-content" id="cp-content">

          <!-- All lesson panes (show one at a time via JS) -->
          {flatLessons.map(({ lesson, chIdx, lIdx }, globalIdx) => {
            const ch = detail.chapters[chIdx]!;
            const isFirst = globalIdx === 0;
            return (
              <article
                class="cp-pane"
                id={`cp-pane-${globalIdx}`}
                data-lesson-id={lesson.id}
                hidden={!isFirst}
              >
                <!-- Pane header -->
                <div class="cp-pane__header">
                  <div class="cp-pane__breadcrumb">
                    <span class="cp-pane__ch-name">{ch.title}</span>
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                    <span class="cp-pane__lesson-type">{lesson.type}</span>
                  </div>
                  <h1 class="cp-pane__title">{lesson.title}</h1>
                  {lesson.description && (
                    <p class="cp-pane__desc">{lesson.description}</p>
                  )}
                  {lesson.duration_minutes > 0 && (
                    <div class="cp-pane__dur">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                      {fmtDuration(lesson.duration_minutes)}
                    </div>
                  )}
                </div>

                <!-- ── VIDEO ─────────────────────────────────────────────── -->
                {lesson.video && (
                  <div class="cp-video-wrap">
                    <iframe
                      class="cp-video"
                      data-src={lesson.video.embed_url}
                      src={isFirst ? lesson.video.embed_url : undefined}
                      title={lesson.title}
                      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                      allowfullscreen
                      loading="lazy"
                    ></iframe>
                  </div>
                )}
                {lesson.video && (
                  <div class="cp-video-meta">
                    <a href={lesson.video.url} target="_blank" rel="noopener" class="cp-video-meta__link">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                      Open on {lesson.video.source}
                    </a>
                    {lesson.video.channel && (
                      <span class="cp-video-meta__channel">by {lesson.video.channel}</span>
                    )}
                    {lesson.video.subtitles_available && (
                      <span class="cp-video-meta__subs">CC available</span>
                    )}
                  </div>
                )}

                <!-- Video timestamps -->
                {lesson.video?.timestamps && lesson.video.timestamps.length > 0 && (
                  <div class="cp-timestamps">
                    <div class="cp-timestamps__title">Chapters</div>
                    <div class="cp-timestamps__list">
                      {lesson.video.timestamps.map(ts => (
                        <div class="cp-timestamp">
                          <code class="cp-timestamp__time">{ts.time}</code>
                          <span class="cp-timestamp__label">{ts.label}</span>
                        </div>
                      ))}
                    </div>
                  </div>
                )}

                <!-- ── READING ────────────────────────────────────────────── -->
                {lesson.reading && (
                  <div class="cp-reading">
                    <div class="cp-reading__source">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                      <a href={lesson.reading.url} target="_blank" rel="noopener" class="cp-reading__link">
                        Read on {lesson.reading.source}
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                      </a>
                      {lesson.reading.estimated_minutes && (
                        <span class="cp-reading__est">~{lesson.reading.estimated_minutes} min read</span>
                      )}
                    </div>
                    {lesson.reading.sections_to_read && lesson.reading.sections_to_read.length > 0 && (
                      <div class="cp-reading__sections">
                        <strong>Read these sections:</strong>
                        <ul>
                          {lesson.reading.sections_to_read.map(s => <li>{s}</li>)}
                        </ul>
                      </div>
                    )}
                  </div>
                )}

                <!-- ── TEXT / CURATOR NOTES ───────────────────────────────── -->
                {lesson.text_md && (
                  <div class="cp-notes">
                    <div class="cp-notes__label">
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                      Curator Notes
                    </div>
                    <div class="cp-notes__body prose">{lesson.text_md}</div>
                  </div>
                )}

                <!-- ── CODE BLOCKS ────────────────────────────────────────── -->
                {lesson.code_blocks && lesson.code_blocks.length > 0 && (
                  <div class="cp-code-section">
                    {lesson.code_blocks.map(cb => (
                      <div class="cp-code-block">
                        <div class="cp-code-block__bar">
                          <div class="cp-code-block__dots">
                            <span></span><span></span><span></span>
                          </div>
                          <span class="cp-code-block__title">{cb.title}</span>
                          <span class="cp-code-block__lang">{cb.language}</span>
                          <button class="cp-code-block__copy" data-copy-src={cb.snippet}>Copy</button>
                        </div>
                        <pre class="cp-code-block__pre"><code class={`language-${cb.language}`}>{cb.snippet}</code></pre>
                        {cb.explanation && (
                          <div class="cp-code-block__explain">{cb.explanation}</div>
                        )}
                        {cb.expected_output && (
                          <div class="cp-code-block__output">
                            <span class="cp-code-block__output-label">Expected output</span>
                            <pre><code>{cb.expected_output}</code></pre>
                          </div>
                        )}
                      </div>
                    ))}
                  </div>
                )}

                <!-- ── EXERCISE ───────────────────────────────────────────── -->
                {lesson.exercise && (
                  <div class="cp-exercise">
                    <div class="cp-exercise__header">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                      Hands-on Exercise
                    </div>
                    <div class="cp-exercise__body">
                      <a href={lesson.exercise.starter_repo} class="cp-exercise__repo" target="_blank" rel="noopener">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2c-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.27-1.68-1.27-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.69 1.25 3.34.96.1-.74.4-1.25.72-1.54-2.55-.29-5.23-1.28-5.23-5.69 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.17 1.18a11 11 0 0 1 5.78 0c2.2-1.49 3.17-1.18 3.17-1.18.62 1.58.23 2.75.11 3.04.74.81 1.18 1.84 1.18 3.1 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.06.78 2.14v3.17c0 .31.21.67.8.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5Z"/></svg>
                        Open Starter Repo
                      </a>
                      {lesson.exercise.test_command && (
                        <div class="cp-exercise__cmd">
                          <span class="cp-exercise__cmd-label">Run tests:</span>
                          <code>{lesson.exercise.test_command}</code>
                        </div>
                      )}
                      {lesson.exercise.submission_type && (
                        <div class="cp-exercise__submit">
                          Submit via: <strong>{lesson.exercise.submission_type}</strong>
                        </div>
                      )}
                    </div>
                    {lesson.hints && lesson.hints.length > 0 && (
                      <details class="cp-hints">
                        <summary class="cp-hints__toggle">Hints ({lesson.hints.length})</summary>
                        <div class="cp-hints__list">
                          {lesson.hints.map((h, hi) => (
                            <div class="cp-hint">
                              <span class="cp-hint__level">Hint {hi + 1}</span>
                              <p>{h.text}</p>
                            </div>
                          ))}
                        </div>
                      </details>
                    )}
                  </div>
                )}

                <!-- ── LINKS ──────────────────────────────────────────────── -->
                {lesson.links && lesson.links.length > 0 && (
                  <div class="cp-links">
                    <div class="cp-links__title">Resources</div>
                    <ul class="cp-links__list">
                      {lesson.links.map(link => (
                        <li class="cp-link-item">
                          <a href={link.url} target="_blank" rel="noopener" class="cp-link-item__a">
                            <span class="cp-link-item__label">{link.label}</span>
                            <span class="cp-link-item__type">{link.type}</span>
                            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                          </a>
                          {link.required && <span class="cp-link-item__req">Required</span>}
                          {link.note && <span class="cp-link-item__note">{link.note}</span>}
                        </li>
                      ))}
                    </ul>
                  </div>
                )}

                <!-- ── SUPPLEMENTAL ───────────────────────────────────────── -->
                {lesson.supplemental && lesson.supplemental.length > 0 && (
                  <div class="cp-links">
                    <div class="cp-links__title">Supplemental Reading</div>
                    <ul class="cp-links__list">
                      {lesson.supplemental.map(link => (
                        <li class="cp-link-item">
                          <a href={link.url} target="_blank" rel="noopener" class="cp-link-item__a">
                            <span class="cp-link-item__label">{link.label}</span>
                            <span class="cp-link-item__type">{link.type}</span>
                            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}

                <!-- Prev / Next navigation -->
                <div class="cp-pane__nav">
                  {globalIdx > 0 && (
                    <button class="cp-pane__nav-btn cp-pane__nav-btn--prev" data-go-lesson={globalIdx - 1}>
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
                      {flatLessons[globalIdx - 1]?.lesson.title ?? 'Previous'}
                    </button>
                  )}
                  {globalIdx < flatLessons.length - 1 && (
                    <button class="cp-pane__nav-btn cp-pane__nav-btn--next" data-go-lesson={globalIdx + 1}>
                      {flatLessons[globalIdx + 1]?.lesson.title ?? 'Next'}
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                    </button>
                  )}
                </div>
              </article>
            );
          })}

          <!-- Overview pane (course intro — shown before any lesson is selected on fresh load) -->
          {flatLessons.length === 0 && (
            <div class="cp-pane" style="padding:3rem 2rem">
              <h1 style="margin:0 0 1rem">{detail.title}</h1>
              <p style="color:var(--text-secondary)">{detail.description_short}</p>
              <p style="color:var(--text-muted);font-size:0.85rem">This course has no lessons yet — check back after publish.</p>
            </div>
          )}
        </main>

        <!-- ── Right info panel ──────────────────────────────────────────── -->
        <aside class="cp-infopanel">

          <!-- About this course -->
          <div class="cp-card">
            <div class="cp-card__title">About this course</div>
