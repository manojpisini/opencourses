              )}
              {detail.prerequisites.courses.length > 0 && (
                <div>
                  {detail.prerequisites.courses.map(cid => {
                    const c = OC.COURSES.find(x => x.slug === cid);
                    return (
                      <a href={`${base}/courses/${cid}`} class="cp-prereq-course">
                        📚 {c?.title ?? cid}
