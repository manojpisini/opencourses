        <a href={`${base}/courses`} style="color:var(--text-muted)">courses</a>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        <span>{slugFallback}</span>
      </div>

      <h1 style="font-size:2rem;font-weight:800;margin:0 0 0.5rem;letter-spacing:-0.02em">{title}</h1>
      <p style="font-size:1rem;color:var(--text-secondary);margin:0 0 2rem;max-width:640px">{tagline}</p>

      {summaryFallback && (
        <div style="display:flex;flex-wrap:wrap;gap:0.75rem;align-items:center;margin-bottom:2rem">
          <TrackBadge track={summaryFallback.track} />
          <DifficultyBadge level={summaryFallback.difficulty} />
          <span style="font-family:var(--font-mono);font-size:0.78rem;color:var(--text-muted)">{summaryFallback.duration}</span>
          <span style="font-family:var(--font-mono);font-size:0.78rem;color:var(--text-muted)">{summaryFallback.modules} chapters</span>
        </div>
      )}

      <div style="background:var(--bg-surface);border:1px solid var(--border-default);border-radius:10px;padding:1.5rem;max-width:480px">
        <div style="font-size:0.85rem;color:var(--text-muted);margin-bottom:1rem">Course content is being published. Full player coming soon.</div>
        <a
          href={`https://github.com/manojpisini/opencourses/issues/new?template=enroll.yml&title=[Enrolled]+@YOUR_USERNAME+—+${slugFallback}&labels=enrollment-request`}
          style="display:inline-flex;align-items:center;gap:8px;padding:10px 18px;background:var(--accent-blue,#4f9eff);color:#fff;border-radius:8px;text-decoration:none;font-weight:600;font-size:0.875rem"
          target="_blank" rel="noopener"
        >
          Enroll via GitHub Issues
        </a>
      </div>
    </div>
