  <!-- Highlight.js for syntax highlighting -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js" is:inline></script>

  <script is:inline>
  (function () {
    'use strict';

    // ── Highlight.js init ──────────────────────────────────────────────────
    if (typeof hljs !== 'undefined') {
      document.querySelectorAll('pre code[class^="language-"]').forEach(function (el) {
        hljs.highlightElement(el);
      });
    }

    // ── State ──────────────────────────────────────────────────────────────
    var STORAGE_KEY_LESSON   = 'oc-player-lesson-' + (window.location.pathname);
    var STORAGE_KEY_PROGRESS = 'oc-player-done-'   + (window.location.pathname);

    var totalLessons = document.querySelectorAll('[data-lesson]').length;
    if (!totalLessons) return; // fallback page, nothing to do

    function getDone() {
      try { return JSON.parse(localStorage.getItem(STORAGE_KEY_PROGRESS) || '[]'); }
      catch { return []; }
    }
    function saveDone(arr) {
      try { localStorage.setItem(STORAGE_KEY_PROGRESS, JSON.stringify(arr)); }
      catch {}
    }
    function getSavedLesson() {
      try { return parseInt(localStorage.getItem(STORAGE_KEY_LESSON) || '0', 10) || 0; }
      catch { return 0; }
    }
    function saveCurrentLesson(idx) {
      try { localStorage.setItem(STORAGE_KEY_LESSON, String(idx)); }
      catch {}
    }

    var done = getDone();
    var currentLesson = 0;

    // ── Update progress bar ────────────────────────────────────────────────
    function updateProgress() {
      var bar   = document.getElementById('cp-progress-bar');
      var label = document.getElementById('cp-progress-label');
      if (bar)   bar.style.width = (done.length / totalLessons * 100) + '%';
      if (label) label.textContent = done.length + ' / ' + totalLessons;
    }

    // ── Show a lesson pane ─────────────────────────────────────────────────
    function showLesson(idx) {
      // Hide all panes
      document.querySelectorAll('.cp-pane').forEach(function (pane) {
        pane.hidden = true;
      });
      // Show target pane
      var pane = document.getElementById('cp-pane-' + idx);
      if (!pane) return;
      pane.hidden = false;

      // Activate sidebar button
      document.querySelectorAll('[data-lesson]').forEach(function (btn) {
        btn.classList.toggle('active', parseInt(btn.dataset.lesson, 10) === idx);
      });

      // Lazy-load iframe: set src from data-src
      var iframe = pane.querySelector('iframe.cp-video');
      if (iframe && iframe.dataset.src && !iframe.src) {
        iframe.src = iframe.dataset.src;
      }

      // Mark done when navigating away (previous lesson is done)
      if (currentLesson !== idx && done.indexOf(currentLesson) === -1) {
        done.push(currentLesson);
        saveDone(done);
        updateProgress();
      }

      currentLesson = idx;
      saveCurrentLesson(idx);

      // Update check marks
      done.forEach(function (doneIdx) {
        var chk = document.getElementById('cp-check-' + doneIdx);
        if (chk) chk.textContent = '✓';
      });

      // Scroll to top of content
      var content = document.getElementById('cp-content');
      if (content) content.scrollTop = 0;

      // Update URL hash without scrolling
      history.replaceState(null, '', '#lesson-' + idx);
    }

    // ── Restore lesson from URL hash or localStorage ───────────────────────
    var hashMatch = window.location.hash.match(/^#lesson-(\d+)$/);
    var initLesson = hashMatch ? parseInt(hashMatch[1], 10) : getSavedLesson();
    initLesson = Math.max(0, Math.min(initLesson, totalLessons - 1));

    // Render done checkmarks
    updateProgress();
    done.forEach(function (doneIdx) {
      var chk = document.getElementById('cp-check-' + doneIdx);
      if (chk) chk.textContent = '✓';
    });

    // Show initial lesson (first pane is rendered visible from SSR)
    if (initLesson > 0) {
      showLesson(initLesson);
    } else {
      // Activate first sidebar button
      var firstBtn = document.querySelector('[data-lesson="0"]');
      if (firstBtn) firstBtn.classList.add('active');
    }

    // ── Sidebar lesson click ───────────────────────────────────────────────
    document.addEventListener('click', function (e) {
      var btn = e.target.closest('[data-lesson]');
      if (btn) {
        var idx = parseInt(btn.dataset.lesson, 10);
        showLesson(idx);
        return;
      }

      // Prev / Next navigation buttons inside pane
      var navBtn = e.target.closest('[data-go-lesson]');
      if (navBtn) {
        var toIdx = parseInt(navBtn.dataset.goLesson, 10);
        showLesson(toIdx);
        return;
      }

      // Copy button on code blocks
      var copyBtn = e.target.closest('[data-copy-src]');
      if (copyBtn) {
        var text = copyBtn.dataset.copySrc;
        navigator.clipboard.writeText(text).then(function () {
          var orig = copyBtn.textContent;
          copyBtn.textContent = 'Copied!';
          setTimeout(function () { copyBtn.textContent = orig; }, 1500);
        }).catch(function () {});
        return;
      }
    });

    // ── Chapter accordion toggle ──────────────────────────────────────────
    document.querySelectorAll('[data-ch-toggle]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var ci = btn.dataset.chToggle;
        var lessons = document.querySelector('[data-ch-lessons="' + ci + '"]');
        var chevron = btn.querySelector('.cp-chapter__chevron');
        if (!lessons) return;
        var open = !lessons.hidden;
        lessons.hidden = open;
        if (chevron) chevron.style.transform = open ? 'rotate(0deg)' : 'rotate(90deg)';
      });
    });

    // Open chapter that contains current lesson
    (function () {
      var activeBtn = document.getElementById('cp-lessonbtn-' + initLesson);
      if (!activeBtn) return;
      // Find parent [data-ch-lessons]
      var parent = activeBtn.closest('[data-ch-lessons]');
      if (!parent) return;
      parent.hidden = false;
      var ci = parent.dataset.chLessons;
      var head = document.querySelector('[data-ch-toggle="' + ci + '"]');
      if (head) {
        var chevron = head.querySelector('.cp-chapter__chevron');
        if (chevron) chevron.style.transform = 'rotate(90deg)';
      }
    })();

    // ── Mobile sidebar toggle ─────────────────────────────────────────────
    var sidebarToggle = document.getElementById('cp-sidebar-toggle');
    var sidebar = document.getElementById('cp-sidebar');
    if (sidebarToggle && sidebar) {
      sidebarToggle.addEventListener('click', function () {
        sidebar.classList.toggle('cp-sidebar--open');
      });
    }

  })();
  </script>
</Base>

<style>
/* ═══════════════════════════════════════════════════════════════════════════ */
/* COURSE PLAYER LAYOUT                                                        */
/* ═══════════════════════════════════════════════════════════════════════════ */

.cp-root {
  display: flex;
  flex-direction: column;
  height: calc(100vh - 56px);
  overflow: hidden;
}

/* ── Top bar ─────────────────────────────────────────────────────────────── */
.cp-topbar {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 0 1rem;
  height: 48px;
  background: var(--bg-surface);
  border-bottom: 1px solid var(--border-default);
  flex-shrink: 0;
  overflow: hidden;
  position: relative;
}
.cp-topbar__back {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--text-muted);
  text-decoration: none;
  white-space: nowrap;
  flex-shrink: 0;
  transition: color 0.15s;
}
.cp-topbar__back:hover { color: var(--text-primary); }
.cp-topbar__title {
  font-weight: 700;
  font-size: 0.875rem;
  color: var(--text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
}
.cp-topbar__meta {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-shrink: 0;
}
.cp-topbar__duration {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--text-muted);
  flex-shrink: 0;
}
.cp-topbar__progress {
  width: 80px;
  height: 4px;
  background: var(--border-default);
  border-radius: 2px;
  flex-shrink: 0;
  overflow: hidden;
}
.cp-topbar__progress-bar {
  height: 100%;
  background: #34d399;
  border-radius: 2px;
  transition: width 0.3s;
}
.cp-topbar__progress-label {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: var(--text-muted);
  flex-shrink: 0;
}

/* ── Body ────────────────────────────────────────────────────────────────── */
.cp-body {
  display: grid;
  grid-template-columns: 280px 1fr 280px;
  grid-template-areas: "sidebar content infopanel";
  height: calc(100vh - 56px - 48px);
  overflow: hidden;
}
@media (max-width: 1280px) {
  .cp-body {
    grid-template-columns: 260px 1fr;
    grid-template-areas: "sidebar content";
  }
  .cp-infopanel { display: none; }
}
@media (max-width: 800px) {
  .cp-body {
    grid-template-columns: 1fr;
    grid-template-areas: "content";
  }
  .cp-sidebar { display: none; }
  .cp-sidebar-toggle { display: flex; }
}

/* ── Sidebar: chapter/lesson tree ────────────────────────────────────────── */
.cp-sidebar {
  grid-area: sidebar;
  overflow-y: auto;
  scrollbar-width: thin;
  border-right: 1px solid var(--border-default);
  background: var(--bg-surface);
  display: flex;
  flex-direction: column;
}
.cp-sidebar--open {
  display: flex;
  position: fixed;
  top: 104px;
  left: 0;
  width: 280px;
  height: calc(100vh - 104px);
  z-index: 200;
  box-shadow: 4px 0 20px rgba(0,0,0,0.3);
}
.cp-sidebar__inner { padding: 0 0 2rem; flex: 1; }

/* Course info mini card */
.cp-sidebar__course-info {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 1rem;
  border-bottom: 1px solid var(--border-default);
}
.cp-sidebar__thumb {
  width: 48px;
  height: 27px;
  object-fit: cover;
  border-radius: 4px;
  flex-shrink: 0;
}
.cp-sidebar__course-meta { min-width: 0; }
.cp-sidebar__course-title {
  font-size: 0.8rem;
  font-weight: 700;
  color: var(--text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
