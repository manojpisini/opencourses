---
/**
 * [slug].astro — Udemy/Coursera-style course player.
 *
 * For courses with a course-detail.json (published via parse-course), renders
 * the full interactive player: embedded videos, code blocks, reading links,
 * exercise instructions, etc.
 *
 * For courses that only have a summary entry in OC.COURSES (no detail file),
 * falls back to a minimal info page.
 */
import Base from '../../layouts/Base.astro';
import TrackBadge from '../../components/TrackBadge.astro';
import DifficultyBadge from '../../components/DifficultyBadge.astro';
import Avatar from '../../components/Avatar.astro';
import OC from '../../data/oc';
import type { CourseDetailJson, PlayerAssignment, PlayerTest } from '../../types/course';

// ── Load all course-detail JSON files at build time ───────────────────────────
const detailModules = import.meta.glob<{ default: CourseDetailJson }>(
  '../../data/course-details/*.json',
  { eager: true },
);

const detailMap = new Map<string, CourseDetailJson>();
for (const [, mod] of Object.entries(detailModules)) {
  const d = mod.default ?? (mod as unknown as CourseDetailJson);
  if (d?.id) detailMap.set(d.id, d);
}

// ── Static paths ──────────────────────────────────────────────────────────────
export function getStaticPaths() {
  const detailMods = import.meta.glob<{ default: CourseDetailJson }>(
    '../../data/course-details/*.json',
    { eager: true },
  );

  const paths: Array<{ params: { slug: string }; props: { detail: CourseDetailJson | null; slugFallback: string } }> = [];
  const seen = new Set<string>();

  for (const [, mod] of Object.entries(detailMods)) {
    const d = mod.default ?? (mod as unknown as CourseDetailJson);
    if (!d?.id) continue;
    paths.push({ params: { slug: d.id }, props: { detail: d, slugFallback: d.id } });
    seen.add(d.id);
  }

  // Add any OC.COURSES that don't have a detail file yet
  for (const c of OC.COURSES) {
    if (!seen.has(c.slug)) {
      paths.push({ params: { slug: c.slug }, props: { detail: null, slugFallback: c.slug } });
    }
  }

  return paths;
}

interface Props {
  detail: CourseDetailJson | null;
  slugFallback: string;
}

const { detail, slugFallback } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Fallback summary from OC.COURSES
const summaryFallback = OC.COURSES.find(c => c.slug === slugFallback);

const githubRepo = 'manojpisini/opencourses';
const githubRepoUrl = `https://github.com/${githubRepo}`;

type CourseAction = {
  kind: 'enroll' | 'test' | 'final-test' | 'assignment';
  title: string;
  eyebrow: string;
  summary: string;
  formUrl: string;
  ghCommand: string;
  body: string;
  requiresEnrollment: boolean;
  test?: PlayerTest;
  assignment?: PlayerAssignment;
};

function issueFormUrl(template: string, title: string, labels: string): string {
  const params = new URLSearchParams({ template, title, labels });
  return `${githubRepoUrl}/issues/new?${params.toString()}`;
}

function ghWebCommand(template: string, title: string, label: string): string {
  return `gh issue create --repo ${githubRepo} --template ${template} --title "${title}" --label "${label}" --web`;
}

function courseAssetUrl(courseId: string, file: string): string {
  if (/^https?:\/\//.test(file)) return file;
  if (file.startsWith('/')) return `${base}${file}`;
  const encodedPath = file.split('/').map(encodeURIComponent).join('/');
  return `https://raw.githubusercontent.com/${githubRepo}/main/engine/courses/${courseId}/${encodedPath}`;
}

function courseTreeUrl(courseId: string, file = ''): string {
  const cleaned = file.replace(/^\/+/, '').replace(/\/?[^/]*$/, '');
  const suffix = cleaned ? `/${cleaned.split('/').map(encodeURIComponent).join('/')}` : '';
  return `${githubRepoUrl}/tree/main/engine/courses/${courseId}/${suffix}`;
}

function resourceKind(typeOrPath: string): 'image' | 'video' | 'pdf' | 'slide' | 'code' | 'data' | 'link' {
  const value = typeOrPath.toLowerCase();
  if (/\b(image|diagram|figure)\b/.test(value) || /\.(png|jpe?g|webp|gif|svg)$/.test(value)) return 'image';
  if (/\b(video|lecture)\b/.test(value) || /\.(mp4|webm|ogg|mov)$/.test(value)) return 'video';
  if (/\b(pdf|paper|book)\b/.test(value) || /\.pdf($|\?)/.test(value)) return 'pdf';
  if (/\b(slide|deck|presentation)\b/.test(value) || /\.(pptx?|key)$/.test(value)) return 'slide';
  if (/\b(code|repo|notebook)\b/.test(value) || /\.(py|ts|js|ipynb|md|yaml|json)$/.test(value)) return 'code';
  if (/\b(data|dataset)\b/.test(value) || /\.(csv|jsonl|parquet|txt)$/.test(value)) return 'data';
  return 'link';
}

function mediaEmbedUrl(url: string): string | null {
  const yt = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([A-Za-z0-9_-]{11})/);
  if (yt) return `https://www.youtube-nocookie.com/embed/${yt[1]}`;
  if (url.includes('youtube.com/embed/') || url.includes('youtube-nocookie.com/embed/')) return url;
  const vimeo = url.match(/vimeo\.com\/(\d+)/);
  if (vimeo) return `https://player.vimeo.com/video/${vimeo[1]}`;
  if (url.includes('player.vimeo.com/video/')) return url;
  return null;
}

function escapeLessonHtml(value: string): string {
  return String(value ?? '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function renderInlineMarkdown(value: string): string {
  return escapeLessonHtml(value)
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/`([^`]+)`/g, '<code>$1</code>');
}

function isMarkdownTableDivider(line: string): boolean {
  return /^\s*\|?\s*:?-{3,}:?\s*(\|\s*:?-{3,}:?\s*)+\|?\s*$/.test(line);
}

function splitMarkdownTableRow(line: string): string[] {
  return line
    .trim()
    .replace(/^\|/, '')
    .replace(/\|$/, '')
    .split('|')
    .map(cell => cell.trim());
}

function renderParagraph(lines: string[]): string {
  const text = lines.join('\n').trim();
  return text ? `<p>${renderInlineMarkdown(text).replace(/\n/g, '<br>')}</p>` : '';
}

function renderLessonMarkdown(markdown: string): string {
  const lines = String(markdown ?? '').replace(/\r\n/g, '\n').split('\n');
  const blocks: string[] = [];
  let paragraph: string[] = [];
  let list: string[] = [];

  const flushParagraph = () => {
    if (paragraph.length) {
      blocks.push(renderParagraph(paragraph));
      paragraph = [];
    }
  };
  const flushList = () => {
    if (list.length) {
      blocks.push(`<ul class="cp-rich-list">${list.map(item => `<li>${renderInlineMarkdown(item)}</li>`).join('')}</ul>`);
      list = [];
    }
  };

  for (let i = 0; i < lines.length; i++) {
    const line = lines[i] ?? '';
    const trimmed = line.trim();

    if (trimmed.startsWith('```')) {
      flushParagraph();
      flushList();
      const lang = trimmed.replace(/^```/, '').trim() || 'text';
      const codeLines: string[] = [];
      i++;
      while (i < lines.length && !(lines[i] ?? '').trim().startsWith('```')) {
        codeLines.push(lines[i] ?? '');
        i++;
      }
      blocks.push(`<pre class="cp-rich-code"><code class="language-${escapeLessonHtml(lang)}">${escapeLessonHtml(codeLines.join('\n').trim())}</code></pre>`);
      continue;
    }

    if (!trimmed) {
      flushParagraph();
      flushList();
      continue;
    }

    if (/^#{2,3}\s+/.test(trimmed)) {
      flushParagraph();
      flushList();
      const level = trimmed.startsWith('###') ? 3 : 2;
      blocks.push(`<h${level}>${renderInlineMarkdown(trimmed.replace(/^#{2,3}\s+/, ''))}</h${level}>`);
      continue;
    }

    if (trimmed.includes('|') && i + 1 < lines.length && isMarkdownTableDivider(lines[i + 1] ?? '')) {
      flushParagraph();
      flushList();
      const headers = splitMarkdownTableRow(trimmed);
      i += 2;
      const rows: string[][] = [];
      while (i < lines.length && (lines[i] ?? '').trim().includes('|') && (lines[i] ?? '').trim()) {
        rows.push(splitMarkdownTableRow(lines[i] ?? ''));
        i++;
      }
      i--;
      blocks.push(
        '<div class="cp-rich-table-wrap"><table class="cp-rich-table"><thead><tr>' +
        headers.map(cell => `<th>${renderInlineMarkdown(cell)}</th>`).join('') +
        '</tr></thead><tbody>' +
        rows.map(row => `<tr>${headers.map((_header, index) => `<td>${renderInlineMarkdown(row[index] ?? '')}</td>`).join('')}</tr>`).join('') +
        '</tbody></table></div>',
      );
      continue;
    }

    const listMatch = trimmed.match(/^[-*]\s+(.+)$/);
    if (listMatch) {
      flushParagraph();
      list.push(listMatch[1] ?? '');
      continue;
    }

    flushList();
    paragraph.push(line);
  }

  flushParagraph();
  flushList();
  return blocks.join('\n');
}

function enrollmentBody(courseId: string): string {
  return `### Your GitHub Username
@YOUR_USERNAME

### Course Slug
${courseId}

### Email Address (optional)


### Your Goal (optional)


### Current Experience Level
Complete beginner

### Agreements
- [x] I understand OpenCourses enrollment is tracked in the open repository.`;
}

function testAnswersTemplate(test?: PlayerTest): string {
  const questions = test?.sections.flatMap(section => section.questions) ?? [];
  if (!questions.length) {
    return `### Answer: question-id
Your answer here`;
  }
  return questions.map((question) => `### Answer: ${question.id}
Your answer here`).join('\n\n');
}

function chapterTestBody(courseId: string, testId: string, test?: PlayerTest): string {
  return `### Your GitHub Username
@YOUR_USERNAME

### Course Slug
${courseId}

### Test ID
${testId}

### Answers
${testAnswersTemplate(test)}

### Confirmation
- [x] I understand this submission may trigger automated grading.`;
}

function finalTestBody(courseId: string, test?: PlayerTest): string {
  return `### Your GitHub Username
@YOUR_USERNAME

### Course Slug
${courseId}

### Your Enrollment Issue URL
https://github.com/manojpisini/opencourses/issues/ISSUE_NUMBER

### Final Test Answers
${testAnswersTemplate(test)}

### Confirmation
- [x] I understand this final test may trigger automated grading and certificate generation.`;
}

function assignmentBody(courseId: string, chapterId: string, assignmentId: string): string {
  return `### Your GitHub Username
@YOUR_USERNAME

### Course Slug
${courseId}

### Chapter ID
${chapterId}

### Assignment ID
${assignmentId}

### Repository Link
https://github.com/YOUR_USERNAME/your-assignment-repo

### What did you build?
Describe your implementation, important decisions, and known limitations.

### Self-review checklist
- [ ] I completed the required deliverables.
- [ ] My repository is public and accessible.
- [ ] I ran the local tests or validation steps.

### Confirmation
- [x] I confirm this is my own work and uses the same GitHub username as enrollment.`;
}

const courseIdForActions = detail?.id ?? slugFallback;
const courseActions: Record<string, CourseAction> = {};
const chapterTestMap = new Map((detail?.chapter_tests ?? []).map(test => [test.id, test]));
const chapterAssignmentMap = new Map((detail?.chapter_assignments ?? []).map(assignment => [assignment.id, assignment]));
const enrollTitle = `[Enrolled] @YOUR_USERNAME - ${courseIdForActions}`;
courseActions.enroll = {
  kind: 'enroll',
  title: 'Enroll in Course',
  eyebrow: courseIdForActions,
  summary: 'Start this course with the web form or the GitHub CLI.',
  formUrl: issueFormUrl('enroll.yml', enrollTitle, 'enrollment-request'),
  ghCommand: ghWebCommand('enroll.yml', enrollTitle, 'enrollment-request'),
  body: enrollmentBody(courseIdForActions),
  requiresEnrollment: false,
};

if (detail) {
  for (const chapter of detail.chapters) {
    const testId = chapter.chapter_test_id;
    const test = chapterTestMap.get(testId);
    const title = `[Chapter Test] @YOUR_USERNAME - ${detail.id}/${testId}`;
    courseActions[`chapter:${chapter.id}`] = {
      kind: 'test',
      title: `Submit ${chapter.title} Test`,
      eyebrow: testId,
      summary: `${chapter.test_summary.question_count} questions, ${chapter.test_summary.passing_score}% passing score.`,
      formUrl: issueFormUrl('quiz-submit.yml', title, 'quiz-submit'),
      ghCommand: ghWebCommand('quiz-submit.yml', title, 'quiz-submit'),
      body: chapterTestBody(detail.id, testId, test),
      requiresEnrollment: true,
      test,
    };
    if (chapter.chapter_assignment_id) {
      const assignment = chapterAssignmentMap.get(chapter.chapter_assignment_id);
      const assignmentTitle = `[Assignment] @YOUR_USERNAME - ${detail.id}/${chapter.chapter_assignment_id}`;
      courseActions[`assignment:${chapter.id}`] = {
        kind: 'assignment',
        title: assignment?.title ?? `Submit ${chapter.title} Assignment`,
        eyebrow: chapter.chapter_assignment_id,
        summary: assignment?.total_points
          ? `${assignment.total_points} points, ${assignment.passing_score ?? 70}% passing score.`
          : 'Submit your public GitHub repository for this chapter assignment.',
        formUrl: issueFormUrl('assignment-submit.yml', assignmentTitle, 'assignment-submit'),
        ghCommand: ghWebCommand('assignment-submit.yml', assignmentTitle, 'assignment-submit'),
        body: assignmentBody(detail.id, chapter.id, chapter.chapter_assignment_id),
        requiresEnrollment: true,
        assignment,
      };
    }
  }

  if (detail.final_test) {
    const title = `[Final Test] @YOUR_USERNAME - ${detail.id}`;
    courseActions.final = {
      kind: 'final-test',
      title: 'Submit Final Test',
      eyebrow: detail.final_test.id,
      summary: `${detail.final_test.question_count} questions, ${detail.final_test.passing_score}% passing score.`,
      formUrl: issueFormUrl('final-test.yml', title, 'final-test'),
      ghCommand: ghWebCommand('final-test.yml', title, 'final-test'),
      body: finalTestBody(detail.id, detail.final_test),
      requiresEnrollment: true,
      test: detail.final_test,
    };
  }
} else {
  const chapterTestId = 'ch-01-test';
  const chapterTitle = `[Chapter Test] @YOUR_USERNAME - ${courseIdForActions}/${chapterTestId}`;
  courseActions['chapter:manual'] = {
    kind: 'test',
    title: 'Submit Chapter Test',
    eyebrow: chapterTestId,
    summary: 'Use the course test ID shown in the course materials.',
    formUrl: issueFormUrl('quiz-submit.yml', chapterTitle, 'quiz-submit'),
    ghCommand: ghWebCommand('quiz-submit.yml', chapterTitle, 'quiz-submit'),
    body: chapterTestBody(courseIdForActions, chapterTestId),
    requiresEnrollment: true,
  };

  const finalTitle = `[Final Test] @YOUR_USERNAME - ${courseIdForActions}`;
  courseActions.final = {
    kind: 'final-test',
    title: 'Submit Final Test',
    eyebrow: courseIdForActions,
    summary: 'Use this when you have completed the course final test.',
    formUrl: issueFormUrl('final-test.yml', finalTitle, 'final-test'),
    ghCommand: ghWebCommand('final-test.yml', finalTitle, 'final-test'),
    body: finalTestBody(courseIdForActions),
    requiresEnrollment: true,
  };
}

const courseRuntime = {
  actions: courseActions,
  courseId: courseIdForActions,
  githubRepo,
};

// Helpers
function fmtDuration(mins: number): string {
  if (!mins) return '—';
  if (mins < 60) return `${mins}m`;
  const h = Math.floor(mins / 60);
  const m = mins % 60;
  return m ? `${h}h ${m}m` : `${h}h`;
}

function lessonIcon(type: string): string {
  const icons: Record<string, string> = {
    video: 'V',
    reading: 'R',
    code: 'C',
    exercise: 'L',
    reference: 'Ref',
    quiz: 'Q',
    discussion: 'D',
    project: 'P',
    live: 'Live',
  };
  return icons[type] ?? 'Step';
}

// Build flat lesson list with chapter info for navigation
const flatLessons: Array<{ chIdx: number; lIdx: number; lesson: CourseDetailJson['chapters'][number]['lessons'][number]; chapterId: string }> = [];
if (detail) {
  for (let ci = 0; ci < detail.chapters.length; ci++) {
    const ch = detail.chapters[ci]!;
    for (let li = 0; li < ch.lessons.length; li++) {
      flatLessons.push({ chIdx: ci, lIdx: li, lesson: ch.lessons[li]!, chapterId: ch.id });
    }
  }
}

const title  = detail?.title  ?? summaryFallback?.title  ?? slugFallback;
const tagline = detail?.tagline ?? summaryFallback?.description ?? '';
const primaryColor = detail?.cover.color_primary ?? '#4C1BC9';
const secondaryColor = detail?.cover.color_secondary ?? '#7C3AED';
const trackKey = detail?.track ?? summaryFallback?.track ?? 'foundations';
const trackParts = trackKey.split('-').filter(Boolean);
const trackMark = (trackParts.length > 1
  ? trackParts.map(part => part[0]).join('')
  : trackKey.slice(0, 2)
).slice(0, 2).toUpperCase();
const totalH = detail ? `${detail.effort.total_hours}h` : (summaryFallback?.duration ?? '—');
const qualityLabels: Record<string, string> = {
  'actively-maintained': 'Actively maintained',
  'has-assignments': 'Has assignments',
  'has-final-project': 'Has final project',
  'certificate-enabled': 'Certificate enabled',
  'beginner-friendly': 'Beginner friendly',
  'needs-reviewers': 'Needs reviewers',
  'community-verified': 'Community verified',
};
const qualityBadges = detail?.qualityBadges ?? [];

function lessonObjective(detail: CourseDetailJson, chapterId: string, lessonDescription?: string): string {
  return lessonDescription || detail.outcomes.by_chapter[chapterId]?.[0] || detail.outcomes.by_completion[0] || 'Complete the current lesson and move one step closer to certification.';
}
---

<Base
  title={title}
  description={tagline}
  currentPath={`/courses/${slugFallback}`}
>
  {detail ? (
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- FULL COURSE PLAYER                                                      -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <div
      class="cp-root cp-root--locked"
      id="cp-root"
      data-course-id={courseIdForActions}
      data-track={trackKey}
      style={`--course-primary:${primaryColor};--course-secondary:${secondaryColor}`}
    >

      <!-- ── Top bar ──────────────────────────────────────────────────────── -->
      <header class="cp-topbar">
        <a href={`${base}/courses`} class="cp-topbar__back">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          Courses
        </a>
        <div class="cp-topbar__title">{detail.title}</div>
        <div class="cp-topbar__meta">
          <TrackBadge track={detail.track} />
          <DifficultyBadge level={detail.level} />
          <span class="cp-topbar__duration">{totalH}</span>
        </div>
        <!-- Progress bar (driven by JS) -->
        <div class="cp-topbar__progress" id="cp-progress-wrap">
          <div class="cp-topbar__progress-bar" id="cp-progress-bar" style="width:0%"></div>
        </div>
        <span class="cp-topbar__progress-label" id="cp-progress-label">0 / {flatLessons.length}</span>
        <button class="cp-resume-btn" id="cp-resume-btn" type="button" hidden>Continue</button>
      </header>

      <!-- ── Player body: sidebar + content ───────────────────────────────── -->
      <div class="cp-body">

        <!-- Sidebar: chapter / lesson tree -->
        <nav class="cp-sidebar" id="cp-sidebar">
          <div class="cp-sidebar__inner">
            <!-- Course info mini card -->
            <div class="cp-sidebar__course-info">
              <div class="cp-course-abstract cp-course-abstract--mini" data-track={trackKey} aria-hidden="true">
                <span>{trackMark}</span>
              </div>
              <div class="cp-sidebar__course-meta">
                <div class="cp-sidebar__course-title">{detail.title}</div>
                <div class="cp-sidebar__course-sub">
                  {detail.totalChapters} chapters · {detail.totalLessons} lessons
                </div>
              </div>
            </div>

            <div class="cp-sidebar-progress" aria-label="Course chapter timeline">
              <div class="cp-sidebar-progress__top">
                <span>Progress timeline</span>
                <strong id="cp-sidebar-progress-label">0%</strong>
              </div>
              <div class="cp-timeline" id="cp-timeline">
                {detail.chapters.map((ch, ci) => (
                  <span class="cp-timeline__seg" data-timeline-chapter={ci} title={ch.title}></span>
                ))}
              </div>
              <p class="cp-current-objective" id="cp-current-objective">Choose a lesson to begin.</p>
            </div>

            <!-- Chapter list -->
            {detail.chapters.map((ch, ci) => (
              <div class="cp-chapter" id={`cp-ch-${ch.id}`}>
                <button class="cp-chapter__head" data-ch-toggle={ci}>
                  <svg class="cp-chapter__chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                  <span class="cp-chapter__num">{String(ci + 1).padStart(2, '0')}</span>
                  <span class="cp-chapter__title">{ch.title}</span>
                  <span class="cp-chapter__count">{ch.lessonCount}</span>
                </button>
                <div class="cp-chapter__lessons" data-ch-lessons={ci}>
                  {ch.lessons.map((lesson, li) => {
                    const globalIdx = flatLessons.findIndex(fl => fl.chapterId === ch.id && fl.lIdx === li);
                    return (
                      <button
                        class="cp-lesson-btn"
                        data-lesson={globalIdx}
                        data-lesson-id={lesson.id}
                        id={`cp-lessonbtn-${globalIdx}`}
                      >
                        <span class="cp-lesson-btn__icon">{lessonIcon(lesson.type)}</span>
                        <span class="cp-lesson-btn__title">{lesson.title}</span>
                        {lesson.duration_minutes > 0 && (
                          <span class="cp-lesson-btn__dur">{fmtDuration(lesson.duration_minutes)}</span>
                        )}
                        <span class="cp-lesson-btn__check" id={`cp-check-${globalIdx}`}></span>
                      </button>
                    );
                  })}
                  <!-- Chapter test action -->
                  <button class="cp-chapter-test-pill" type="button" data-course-action={`chapter:${ch.id}`} data-requires-enrollment="true">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                    Chapter Test · {ch.test_summary.question_count}q · {ch.test_summary.passing_score}% pass
                    <span class="cp-action-cue">Submit</span>
                  </button>
                  {ch.chapter_assignment_id && (
                    <button class="cp-chapter-test-pill cp-chapter-test-pill--assignment" type="button" data-course-action={`assignment:${ch.id}`} data-requires-enrollment="true">
                      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5-5 5 5"/><path d="M12 5v12"/></svg>
                      Assignment · {ch.chapter_assignment_id}
                      <span class="cp-action-cue">Submit</span>
                    </button>
                  )}
                </div>
              </div>
            ))}

            <!-- Final Test / Assignment pills -->
            {detail.final_test && (
              <button class="cp-final-pill cp-final-pill--test" type="button" data-course-action="final" data-requires-enrollment="true">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                Final Test · {detail.final_test.question_count}q
                <span class="cp-action-cue">Submit</span>
              </button>
            )}
            {detail.final_assignment && (
              <div class="cp-final-pill cp-final-pill--assign">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                Final Assignment
              </div>
            )}

            <!-- Enroll CTA -->
            <button
              class="cp-enroll-btn"
              type="button"
              data-course-action="enroll"
            >
              Enroll / Open Options
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            </button>
          </div>
        </nav>

        <!-- Sidebar toggle (mobile) -->
        <button class="cp-sidebar-toggle" id="cp-sidebar-toggle" aria-label="Toggle course outline">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>

        <!-- ── Main content area ─────────────────────────────────────────── -->
        <main class="cp-content" id="cp-content">
          <article class="cp-pane cp-enrollment-gate" id="cp-enrollment-gate">
            <div class="cp-gate-hero">
              <div class="cp-course-abstract cp-course-abstract--hero" data-track={trackKey} aria-hidden="true">
                <span>{trackMark}</span>
              </div>
              <div>
                <div class="cp-gate-hero__eyebrow">Enrollment required</div>
                <h1 class="cp-gate-hero__title">{detail.title}</h1>
                <p class="cp-gate-hero__desc">{detail.description_short}</p>
                <div class="cp-gate-hero__meta">
                  <TrackBadge track={detail.track} />
                  <DifficultyBadge level={detail.level} />
                  <span>{detail.totalChapters} chapters</span>
                  <span>{detail.totalLessons} lessons</span>
                  <span>{totalH}</span>
                </div>
              </div>
            </div>

            <div class="cp-enrollment-check">
              <label class="cp-enrollment-check__label" for="cp-github-username">GitHub username</label>
              <div class="cp-enrollment-check__row">
                <input class="cp-enrollment-check__input" id="cp-github-username" type="text" placeholder="@your-username" autocomplete="username" />
                <button class="cp-action-choice cp-action-choice--primary" type="button" id="cp-check-enrollment">Check enrollment</button>
                <button class="cp-action-choice" type="button" data-course-action="enroll">Enroll</button>
              </div>
              <p class="cp-enrollment-check__status" id="cp-enrollment-status">
                Enter your GitHub username to unlock the course after enrollment is confirmed.
              </p>
            </div>
          </article>

          <!-- All lesson panes (show one at a time via JS) -->
          {flatLessons.map(({ lesson, chIdx, lIdx }, globalIdx) => {
            const ch = detail.chapters[chIdx]!;
            const isFirst = globalIdx === 0;
            const readingEmbed = lesson.reading ? mediaEmbedUrl(lesson.reading.url) : null;
            const hasPrimaryPlayer = !!lesson.video || !!readingEmbed;
            const resourceFiles = lesson.files ?? [];
            const resourceLinks = [
              ...(lesson.links ?? []),
              ...(lesson.supplemental ?? []).map(link => ({ ...link, required: false, note: undefined })),
            ];
            return (
              <article
                class="cp-pane"
                id={`cp-pane-${globalIdx}`}
                data-lesson-id={lesson.id}
                data-objective={lessonObjective(detail, ch.id, lesson.description)}
                hidden
              >
                <!-- Pane header -->
                <div class="cp-pane__header">
                  <div class="cp-pane__breadcrumb">
                    <span class="cp-pane__ch-name">{ch.title}</span>
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                    <span class="cp-pane__lesson-type">{lesson.type}</span>
                  </div>
                  <h1 class="cp-pane__title">{lesson.title}</h1>
                  {lesson.description && (
                    <p class="cp-pane__desc">{lesson.description}</p>
                  )}
                  {lesson.duration_minutes > 0 && (
                    <div class="cp-pane__dur">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                      {fmtDuration(lesson.duration_minutes)}
                    </div>
                  )}
                  <div class="cp-objective">
                    <span>Current objective</span>
                    <strong>{lessonObjective(detail, ch.id, lesson.description)}</strong>
                  </div>
                </div>

                <!-- ── PRIMARY LEARNING STAGE ────────────────────────────── -->
                {hasPrimaryPlayer && (
                  <section class="cp-learning-stage">
                    <div class="cp-learning-stage__bar">
                      <span class="cp-learning-stage__label">{lesson.video ? 'Watch' : 'Watch before reading'}</span>
                      <span class="cp-learning-stage__source">{lesson.video?.source ?? lesson.reading?.source}</span>
                    </div>
                    <div class="cp-video-wrap">
                      <iframe
                        class="cp-video"
                        data-src={lesson.video?.embed_url ?? readingEmbed}
                        src={isFirst ? (lesson.video?.embed_url ?? readingEmbed ?? undefined) : undefined}
                        title={lesson.title}
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                        allowfullscreen
                        loading="lazy"
                      ></iframe>
                    </div>
                    <div class="cp-video-meta">
                      <a href={lesson.video?.url ?? lesson.reading?.url} target="_blank" rel="noopener" class="cp-video-meta__link">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                        Open source
                      </a>
                      {lesson.video?.channel && (
                        <span class="cp-video-meta__channel">by {lesson.video.channel}</span>
                      )}
                      {lesson.video?.subtitles_available && (
                        <span class="cp-video-meta__subs">CC available</span>
                      )}
                      {lesson.reading?.estimated_minutes && (
                        <span class="cp-video-meta__subs">~{lesson.reading.estimated_minutes} min</span>
                      )}
                    </div>
                    {readingEmbed && lesson.reading?.sections_to_read && lesson.reading.sections_to_read.length > 0 && (
                      <div class="cp-watch-plan">
                        <strong>Focus</strong>
                        <ul>
                          {lesson.reading.sections_to_read.map(s => <li>{s}</li>)}
                        </ul>
                      </div>
                    )}
                  </section>
                )}

                <!-- Video timestamps -->
                {lesson.video?.timestamps && lesson.video.timestamps.length > 0 && (
                  <div class="cp-timestamps">
                    <div class="cp-timestamps__title">Chapters</div>
                    <div class="cp-timestamps__list">
                      {lesson.video.timestamps.map(ts => (
                        <div class="cp-timestamp">
                          <code class="cp-timestamp__time">{ts.time}</code>
                          <span class="cp-timestamp__label">{ts.label}</span>
                        </div>
                      ))}
                    </div>
                  </div>
                )}

                <!-- ── READING ────────────────────────────────────────────── -->
                {lesson.reading && !readingEmbed && (
                  <div class={`cp-reading ${readingEmbed ? 'cp-reading--with-player' : ''}`}>
                    <div class="cp-reading__source">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                      <a href={lesson.reading.url} target="_blank" rel="noopener" class="cp-reading__link">
                        {readingEmbed ? 'Source: ' : 'Read on '}{lesson.reading.source}
                        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                      </a>
                      {lesson.reading.estimated_minutes && (
                        <span class="cp-reading__est">~{lesson.reading.estimated_minutes} min read</span>
                      )}
                    </div>
                    {lesson.reading.sections_to_read && lesson.reading.sections_to_read.length > 0 && (
                      <div class="cp-reading__sections">
                        <strong>{readingEmbed ? 'Focus while watching:' : 'Read these sections:'}</strong>
                        <ul>
                          {lesson.reading.sections_to_read.map(s => <li>{s}</li>)}
                        </ul>
                      </div>
                    )}
                  </div>
                )}

                <!-- ── TEXT / CURATOR NOTES ───────────────────────────────── -->
                {lesson.text_md && (
                  <div class="cp-notes">
                    <div class="cp-notes__label">
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                      Lesson Guide
                    </div>
                    <div class="cp-notes__body prose" set:html={renderLessonMarkdown(lesson.text_md)}></div>
                  </div>
                )}

                <!-- ── NATIVE RESOURCES ───────────────────────────────────── -->
                {(resourceFiles.length > 0 || resourceLinks.length > 0) && (
                  <details class="cp-resources" aria-label="Lesson resources" open>
                    <summary class="cp-resources__header">
                      <span>Course Resources</span>
                      <small>{resourceFiles.length + resourceLinks.length} item{resourceFiles.length + resourceLinks.length === 1 ? '' : 's'}</small>
                    </summary>
                    <div class="cp-resource-grid">
                      {resourceFiles.map(file => {
                        const src = courseAssetUrl(detail.id, file.file);
                        const kind = resourceKind(`${file.type} ${file.file}`);
                        return (
                          <article class={`cp-resource-card cp-resource-card--${kind}`}>
                            <div class="cp-resource-card__media">
                              {kind === 'image' && (
                                <>
                                  <img src={src} alt={file.label} loading="lazy" class="cp-resource-card__img" data-zoomable-image />
                                  <button
                                    class="cp-resource-card__zoom"
                                    type="button"
                                    data-image-viewer-open
                                    data-image-src={src}
                                    data-image-title={file.label}
                                    aria-label={`View ${file.label} larger`}
                                  >
                                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="m21 3-7 7"/><path d="M9 21H3v-6"/><path d="m3 21 7-7"/></svg>
                                  </button>
                                </>
                              )}
                              {kind === 'video' && (
                                <video controls preload="metadata" class="cp-resource-card__video">
                                  <source src={src} />
                                </video>
                              )}
                              {kind === 'pdf' && (
                                <iframe src={src} title={file.label} loading="lazy" class="cp-resource-card__frame"></iframe>
                              )}
                              {kind !== 'image' && kind !== 'video' && kind !== 'pdf' && (
                                <div class="cp-resource-card__placeholder">
                                  <span>{kind}</span>
                                </div>
                              )}
                            </div>
                            <div class="cp-resource-card__body">
                              <div>
                                <h3>{file.label}</h3>
                                <p>{file.file}</p>
                              </div>
                              <a href={src} target="_blank" rel="noopener" class="cp-resource-card__open">Open</a>
                            </div>
                          </article>
                        );
                      })}
                      {resourceLinks.map(link => {
                        const embed = mediaEmbedUrl(link.url);
                        const kind = embed ? 'video' : resourceKind(`${link.type} ${link.url}`);
                        return (
                          <article class={`cp-resource-card cp-resource-card--${kind}`}>
                            <div class="cp-resource-card__media">
                              {embed && (
                                <iframe
                                  src={embed}
                                  title={link.label}
                                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                                  allowfullscreen
                                  loading="lazy"
                                  class="cp-resource-card__frame"
                                ></iframe>
                              )}
                              {!embed && kind === 'image' && (
                                <>
                                  <img src={link.url} alt={link.label} loading="lazy" class="cp-resource-card__img" data-zoomable-image />
                                  <button
                                    class="cp-resource-card__zoom"
                                    type="button"
                                    data-image-viewer-open
                                    data-image-src={link.url}
                                    data-image-title={link.label}
                                    aria-label={`View ${link.label} larger`}
                                  >
                                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="m21 3-7 7"/><path d="M9 21H3v-6"/><path d="m3 21 7-7"/></svg>
                                  </button>
                                </>
                              )}
                              {!embed && kind === 'pdf' && (
                                <iframe src={link.url} title={link.label} loading="lazy" class="cp-resource-card__frame"></iframe>
                              )}
                              {!embed && kind !== 'pdf' && kind !== 'image' && (
                                <div class="cp-resource-card__placeholder">
                                  <span>{kind}</span>
                                </div>
                              )}
                            </div>
                            <div class="cp-resource-card__body">
                              <div>
                                <h3>{link.label}</h3>
                                <p>{link.note ?? link.type}</p>
                              </div>
                              <a href={link.url} target="_blank" rel="noopener" class="cp-resource-card__open">Open</a>
                            </div>
                            {link.required && <div class="cp-resource-card__required">Required</div>}
                          </article>
                        );
                      })}
                    </div>
                  </details>
                )}

                <!-- ── CODE BLOCKS ────────────────────────────────────────── -->
                {lesson.code_blocks && lesson.code_blocks.length > 0 && (
                  <div class="cp-code-section">
                    {lesson.code_blocks.map(cb => (
                      <div class="cp-code-block">
                        <div class="cp-code-block__bar">
                          <div class="cp-code-block__dots">
                            <span></span><span></span><span></span>
                          </div>
                          <span class="cp-code-block__title">{cb.title}</span>
                          <span class="cp-code-block__lang">{cb.language}</span>
                          <button class="cp-code-block__copy" data-copy-src={cb.snippet}>Copy</button>
                        </div>
                        <pre class="cp-code-block__pre"><code class={`language-${cb.language}`}>{cb.snippet}</code></pre>
                        {cb.explanation && (
                          <div class="cp-code-block__explain">{cb.explanation}</div>
                        )}
                        {cb.expected_output && (
                          <div class="cp-code-block__output">
                            <span class="cp-code-block__output-label">Expected output</span>
                            <pre><code>{cb.expected_output}</code></pre>
                          </div>
                        )}
                      </div>
                    ))}
                  </div>
                )}

                <!-- ── EXERCISE ───────────────────────────────────────────── -->
                {lesson.exercise && (
                  <div class="cp-exercise">
                    <div class="cp-exercise__header">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                      Hands-on Exercise
                    </div>
                    <div class="cp-exercise__body">
                      <a href={courseTreeUrl(detail.id, 'assets/starter')} class="cp-exercise__repo" target="_blank" rel="noopener">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2c-3.2.7-3.87-1.36-3.87-1.36-.52-1.33-1.27-1.68-1.27-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.69 1.25 3.34.96.1-.74.4-1.25.72-1.54-2.55-.29-5.23-1.28-5.23-5.69 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.17 1.18a11 11 0 0 1 5.78 0c2.2-1.49 3.17-1.18 3.17-1.18.62 1.58.23 2.75.11 3.04.74.81 1.18 1.84 1.18 3.1 0 4.42-2.69 5.39-5.25 5.68.41.36.78 1.06.78 2.14v3.17c0 .31.21.67.8.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5Z"/></svg>
                        Open starter files
                      </a>
                      {lesson.exercise.entry_file && (
                        <div class="cp-exercise__cmd">
                          <span class="cp-exercise__cmd-label">Work in:</span>
                          <code>{lesson.exercise.entry_file}</code>
                        </div>
                      )}
                      {lesson.exercise.test_command && (
                        <div class="cp-exercise__cmd">
                          <span class="cp-exercise__cmd-label">Run tests:</span>
                          <code>{lesson.exercise.test_command}</code>
                        </div>
                      )}
                      {lesson.exercise.submission_type && (
                        <div class="cp-exercise__submit">
                          Submit via: <strong>{lesson.exercise.submission_type}</strong>
                        </div>
                      )}
                    </div>
                    {lesson.hints && lesson.hints.length > 0 && (
                      <details class="cp-hints">
                        <summary class="cp-hints__toggle">Hints ({lesson.hints.length})</summary>
                        <div class="cp-hints__list">
                          {lesson.hints.map((h, hi) => (
                            <div class="cp-hint">
                              <span class="cp-hint__level">Hint {hi + 1}</span>
                              <p>{h.text}</p>
                            </div>
                          ))}
                        </div>
                      </details>
                    )}
                  </div>
                )}

                <!-- Prev / Next navigation -->
                <div class="cp-pane__nav">
                  {globalIdx > 0 && (
                    <button class="cp-pane__nav-btn cp-pane__nav-btn--prev" data-go-lesson={globalIdx - 1}>
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
                      {flatLessons[globalIdx - 1]?.lesson.title ?? 'Previous'}
                    </button>
                  )}
                  {globalIdx < flatLessons.length - 1 && (
                    <button class="cp-pane__nav-btn cp-pane__nav-btn--next" data-go-lesson={globalIdx + 1}>
                      {flatLessons[globalIdx + 1]?.lesson.title ?? 'Next'}
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                    </button>
                  )}
                </div>
              </article>
            );
          })}

          <!-- Overview pane (course intro — shown before any lesson is selected on fresh load) -->
          {flatLessons.length === 0 && (
            <div class="cp-pane" style="padding:3rem 2rem">
              <h1 style="margin:0 0 1rem">{detail.title}</h1>
              <p style="color:var(--text-secondary)">{detail.description_short}</p>
              <p style="color:var(--text-muted);font-size:0.85rem">This course has no lessons yet — check back after publish.</p>
            </div>
          )}
        </main>

        <!-- ── Right info panel ──────────────────────────────────────────── -->
        <aside class="cp-infopanel">

          <!-- Course actions -->
          <div class="cp-card cp-action-card cp-card--public">
            <div class="cp-card__title">Course actions</div>
            <div class="cp-action-list">
              <button class="cp-action-row" type="button" data-course-action="enroll">
                <span>
                  <strong>Enroll</strong>
                  <small>Web form or gh command</small>
                </span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
              </button>
              {detail.chapters.length > 0 && (
                <button class="cp-action-row" type="button" data-course-action={`chapter:${detail.chapters[0]!.id}`} data-requires-enrollment="true">
                  <span>
                    <strong>Submit chapter test</strong>
                    <small>Pick any chapter from the outline</small>
                  </span>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </button>
              )}
              {detail.chapters.find(ch => ch.chapter_assignment_id) && (
                <button class="cp-action-row" type="button" data-course-action={`assignment:${detail.chapters.find(ch => ch.chapter_assignment_id)!.id}`} data-requires-enrollment="true">
                  <span>
                    <strong>Submit assignment</strong>
                    <small>Chapter repository submission</small>
                  </span>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </button>
              )}
              {detail.final_test && (
                <button class="cp-action-row" type="button" data-course-action="final" data-requires-enrollment="true">
                  <span>
                    <strong>Submit final test</strong>
                    <small>{detail.final_test.id}</small>
                  </span>
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </button>
              )}
            </div>
          </div>

          {qualityBadges.length > 0 && (
            <div class="cp-card cp-card--quality cp-card--public">
              <div class="cp-card__title">Course quality</div>
              <div class="cp-quality-badges">
                {qualityBadges.map(badge => <span class="cp-quality-badge">{qualityLabels[badge] ?? badge}</span>)}
              </div>
            </div>
          )}

          <!-- About this course -->
          <div class="cp-card cp-card--public">
            <div class="cp-card__title">About this course</div>
            <p class="cp-card__text">{detail.description_short}</p>
            <div class="cp-card__pills">
              {detail.tags.map(t => <span class="cp-tag">{t}</span>)}
            </div>
          </div>

          <!-- Skills gained -->
          {detail.skills_gained.length > 0 && (
            <div class="cp-card">
              <div class="cp-card__title">Skills you'll gain</div>
              <ul class="cp-skills">
                {detail.skills_gained.slice(0, 8).map(s => (
                  <li class="cp-skill">
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#34d399" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                    {s}
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- Prerequisites -->
          {(detail.prerequisites.knowledge.length > 0 || detail.prerequisites.courses.length > 0 || detail.prerequisites.tools.length > 0) && (
            <div class="cp-card">
              <div class="cp-card__title">Prerequisites</div>
              {detail.prerequisites.knowledge.length > 0 && (
                <ul class="cp-skills" style="margin-bottom:0.5rem">
                  {detail.prerequisites.knowledge.map(k => (
                    <li class="cp-skill">
                      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                      {k}
                    </li>
                  ))}
                </ul>
              )}
              {detail.prerequisites.courses.length > 0 && (
                <div>
                  {detail.prerequisites.courses.map(cid => {
                    const c = OC.COURSES.find(x => x.slug === cid);
                    return (
                      <a href={`${base}/courses/${cid}`} class="cp-prereq-course">
                        📚 {c?.title ?? cid}
                      </a>
                    );
                  })}
                </div>
              )}
              {detail.prerequisites.tools.length > 0 && (
                <ul class="cp-skills" style="margin-top:0.5rem">
                  {detail.prerequisites.tools.map(t => (
                    <li class="cp-skill">
                      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                      <a href={t.url} target="_blank" rel="noopener">{t.name}</a>
                      {t.required && <span style="color:var(--text-muted);font-size:0.7em">required</span>}
                    </li>
                  ))}
                </ul>
              )}
            </div>
          )}

          <!-- Outcomes -->
          {detail.outcomes.by_completion.length > 0 && (
            <div class="cp-card">
              <div class="cp-card__title">What you'll learn</div>
              <ul class="cp-skills">
                {detail.outcomes.by_completion.map(o => (
                  <li class="cp-skill">
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4C1BC9" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                    {o}
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- Curator -->
          <div class="cp-card">
            <div class="cp-card__title">Curator</div>
            <div class="cp-curator">
              <Avatar login={detail.curator.github} size="sm" />
              <div>
                <div class="cp-curator__name">{detail.curator.name}</div>
                <div class="cp-curator__role">@{detail.curator.github} · {detail.curator.role}</div>
              </div>
            </div>
            {detail.curator.bio && <p class="cp-curator__bio">{detail.curator.bio}</p>}
          </div>

          <!-- Certificate -->
          {detail.certificate.enabled && (
            <div class="cp-card cp-card--cert">
              <div class="cp-card__title">Certificate</div>
              <div class="cp-cert-title">{detail.certificate.title}</div>
              {detail.certificate.subtitle && (
                <div class="cp-cert-sub">{detail.certificate.subtitle}</div>
              )}
              <div class="cp-cert-req">
                {detail.certificate.requirements.map(r => (
                  <div class="cp-cert-req__item">
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#fb923c" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                    {r.type.replace(/_/g, ' ')} ≥ {r.min_score}%
                  </div>
                ))}
              </div>
              <div class="cp-cert-badge">GPG-signed SVG · Open Badges 3.0</div>
            </div>
          )}

          <!-- Enroll -->
          <button
            class="cp-enroll-btn cp-enroll-btn--full"
            type="button"
            data-course-action="enroll"
          >
            Enroll / Open Options
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </button>
        </aside>
      </div>
    </div>

  ) : (

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- FALLBACK: minimal course info page (no detail file yet)                -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <div class="container" style="padding-top:2rem;padding-bottom:4rem">
      <div style="display:flex;align-items:center;gap:6px;font-family:var(--font-mono);font-size:0.72rem;color:var(--text-muted);margin-bottom:1.5rem">
        <a href={`${base}/`} style="color:var(--text-muted)">~</a>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        <a href={`${base}/courses`} style="color:var(--text-muted)">courses</a>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        <span>{slugFallback}</span>
      </div>

      <h1 style="font-size:2rem;font-weight:800;margin:0 0 0.5rem;letter-spacing:-0.02em">{title}</h1>
      <p style="font-size:1rem;color:var(--text-secondary);margin:0 0 2rem;max-width:640px">{tagline}</p>

      {summaryFallback && (
        <div style="display:flex;flex-wrap:wrap;gap:0.75rem;align-items:center;margin-bottom:2rem">
          <TrackBadge track={summaryFallback.track} />
          <DifficultyBadge level={summaryFallback.difficulty} />
          <span style="font-family:var(--font-mono);font-size:0.78rem;color:var(--text-muted)">{summaryFallback.duration}</span>
          <span style="font-family:var(--font-mono);font-size:0.78rem;color:var(--text-muted)">{summaryFallback.modules} chapters</span>
        </div>
      )}

      <div style="background:var(--bg-surface);border:1px solid var(--border-default);border-radius:10px;padding:1.5rem;max-width:560px">
        <div style="font-size:0.85rem;color:var(--text-muted);margin-bottom:1rem">Course content is being published. Full player coming soon.</div>
        <div class="cp-fallback-actions">
          <button class="cp-action-row" type="button" data-course-action="enroll">
            <span>
              <strong>Enroll</strong>
              <small>Web form or gh command</small>
            </span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </button>
          <button class="cp-action-row" type="button" data-course-action="chapter:manual" data-requires-enrollment="true">
            <span>
              <strong>Submit chapter test</strong>
              <small>Edit the test ID before submitting</small>
            </span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </button>
          <button class="cp-action-row" type="button" data-course-action="final" data-requires-enrollment="true">
            <span>
              <strong>Submit final test</strong>
              <small>Complete the course final</small>
            </span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </button>
        </div>
      </div>
    </div>
  )}

  {Object.keys(courseActions).length > 0 && (
    <div class="cp-action-modal" id="cp-action-modal" hidden>
      <div class="cp-action-modal__backdrop" data-action-close></div>
      <section class="cp-action-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="cp-action-title">
        <button class="cp-action-modal__close" type="button" data-action-close aria-label="Close action panel">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
        <div class="cp-action-modal__eyebrow" id="cp-action-eyebrow"></div>
        <h2 class="cp-action-modal__title" id="cp-action-title">Course action</h2>
        <p class="cp-action-modal__summary" id="cp-action-summary"></p>

        <label class="cp-action-body-label" for="cp-action-username">GitHub username</label>
        <input class="cp-action-username" id="cp-action-username" type="text" placeholder="@your-username" autocomplete="username" />
        <p class="cp-action-modal__hint" id="cp-action-username-hint">This username is written into the issue body and must match the account that opens the issue.</p>

        <div class="cp-test-composer" id="cp-test-composer" hidden>
          <div class="cp-test-composer__head">
            <div>
              <span class="cp-test-composer__eyebrow">In-course test</span>
              <h3 id="cp-test-composer-title">Answer questions</h3>
            </div>
            <span class="cp-test-composer__meta" id="cp-test-composer-meta"></span>
          </div>
          <div class="cp-test-composer__questions" id="cp-test-composer-questions"></div>
        </div>

        <div class="cp-action-modal__options">
          <a class="cp-action-choice cp-action-choice--primary" id="cp-action-form" href="#" target="_blank" rel="noopener">
            Open form
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
          <button class="cp-action-choice" type="button" id="cp-copy-gh">Copy gh command</button>
          <button class="cp-action-choice" type="button" id="cp-copy-body">Copy body</button>
        </div>

        <div class="cp-action-codeblock">
          <div class="cp-action-codeblock__label">GitHub CLI</div>
          <pre id="cp-action-command"></pre>
        </div>
        <label class="cp-action-body-label" for="cp-action-body">Submission body</label>
        <textarea class="cp-action-body" id="cp-action-body" spellcheck="false"></textarea>
      </section>
    </div>
  )}

  <div class="cp-image-viewer" id="cp-image-viewer" hidden>
    <div class="cp-image-viewer__backdrop" data-image-viewer-close></div>
    <section class="cp-image-viewer__dialog" role="dialog" aria-modal="true" aria-labelledby="cp-image-viewer-title">
      <header class="cp-image-viewer__bar">
        <h2 id="cp-image-viewer-title">Image preview</h2>
        <div class="cp-image-viewer__actions">
          <button class="cp-image-viewer__btn" type="button" data-image-zoom="out" aria-label="Zoom out">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M5 12h14"/></svg>
          </button>
          <button class="cp-image-viewer__btn" type="button" data-image-zoom="reset">100%</button>
          <button class="cp-image-viewer__btn" type="button" data-image-zoom="in" aria-label="Zoom in">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
          </button>
          <button class="cp-image-viewer__btn" type="button" data-image-fullscreen>
            Fullscreen
          </button>
          <button class="cp-image-viewer__btn cp-image-viewer__btn--close" type="button" data-image-viewer-close aria-label="Close image preview">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
          </button>
        </div>
      </header>
      <div class="cp-image-viewer__stage" id="cp-image-viewer-stage">
        <img id="cp-image-viewer-img" alt="" />
      </div>
    </section>
  </div>

  <!-- Highlight.js for syntax highlighting -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js" is:inline></script>

  <script define:vars={{ courseRuntime }} is:inline>
    window.OC_COURSE_ACTIONS = courseRuntime.actions;
    window.OC_COURSE_ID = courseRuntime.courseId;
    window.OC_GITHUB_REPO = courseRuntime.githubRepo;
  </script>

  <script is:inline>
  (function () {
    'use strict';

    // ── Highlight.js init ──────────────────────────────────────────────────
    if (typeof hljs !== 'undefined') {
      document.querySelectorAll('pre code[class^="language-"]').forEach(function (el) {
        hljs.highlightElement(el);
      });
    }

    // ── Course action panel ───────────────────────────────────────────────
    var actions = window.OC_COURSE_ACTIONS || {};
    var actionModal = document.getElementById('cp-action-modal');
    var actionTitle = document.getElementById('cp-action-title');
    var actionEyebrow = document.getElementById('cp-action-eyebrow');
    var actionSummary = document.getElementById('cp-action-summary');
    var actionForm = document.getElementById('cp-action-form');
    var actionCommand = document.getElementById('cp-action-command');
    var actionBody = document.getElementById('cp-action-body');
    var copyGh = document.getElementById('cp-copy-gh');
    var copyBody = document.getElementById('cp-copy-body');
    var testComposer = document.getElementById('cp-test-composer');
    var testComposerTitle = document.getElementById('cp-test-composer-title');
    var testComposerMeta = document.getElementById('cp-test-composer-meta');
    var testComposerQuestions = document.getElementById('cp-test-composer-questions');
    var activeAction = null;
    var root = document.getElementById('cp-root');
    var gate = document.getElementById('cp-enrollment-gate');
    var gateInput = document.getElementById('cp-github-username');
    var modalInput = document.getElementById('cp-action-username');
    var checkBtn = document.getElementById('cp-check-enrollment');
    var enrollmentStatus = document.getElementById('cp-enrollment-status');
    var imageViewer = document.getElementById('cp-image-viewer');
    var imageViewerImg = document.getElementById('cp-image-viewer-img');
    var imageViewerTitle = document.getElementById('cp-image-viewer-title');
    var imageViewerStage = document.getElementById('cp-image-viewer-stage');
    var currentObjective = document.getElementById('cp-current-objective');
    var sidebarProgressLabel = document.getElementById('cp-sidebar-progress-label');
    var resumeBtn = document.getElementById('cp-resume-btn');
    var courseId = window.OC_COURSE_ID || '';
    var githubRepo = window.OC_GITHUB_REPO || 'manojpisini/opencourses';
    var enrollmentIssue = null;
    var playerReady = false;
    var imageZoom = 1;

    function normalizeUsername(value) {
      return String(value || '').trim().replace(/^@+/, '').toLowerCase();
    }

    function enrollmentStorageKey(username) {
      return 'oc-enrollment-' + courseId + '-' + normalizeUsername(username);
    }

    function getStoredUsername() {
      try { return localStorage.getItem('oc-github-username') || ''; }
      catch { return ''; }
    }

    function setStoredUsername(username) {
      try { localStorage.setItem('oc-github-username', normalizeUsername(username)); }
      catch {}
    }

    function currentUsername() {
      return normalizeUsername(
        (modalInput && modalInput.value) ||
        (gateInput && gateInput.value) ||
        getStoredUsername()
      );
    }

    function setUsernameInputs(username) {
      var clean = normalizeUsername(username);
      if (gateInput && gateInput.value !== clean) gateInput.value = clean ? '@' + clean : '';
      if (modalInput && modalInput.value !== clean) modalInput.value = clean ? '@' + clean : '';
    }

    function withUsername(text, username) {
      var clean = normalizeUsername(username) || 'YOUR_USERNAME';
      var issueNumber = enrollmentIssue && enrollmentIssue.number ? String(enrollmentIssue.number) : 'ISSUE_NUMBER';
      return String(text || '')
        .replace(/@YOUR_USERNAME/g, '@' + clean)
        .replace(/YOUR_USERNAME/g, clean)
        .replace(/ISSUE_NUMBER/g, issueNumber);
    }

    function escapeHtml(value) {
      return String(value || '').replace(/[&<>"']/g, function (char) {
        return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[char];
      });
    }

    function getQuestionInputName(questionId) {
      return 'cp-answer-' + String(questionId || '').replace(/[^a-zA-Z0-9_-]/g, '-');
    }

    function answerBlock(question, value) {
      return '### Answer: ' + question.id + '\n' + String(value || '').trim();
    }

    function collectTestAnswers() {
      if (!activeAction || !activeAction.test) return null;
      var blocks = [];
      activeAction.test.sections.forEach(function (section) {
        section.questions.forEach(function (question) {
          var name = getQuestionInputName(question.id);
          var value = '';
          if (question.type === 'multi') {
            value = Array.from(document.querySelectorAll('[name="' + name + '"]:checked'))
              .map(function (input) { return input.value; })
              .join(', ');
          } else {
            var input = document.querySelector('[name="' + name + '"]');
            value = input ? input.value : '';
          }
          blocks.push(answerBlock(question, value || 'Your answer here'));
        });
      });
      return blocks.join('\n\n');
    }

    function mergeTestAnswers(body) {
      var answers = collectTestAnswers();
      if (!answers) return body;
      if (body.indexOf('### Final Test Answers') !== -1) {
        return body.replace(/### Final Test Answers[\s\S]*?### Confirmation/, '### Final Test Answers\n' + answers + '\n\n### Confirmation');
      }
      return body.replace(/### Answers[\s\S]*?### Confirmation/, '### Answers\n' + answers + '\n\n### Confirmation');
    }

    function mergeAssignmentFields(body) {
      if (!activeAction || !activeAction.assignment) return body;
      var repoInput = document.getElementById('cp-assignment-repo');
      var repo = repoInput && repoInput.value ? repoInput.value.trim() : '';
      if (!repo) return body;
      return body.replace(/### Repository Link\n[^\n]*/, '### Repository Link\n' + repo);
    }

    function renderAction(action) {
      if (!action) return;
      var username = currentUsername();
      if (actionForm) actionForm.href = withUsername(action.formUrl, username);
      if (actionCommand) actionCommand.textContent = withUsername(action.ghCommand, username);
      if (actionBody) actionBody.value = mergeAssignmentFields(mergeTestAnswers(withUsername(action.body, username)));
    }

    function renderTestComposer(action) {
      if (!testComposer || !testComposerQuestions) return;
      if (action && action.assignment) {
        var assignment = action.assignment;
        testComposer.hidden = false;
        if (testComposerTitle) testComposerTitle.textContent = assignment.title;
        if (testComposerMeta) {
          var assignmentBits = [assignment.submission_type || 'github_url'];
          if (assignment.total_points) assignmentBits.push(assignment.total_points + ' pts');
          if (assignment.passing_score) assignmentBits.push(assignment.passing_score + '% pass');
          testComposerMeta.textContent = assignmentBits.join(' · ');
        }
        var text = assignment.content && assignment.content.text && assignment.content.text.body
          ? '<div class="cp-assignment-brief">' + escapeHtml(assignment.content.text.body) + '</div>'
          : '';
        var rubric = assignment.rubric && assignment.rubric.length
          ? '<div class="cp-assignment-rubric"><h4>Rubric</h4>' + assignment.rubric.map(function (item) {
              return '<div><span>' + escapeHtml(item.criterion) + '</span><strong>' + item.points + ' pts</strong></div>';
            }).join('') + '</div>'
          : '';
        testComposerQuestions.innerHTML = text + rubric +
          '<label class="cp-action-body-label" for="cp-assignment-repo">Repository link</label>' +
          '<input class="cp-action-username" id="cp-assignment-repo" type="url" placeholder="https://github.com/your-username/your-assignment-repo">';
        var repoInput = document.getElementById('cp-assignment-repo');
        if (repoInput) {
          repoInput.addEventListener('input', function () {
            renderAction(activeAction);
          });
        }
        return;
      }
      if (!action || !action.test || !action.test.sections) {
        testComposer.hidden = true;
        testComposerQuestions.innerHTML = '';
        return;
      }
      var test = action.test;
      testComposer.hidden = false;
      if (testComposerTitle) testComposerTitle.textContent = test.title;
      if (testComposerMeta) {
        var bits = [test.question_count + ' questions', test.passing_score + '% pass', test.max_attempts + ' attempts'];
        if (test.time_limit_minutes) bits.push(test.time_limit_minutes + ' min');
        testComposerMeta.textContent = bits.join(' · ');
      }
      testComposerQuestions.innerHTML = test.sections.map(function (section) {
        return '<section class="cp-test-section">' +
          '<div class="cp-test-section__title">' + escapeHtml(section.title) + '<span>' + section.weight + '%</span></div>' +
          section.questions.map(function (question, index) {
            var name = getQuestionInputName(question.id);
            var code = question.code && question.code.snippet
              ? '<pre class="cp-test-question__code"><code>' + escapeHtml(question.code.snippet) + '</code></pre>'
              : '';
            var input = '';
            if (question.options && question.options.length && question.type !== 'short') {
              input = '<div class="cp-test-question__options">' + question.options.map(function (option, optIndex) {
                var type = question.type === 'multi' ? 'checkbox' : 'radio';
                var value = String.fromCharCode(65 + optIndex);
                return '<label class="cp-test-option"><input type="' + type + '" name="' + name + '" value="' + value + '"><span>' + value + '. ' + escapeHtml(option) + '</span></label>';
              }).join('') + '</div>';
            } else if (question.type === 'truefalse') {
              input = '<div class="cp-test-question__options">' +
                '<label class="cp-test-option"><input type="radio" name="' + name + '" value="true"><span>True</span></label>' +
                '<label class="cp-test-option"><input type="radio" name="' + name + '" value="false"><span>False</span></label>' +
                '</div>';
            } else {
              input = '<textarea class="cp-test-answer" name="' + name + '" rows="5" placeholder="Write your answer here"></textarea>';
            }
            return '<article class="cp-test-question">' +
              '<div class="cp-test-question__top"><span>Q' + (index + 1) + '</span><code>' + escapeHtml(question.id) + '</code><strong>' + question.points + ' pts</strong></div>' +
              '<p class="cp-test-question__prompt">' + escapeHtml(question.question) + '</p>' +
              code +
              input +
              '</article>';
          }).join('') +
          '</section>';
      }).join('');
      testComposerQuestions.querySelectorAll('input, textarea').forEach(function (input) {
        input.addEventListener('input', function () { renderAction(activeAction); });
        input.addEventListener('change', function () { renderAction(activeAction); });
      });
      if (typeof hljs !== 'undefined') {
        testComposerQuestions.querySelectorAll('pre code').forEach(function (el) {
          hljs.highlightElement(el);
        });
      }
    }

    function setStatus(message, tone) {
      if (!enrollmentStatus) return;
      enrollmentStatus.textContent = message;
      enrollmentStatus.dataset.tone = tone || 'muted';
    }

    function unlockCourse(issue) {
      enrollmentIssue = issue || enrollmentIssue;
      if (!root) return;
      root.classList.remove('cp-root--locked');
      root.classList.add('cp-root--enrolled');
      if (gate) gate.hidden = true;
      if (!playerReady) initPlayer();
      renderAction(activeAction);
    }

    function lockCourse(message) {
      if (root) {
        root.classList.add('cp-root--locked');
        root.classList.remove('cp-root--enrolled');
      }
      if (gate) gate.hidden = false;
      document.querySelectorAll('.cp-pane').forEach(function (pane) {
        if (pane !== gate) pane.hidden = true;
      });
      setStatus(message || 'Enroll with your GitHub username to unlock lessons and test submission.', 'muted');
    }

    async function verifyEnrollment(username) {
      var clean = normalizeUsername(username);
      if (!clean) {
        lockCourse('Enter your GitHub username first.');
        return null;
      }
      setUsernameInputs(clean);
      setStoredUsername(clean);
      setStatus('Checking @' + clean + ' on GitHub...', 'loading');

      var userResponse = await fetch('https://api.github.com/users/' + encodeURIComponent(clean), {
        headers: { Accept: 'application/vnd.github+json' },
      });
      if (!userResponse.ok) {
        lockCourse('GitHub user @' + clean + ' was not found.');
        return null;
      }

      var labels = encodeURIComponent('enrolled,course:' + courseId);
      var issuesResponse = await fetch('https://api.github.com/repos/' + githubRepo + '/issues?state=open&labels=' + labels + '&per_page=100', {
        headers: { Accept: 'application/vnd.github+json' },
      });
      if (!issuesResponse.ok) {
        lockCourse('Could not check enrollment right now. Use the enrollment form, then refresh this page.');
        return null;
      }

      var issues = await issuesResponse.json();
      var issue = issues.find(function (item) {
        return normalizeUsername(item && item.user && item.user.login) === clean;
      });
      if (!issue) {
        lockCourse('@' + clean + ' is a valid GitHub user, but no open enrollment record was found for this course.');
        return null;
      }

      try {
        localStorage.setItem(enrollmentStorageKey(clean), JSON.stringify({
          number: issue.number,
          url: issue.html_url,
          checkedAt: new Date().toISOString(),
        }));
      } catch {}
      setStatus('Enrollment confirmed for @' + clean + ' in issue #' + issue.number + '.', 'success');
      unlockCourse({ number: issue.number, url: issue.html_url });
      return issue;
    }

    function copyText(text, btn) {
      if (!text) return;
      var original = btn ? btn.textContent : '';
      var done = function () {
        if (!btn) return;
        btn.textContent = 'Copied';
        setTimeout(function () { btn.textContent = original; }, 1400);
      };
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(done).catch(function () {});
      } else {
        var scratch = document.createElement('textarea');
        scratch.value = text;
        scratch.setAttribute('readonly', '');
        scratch.style.position = 'fixed';
        scratch.style.opacity = '0';
        document.body.appendChild(scratch);
        scratch.select();
        try { document.execCommand('copy'); done(); } catch {}
        scratch.remove();
      }
    }

    function openActionPanel(key) {
      var action = actions[key];
      if (!action || !actionModal) return;
      if (action.requiresEnrollment && root && root.classList.contains('cp-root--locked')) {
        lockCourse('Enroll and confirm your GitHub username before submitting tests.');
        action = actions.enroll || action;
      }
      activeAction = action;
      if (actionTitle) actionTitle.textContent = action.title;
      if (actionEyebrow) actionEyebrow.textContent = action.eyebrow;
      if (actionSummary) actionSummary.textContent = action.summary;
      setUsernameInputs(currentUsername());
      renderTestComposer(action);
      renderAction(action);
      actionModal.hidden = false;
      document.body.classList.add('cp-action-modal-open');
    }

    function closeActionPanel() {
      if (!actionModal) return;
      actionModal.hidden = true;
      document.body.classList.remove('cp-action-modal-open');
    }

    function applyImageZoom() {
      if (!imageViewerImg) return;
      imageViewerImg.style.transform = 'scale(' + imageZoom + ')';
    }

    function openImageViewer(src, title) {
      if (!imageViewer || !imageViewerImg) return;
      imageZoom = 1;
      imageViewerImg.src = src;
      imageViewerImg.alt = title || 'Course resource image';
      if (imageViewerTitle) imageViewerTitle.textContent = title || 'Image preview';
      applyImageZoom();
      imageViewer.hidden = false;
      document.body.classList.add('cp-image-viewer-open');
    }

    function closeImageViewer() {
      if (!imageViewer) return;
      imageViewer.hidden = true;
      document.body.classList.remove('cp-image-viewer-open');
      if (document.fullscreenElement && document.exitFullscreen) {
        document.exitFullscreen().catch(function () {});
      }
    }

    function updateImageZoom(direction) {
      if (direction === 'reset') imageZoom = 1;
      if (direction === 'in') imageZoom = Math.min(3, Math.round((imageZoom + 0.25) * 100) / 100);
      if (direction === 'out') imageZoom = Math.max(0.5, Math.round((imageZoom - 0.25) * 100) / 100);
      applyImageZoom();
    }

    document.addEventListener('click', function (e) {
      var actionBtn = e.target.closest('[data-course-action]');
      if (actionBtn) {
        openActionPanel(actionBtn.dataset.courseAction);
        return;
      }

      if (e.target.closest('[data-action-close]')) {
        closeActionPanel();
        return;
      }

      var imageOpen = e.target.closest('[data-image-viewer-open]');
      if (imageOpen) {
        openImageViewer(imageOpen.dataset.imageSrc, imageOpen.dataset.imageTitle);
        return;
      }

      var zoomableImage = e.target.closest('[data-zoomable-image]');
      if (zoomableImage) {
        openImageViewer(zoomableImage.currentSrc || zoomableImage.src, zoomableImage.alt);
        return;
      }

      var zoomBtn = e.target.closest('[data-image-zoom]');
      if (zoomBtn) {
        updateImageZoom(zoomBtn.dataset.imageZoom);
        return;
      }

      if (e.target.closest('[data-image-fullscreen]')) {
        if (imageViewerStage && imageViewerStage.requestFullscreen) {
          imageViewerStage.requestFullscreen().catch(function () {});
        }
        return;
      }

      if (e.target.closest('[data-image-viewer-close]')) {
        closeImageViewer();
        return;
      }
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') {
        closeActionPanel();
        closeImageViewer();
      }
    });

    if (copyGh) {
      copyGh.addEventListener('click', function () {
        if (activeAction) copyText(withUsername(activeAction.ghCommand, currentUsername()), copyGh);
      });
    }
    if (copyBody) {
      copyBody.addEventListener('click', function () {
        copyText(actionBody ? actionBody.value : '', copyBody);
      });
    }
    [gateInput, modalInput].forEach(function (input) {
      if (!input) return;
      input.addEventListener('input', function () {
        setUsernameInputs(input.value);
        setStoredUsername(input.value);
        renderAction(activeAction);
      });
    });
    if (checkBtn) {
      checkBtn.addEventListener('click', function () {
        verifyEnrollment(currentUsername()).catch(function () {
          lockCourse('Enrollment check failed. Please try again in a moment.');
        });
      });
    }
    // ── State ──────────────────────────────────────────────────────────────
    var STORAGE_KEY_LESSON   = 'oc-player-lesson-' + (window.location.pathname);
    var STORAGE_KEY_PROGRESS = 'oc-player-done-'   + (window.location.pathname);

    var totalLessons = document.querySelectorAll('[data-lesson]').length;
    var storedUsername = getStoredUsername();
    if (storedUsername) {
      setUsernameInputs(storedUsername);
    } else {
      lockCourse('Enter your GitHub username to unlock the course after enrollment is confirmed.');
    }

    if (!totalLessons) {
      if (storedUsername) verifyEnrollment(storedUsername).catch(function () {});
      return; // fallback page, actions still work
    }

    function getDone() {
      try { return JSON.parse(localStorage.getItem(STORAGE_KEY_PROGRESS) || '[]'); }
      catch { return []; }
    }
    function saveDone(arr) {
      try { localStorage.setItem(STORAGE_KEY_PROGRESS, JSON.stringify(arr)); }
      catch {}
    }
    function getSavedLesson() {
      try { return parseInt(localStorage.getItem(STORAGE_KEY_LESSON) || '0', 10) || 0; }
      catch { return 0; }
    }
    function saveCurrentLesson(idx) {
      try { localStorage.setItem(STORAGE_KEY_LESSON, String(idx)); }
      catch {}
    }
    if (resumeBtn) {
      var savedLesson = getSavedLesson();
      if (savedLesson > 0) resumeBtn.hidden = false;
      resumeBtn.addEventListener('click', function () {
        showLesson(getSavedLesson());
      });
    }

    var done = getDone();
    var currentLesson = 0;

    // ── Update progress bar ────────────────────────────────────────────────
    function updateProgress() {
      var bar   = document.getElementById('cp-progress-bar');
      var label = document.getElementById('cp-progress-label');
      var pct = totalLessons ? Math.round(done.length / totalLessons * 100) : 0;
      if (bar)   bar.style.width = pct + '%';
      if (label) label.textContent = done.length + ' / ' + totalLessons;
      if (sidebarProgressLabel) sidebarProgressLabel.textContent = pct + '%';
    }

    // ── Show a lesson pane ─────────────────────────────────────────────────
    function showLesson(idx) {
      // Hide all panes
      document.querySelectorAll('.cp-pane').forEach(function (pane) {
        pane.hidden = true;
      });
      // Show target pane
      var pane = document.getElementById('cp-pane-' + idx);
      if (!pane) return;
      pane.hidden = false;

      // Activate sidebar button
      document.querySelectorAll('[data-lesson]').forEach(function (btn) {
        btn.classList.toggle('active', parseInt(btn.dataset.lesson, 10) === idx);
      });
      var activeBtn = document.getElementById('cp-lessonbtn-' + idx);
      if (currentObjective && pane.dataset.objective) currentObjective.textContent = pane.dataset.objective;
      document.querySelectorAll('[data-timeline-chapter]').forEach(function (seg) {
        var chapter = activeBtn && activeBtn.closest('[data-ch-lessons]');
        seg.classList.toggle('active', !!chapter && seg.dataset.timelineChapter === chapter.dataset.chLessons);
      });

      // Lazy-load iframe: set src from data-src
      var iframe = pane.querySelector('iframe.cp-video');
      if (iframe && iframe.dataset.src && !iframe.src) {
        iframe.src = iframe.dataset.src;
      }

      // Mark done when navigating away (previous lesson is done)
      if (currentLesson !== idx && done.indexOf(currentLesson) === -1) {
        done.push(currentLesson);
        saveDone(done);
        updateProgress();
      }

      currentLesson = idx;
      saveCurrentLesson(idx);

      // Update check marks
      done.forEach(function (doneIdx) {
        var chk = document.getElementById('cp-check-' + doneIdx);
        if (chk) chk.textContent = '✓';
      });

      // Scroll to top of content
      var content = document.getElementById('cp-content');
      if (content) content.scrollTop = 0;

      // Update URL hash without scrolling
      history.replaceState(null, '', '#lesson-' + idx);
    }

    function initPlayer() {
      if (playerReady || !totalLessons) return;
      playerReady = true;

    // ── Restore lesson from URL hash or localStorage ───────────────────────
    var hashMatch = window.location.hash.match(/^#lesson-(\d+)$/);
    var initLesson = hashMatch ? parseInt(hashMatch[1], 10) : getSavedLesson();
    initLesson = Math.max(0, Math.min(initLesson, totalLessons - 1));

    // Render done checkmarks
    updateProgress();
    done.forEach(function (doneIdx) {
      var chk = document.getElementById('cp-check-' + doneIdx);
      if (chk) chk.textContent = '✓';
    });

    // Show the restored lesson. Lesson panes are SSR-hidden until the player is ready.
    showLesson(initLesson);

    // ── Sidebar lesson click ───────────────────────────────────────────────
    document.addEventListener('click', function (e) {
      var btn = e.target.closest('[data-lesson]');
      if (btn) {
        var idx = parseInt(btn.dataset.lesson, 10);
        showLesson(idx);
        return;
      }

      // Prev / Next navigation buttons inside pane
      var navBtn = e.target.closest('[data-go-lesson]');
      if (navBtn) {
        var toIdx = parseInt(navBtn.dataset.goLesson, 10);
        showLesson(toIdx);
        return;
      }

      // Copy button on code blocks
      var copyBtn = e.target.closest('[data-copy-src]');
      if (copyBtn) {
        var text = copyBtn.dataset.copySrc;
        navigator.clipboard.writeText(text).then(function () {
          var orig = copyBtn.textContent;
          copyBtn.textContent = 'Copied!';
          setTimeout(function () { copyBtn.textContent = orig; }, 1500);
        }).catch(function () {});
        return;
      }
    });

    // ── Chapter accordion toggle ──────────────────────────────────────────
    document.querySelectorAll('[data-ch-toggle]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var ci = btn.dataset.chToggle;
        var lessons = document.querySelector('[data-ch-lessons="' + ci + '"]');
        var chevron = btn.querySelector('.cp-chapter__chevron');
        if (!lessons) return;
        var open = !lessons.hidden;
        lessons.hidden = open;
        if (chevron) chevron.style.transform = open ? 'rotate(0deg)' : 'rotate(90deg)';
      });
    });

    // Open chapter that contains current lesson
    (function () {
      var activeBtn = document.getElementById('cp-lessonbtn-' + initLesson);
      if (!activeBtn) return;
      // Find parent [data-ch-lessons]
      var parent = activeBtn.closest('[data-ch-lessons]');
      if (!parent) return;
      parent.hidden = false;
      var ci = parent.dataset.chLessons;
      var head = document.querySelector('[data-ch-toggle="' + ci + '"]');
      if (head) {
        var chevron = head.querySelector('.cp-chapter__chevron');
        if (chevron) chevron.style.transform = 'rotate(90deg)';
      }
    })();

    // ── Mobile sidebar toggle ─────────────────────────────────────────────
    var sidebarToggle = document.getElementById('cp-sidebar-toggle');
    var sidebar = document.getElementById('cp-sidebar');
    if (sidebarToggle && sidebar) {
      sidebarToggle.addEventListener('click', function () {
        sidebar.classList.toggle('cp-sidebar--open');
      });
    }

    }

    if (storedUsername) {
      try {
        var cached = JSON.parse(localStorage.getItem(enrollmentStorageKey(storedUsername)) || 'null');
        if (cached && cached.number) {
          enrollmentIssue = cached;
          setStatus('Using saved enrollment for @' + normalizeUsername(storedUsername) + ' from issue #' + cached.number + '.', 'success');
          unlockCourse(cached);
        }
      } catch {}
      verifyEnrollment(storedUsername).catch(function () {});
    }

    if (!root || !root.classList.contains('cp-root--locked')) {
      initPlayer();
    }

  })();
  </script>
</Base>

<style>
/* ═══════════════════════════════════════════════════════════════════════════ */
/* COURSE PLAYER LAYOUT                                                        */
/* ═══════════════════════════════════════════════════════════════════════════ */

.cp-root {
  display: flex;
  flex-direction: column;
  height: calc(100vh - 56px);
  overflow: hidden;
}

.cp-root--locked [data-requires-enrollment],
.cp-root--locked .cp-chapter,
.cp-root--locked .cp-final-pill,
.cp-root--locked .cp-topbar__progress,
.cp-root--locked .cp-topbar__progress-label,
.cp-root--locked .cp-infopanel .cp-card:not(.cp-card--public) {
  display: none;
}

.cp-root--locked .cp-sidebar__course-sub::after {
  content: " · enroll to unlock";
  color: #4C1BC9;
}

/* ── Top bar ─────────────────────────────────────────────────────────────── */
.cp-topbar {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 0 1rem;
  height: 48px;
  background: var(--bg-surface);
  border-bottom: 1px solid var(--border-default);
  flex-shrink: 0;
  overflow: hidden;
  position: relative;
}
.cp-topbar__back {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--text-muted);
  text-decoration: none;
  white-space: nowrap;
  flex-shrink: 0;
  transition: color 0.15s;
}
.cp-topbar__back:hover { color: var(--text-primary); }
.cp-topbar__title {
  font-weight: 700;
  font-size: 0.875rem;
  color: var(--text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
}
.cp-topbar__meta {
  display: flex;
  align-items: center;
  gap: 8px;
  flex-shrink: 0;
}
.cp-topbar__duration {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--text-muted);
  flex-shrink: 0;
}
.cp-topbar__progress {
  width: 80px;
  height: 4px;
  background: var(--border-default);
  border-radius: 2px;
  flex-shrink: 0;
  overflow: hidden;
}
.cp-topbar__progress-bar {
  height: 100%;
  background: #34d399;
  border-radius: 2px;
  transition: width 0.3s;
}
.cp-topbar__progress-label {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: var(--text-muted);
  flex-shrink: 0;
}
.cp-resume-btn {
  min-height: 30px;
  padding: 0 0.75rem;
  border: 1px solid color-mix(in srgb, #4C1BC9 36%, var(--border-default));
  border-radius: 8px;
  background: color-mix(in srgb, #4C1BC9 10%, var(--bg-base));
  color: var(--text-primary);
  font-size: 0.75rem;
  font-weight: 800;
}
.cp-resume-btn[hidden] { display: none; }

/* ── Body ────────────────────────────────────────────────────────────────── */
.cp-body {
  display: grid;
  grid-template-columns: 280px 1fr 280px;
  grid-template-areas: "sidebar content infopanel";
  height: calc(100vh - 56px - 48px);
  overflow: hidden;
}
@media (max-width: 1280px) {
  .cp-body {
    grid-template-columns: 260px 1fr;
    grid-template-areas: "sidebar content";
  }
  .cp-infopanel { display: none; }
}
@media (max-width: 800px) {
  .cp-body {
    grid-template-columns: 1fr;
    grid-template-areas: "content";
  }
  .cp-sidebar { display: none; }
  .cp-sidebar-toggle { display: flex; }
}

/* ── Sidebar: chapter/lesson tree ────────────────────────────────────────── */
.cp-sidebar {
  grid-area: sidebar;
  overflow-y: auto;
  scrollbar-width: thin;
  border-right: 1px solid var(--border-default);
  background: var(--bg-surface);
  display: flex;
  flex-direction: column;
}
.cp-sidebar--open {
  display: flex;
  position: fixed;
  top: 104px;
  left: 0;
  width: 280px;
  height: calc(100vh - 104px);
  z-index: 200;
  box-shadow: 4px 0 20px rgba(0,0,0,0.3);
}
.cp-sidebar__inner { padding: 0 0 2rem; flex: 1; }

/* Course info mini card */
.cp-sidebar__course-info {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 1rem;
  border-bottom: 1px solid var(--border-default);
}
.cp-sidebar__course-meta { min-width: 0; }
.cp-sidebar__course-title {
  font-size: 0.8rem;
  font-weight: 700;
  color: var(--text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.cp-sidebar__course-sub {
  font-size: 0.68rem;
  color: var(--text-muted);
  font-family: var(--font-mono);
}
.cp-sidebar-progress {
  display: grid;
  gap: 0.55rem;
  margin: 0.75rem 0 1rem;
  padding: 0.75rem;
  border: 1px solid color-mix(in srgb, #4C1BC9 24%, var(--border-default));
  border-radius: 8px;
  background: color-mix(in srgb, var(--bg-base) 58%, transparent);
}
.cp-sidebar-progress__top {
  display: flex;
  justify-content: space-between;
  gap: 0.6rem;
  color: var(--text-muted);
  font: 0.68rem var(--font-mono);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}
.cp-sidebar-progress__top strong { color: #4C1BC9; }
.cp-timeline {
  display: grid;
  grid-auto-flow: column;
  grid-auto-columns: 1fr;
  gap: 4px;
}
.cp-timeline__seg {
  height: 7px;
  border-radius: 999px;
  background: var(--border-default);
}
.cp-timeline__seg.active { background: #4C1BC9; }
.cp-current-objective {
  margin: 0;
  color: var(--text-secondary);
  font-size: 0.76rem;
  line-height: 1.45;
}

/* Chapter accordion */
.cp-chapter { border-bottom: 1px solid var(--border-default); }
.cp-chapter__head {
  display: flex;
  align-items: center;
  gap: 8px;
  width: 100%;
  padding: 10px 12px;
  background: none;
  border: none;
  cursor: pointer;
  text-align: left;
  color: var(--text-primary);
  transition: background 0.12s;
}
.cp-chapter__head:hover { background: var(--bg-raised); }
.cp-chapter__chevron {
  flex-shrink: 0;
  color: var(--text-muted);
  transform: rotate(90deg);
  transition: transform 0.2s;
}
.cp-chapter__num {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  font-weight: 700;
  color: var(--text-muted);
  flex-shrink: 0;
}
.cp-chapter__title {
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--text-secondary);
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.cp-chapter__count {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: var(--text-muted);
  background: var(--bg-base);
  border: 1px solid var(--border-default);
  border-radius: 10px;
  padding: 1px 6px;
  flex-shrink: 0;
}

/* Lesson buttons */
.cp-chapter__lessons { background: var(--bg-base); }
.cp-lesson-btn {
  display: flex;
  align-items: center;
  gap: 8px;
  width: 100%;
  padding: 8px 12px 8px 20px;
  background: none;
  border: none;
  cursor: pointer;
  text-align: left;
  border-left: 2px solid transparent;
  transition: background 0.1s, border-color 0.1s;
}
.cp-lesson-btn:hover { background: var(--bg-surface); }
.cp-lesson-btn.active {
  background: color-mix(in srgb, #4C1BC9 8%, var(--bg-surface));
  border-left-color: #4C1BC9;
}
.cp-lesson-btn__icon {
  font-size: 0.75rem;
  flex-shrink: 0;
  color: var(--text-muted);
  width: 16px;
  text-align: center;
}
.cp-lesson-btn__title {
  font-size: 0.78rem;
  color: var(--text-secondary);
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  .cp-lesson-btn.active & { color: #4C1BC9; font-weight: 600; }
}
.cp-lesson-btn__dur {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: var(--text-muted);
  flex-shrink: 0;
}
.cp-lesson-btn__check {
  font-size: 0.7rem;
  color: #34d399;
  flex-shrink: 0;
  width: 14px;
  text-align: center;
}

/* Chapter test pill */
.cp-chapter-test-pill {
  display: flex;
  align-items: center;
  gap: 6px;
  width: 100%;
  padding: 6px 20px;
  background: none;
  border: none;
  border-top: 1px solid var(--border-default);
  font-size: 0.7rem;
  color: var(--text-muted);
  font-family: var(--font-mono);
  text-align: left;
  cursor: pointer;
  transition: background 0.15s, color 0.15s;
}
.cp-chapter-test-pill:hover {
  background: color-mix(in srgb, #fb923c 8%, var(--bg-surface));
  color: #fb923c;
}
.cp-chapter-test-pill--assignment:hover {
  background: color-mix(in srgb, #a78bfa 8%, var(--bg-surface));
  color: #a78bfa;
}
.cp-action-cue {
  margin-left: auto;
  color: currentColor;
  opacity: 0.75;
  font-size: 0.62rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}

/* Final test/assignment pills */
.cp-final-pill {
  display: flex;
  align-items: center;
  gap: 6px;
  width: 100%;
  padding: 8px 12px;
  background: none;
  border: none;
  border-top: 1px solid var(--border-default);
  font-size: 0.72rem;
  font-family: var(--font-mono);
  color: var(--text-muted);
  text-align: left;
  cursor: pointer;
  transition: background 0.15s, color 0.15s;
}
.cp-final-pill:hover { background: var(--bg-surface); }
.cp-final-pill--test  { color: #fb923c; }
.cp-final-pill--assign { color: #a78bfa; }
.cp-final-pill--assign {
  cursor: default;
}

/* Enroll button in sidebar */
.cp-enroll-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  margin: 1rem;
  padding: 10px 14px;
  background: #4C1BC9;
  border: 0;
  color: #fff;
  border-radius: 8px;
  text-decoration: none;
  font-size: 0.8rem;
  font-weight: 700;
  cursor: pointer;
  transition: background 0.15s;
}
.cp-enroll-btn:hover { background: #4C1BC9; }
.cp-enroll-btn--full { justify-content: center; width: 100%; box-sizing: border-box; }

.cp-action-card {
  border-color: color-mix(in srgb, #4C1BC9 35%, var(--border-default));
}
.cp-action-list {
  display: grid;
  gap: 8px;
}
.cp-fallback-actions {
  display: grid;
  gap: 10px;
}
.cp-action-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  width: 100%;
  padding: 10px;
  background: var(--bg-base);
  border: 1px solid var(--border-default);
  border-radius: 8px;
  color: var(--text-primary);
  text-align: left;
  cursor: pointer;
  transition: border-color 0.15s, background 0.15s, transform 0.15s;
}
.cp-action-row:hover {
  background: color-mix(in srgb, #4C1BC9 7%, var(--bg-surface));
  border-color: color-mix(in srgb, #4C1BC9 45%, var(--border-default));
  transform: translateX(2px);
}
.cp-action-row strong {
  display: block;
  font-size: 0.82rem;
}
.cp-action-row small {
  display: block;
  margin-top: 2px;
  color: var(--text-muted);
  font-size: 0.68rem;
}

.cp-action-modal[hidden] { display: none; }
.cp-action-modal {
  position: fixed;
  inset: 0;
  z-index: 900;
  display: grid;
  place-items: center;
  padding: 1rem;
}
.cp-action-modal__backdrop {
  position: absolute;
  inset: 0;
  background: rgba(2, 6, 23, 0.74);
  backdrop-filter: blur(8px);
}
.cp-action-modal__dialog {
  position: relative;
  z-index: 1;
  width: min(680px, 100%);
  max-height: min(780px, calc(100vh - 2rem));
  overflow: auto;
  background: var(--bg-surface);
  border: 1px solid color-mix(in srgb, #4C1BC9 28%, var(--border-default));
  border-radius: 10px;
  box-shadow: 0 24px 80px rgba(0,0,0,0.42);
  padding: 1.25rem;
}
.cp-action-modal__close {
  position: absolute;
  top: 12px;
  right: 12px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 34px;
  height: 34px;
  border-radius: 8px;
  border: 1px solid var(--border-default);
  background: var(--bg-base);
  color: var(--text-muted);
  cursor: pointer;
}
.cp-action-modal__eyebrow {
  padding-right: 44px;
  font-family: var(--font-mono);
  font-size: 0.7rem;
  color: #7C3AED;
  word-break: break-word;
}
.cp-action-modal__title {
  margin: 0.25rem 44px 0.35rem 0;
  font-size: 1.25rem;
  letter-spacing: 0;
}
.cp-action-modal__summary {
  margin: 0 0 1rem;
  color: var(--text-secondary);
  font-size: 0.9rem;
}
.cp-action-modal__options {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 1rem;
}
.cp-action-choice {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-height: 36px;
  padding: 0 12px;
  background: var(--bg-base);
  border: 1px solid var(--border-default);
  border-radius: 8px;
  color: var(--text-primary);
  text-decoration: none;
  font-weight: 700;
  font-size: 0.8rem;
  cursor: pointer;
}
.cp-action-choice--primary {
  background: #4C1BC9;
  border-color: #4C1BC9;
  color: #041014;
}
.cp-action-codeblock {
  margin: 0 0 0.9rem;
  border: 1px solid var(--border-default);
  border-radius: 8px;
  overflow: hidden;
  background: var(--bg-base);
}
.cp-action-codeblock__label,
.cp-action-body-label {
  display: block;
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
.cp-action-codeblock__label {
  padding: 8px 10px;
  border-bottom: 1px solid var(--border-default);
}
.cp-action-codeblock pre {
  margin: 0;
  padding: 10px;
  white-space: pre-wrap;
  word-break: break-word;
  color: var(--text-secondary);
  font-size: 0.78rem;
}
.cp-action-body-label { margin-bottom: 6px; }
.cp-action-body {
  width: 100%;
  min-height: 220px;
  box-sizing: border-box;
  resize: vertical;
  padding: 10px;
  background: var(--bg-base);
  border: 1px solid var(--border-default);
  border-radius: 8px;
  color: var(--text-secondary);
  font: 0.78rem/1.55 var(--font-mono);
}
body.cp-action-modal-open { overflow: hidden; }
body.cp-image-viewer-open { overflow: hidden; }

.cp-test-composer {
  margin: 0 0 1rem;
  border: 1px solid color-mix(in srgb, #7C3AED 30%, var(--border-default));
  border-radius: 8px;
  overflow: hidden;
  background: var(--bg-base);
}
.cp-test-composer__head {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  padding: 0.9rem 1rem;
  border-bottom: 1px solid var(--border-default);
  background: color-mix(in srgb, #7C3AED 6%, var(--bg-surface));
}
.cp-test-composer__eyebrow {
  display: block;
  margin-bottom: 0.25rem;
  color: #7C3AED;
  font: 0.68rem var(--font-mono);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
.cp-test-composer__head h3 {
  margin: 0;
  font-size: 1rem;
  letter-spacing: 0;
}
.cp-test-composer__meta {
  align-self: start;
  color: var(--text-muted);
  font: 0.68rem var(--font-mono);
  white-space: nowrap;
}
.cp-test-composer__questions {
  display: grid;
  gap: 1rem;
  padding: 1rem;
}
.cp-test-section {
  display: grid;
  gap: 0.75rem;
}
.cp-test-section__title {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  color: var(--text-secondary);
  font-weight: 800;
  font-size: 0.85rem;
}
.cp-test-section__title span {
  color: var(--text-muted);
  font: 0.7rem var(--font-mono);
}
.cp-test-question {
  padding: 0.9rem;
  border: 1px solid var(--border-default);
  border-radius: 8px;
  background: var(--bg-surface);
}
.cp-test-question__top {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 0.55rem;
  color: var(--text-muted);
  font: 0.68rem var(--font-mono);
}
.cp-test-question__top span {
  color: #4C1BC9;
  font-weight: 800;
}
.cp-test-question__top code {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
}
.cp-test-question__prompt {
  margin: 0 0 0.75rem;
  color: var(--text-secondary);
  line-height: 1.55;
  font-size: 0.88rem;
}
.cp-test-question__code {
  margin: 0 0 0.75rem;
  max-height: 260px;
  overflow: auto;
  border-radius: 8px;
  background: #050b0c;
}
.cp-test-question__code code {
  display: block;
  padding: 0.85rem;
  font: 0.76rem/1.5 var(--font-mono);
}
.cp-test-question__options {
  display: grid;
  gap: 0.45rem;
}
.cp-test-option {
  display: flex;
  gap: 9px;
  align-items: flex-start;
  padding: 0.65rem;
  border: 1px solid var(--border-default);
  border-radius: 8px;
  background: var(--bg-base);
  color: var(--text-secondary);
  font-size: 0.82rem;
  line-height: 1.45;
}
.cp-test-option input {
  margin-top: 0.18rem;
  accent-color: #4C1BC9;
}
.cp-test-answer {
  width: 100%;
  box-sizing: border-box;
  min-height: 118px;
  resize: vertical;
  padding: 0.8rem;
  border: 1px solid var(--border-default);
  border-radius: 8px;
  background: var(--bg-base);
  color: var(--text-secondary);
  font: 0.82rem/1.55 var(--font-mono);
}
.cp-assignment-brief {
  white-space: pre-wrap;
  padding: 0.9rem;
  border: 1px solid var(--border-default);
  border-radius: 8px;
  background: var(--bg-surface);
  color: var(--text-secondary);
  font-size: 0.84rem;
  line-height: 1.65;
}
.cp-assignment-rubric {
  display: grid;
  gap: 0.45rem;
}
.cp-assignment-rubric h4 {
  margin: 0 0 0.15rem;
  color: var(--text-muted);
  font: 0.72rem var(--font-mono);
  text-transform: uppercase;
  letter-spacing: 0.07em;
}
.cp-assignment-rubric div {
  display: flex;
  justify-content: space-between;
  gap: 0.8rem;
  padding: 0.65rem;
  border: 1px solid var(--border-default);
  border-radius: 8px;
  background: var(--bg-surface);
  color: var(--text-secondary);
  font-size: 0.8rem;
  line-height: 1.45;
}
.cp-assignment-rubric strong {
  flex-shrink: 0;
  color: #7C3AED;
  font: 0.7rem var(--font-mono);
}

.cp-image-viewer[hidden] { display: none; }
.cp-image-viewer {
  position: fixed;
  inset: 0;
  z-index: 950;
  display: grid;
  place-items: center;
  padding: 1rem;
}
.cp-image-viewer__backdrop {
  position: absolute;
  inset: 0;
  background: rgba(2, 6, 23, 0.82);
  backdrop-filter: blur(10px);
}
.cp-image-viewer__dialog {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-rows: auto minmax(0, 1fr);
  width: min(1180px, calc(100vw - 2rem));
  height: min(820px, calc(100vh - 2rem));
  overflow: hidden;
  border: 1px solid color-mix(in srgb, #4C1BC9 28%, var(--border-default));
  border-radius: 8px;
  background: var(--bg-base);
  box-shadow: 0 32px 90px rgba(0,0,0,0.5);
}
.cp-image-viewer__bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  padding: 0.75rem;
  border-bottom: 1px solid var(--border-default);
  background: color-mix(in srgb, var(--bg-surface) 88%, transparent);
}
.cp-image-viewer__bar h2 {
  min-width: 0;
  margin: 0;
  overflow: hidden;
  color: var(--text-primary);
  font-size: 0.95rem;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.cp-image-viewer__actions {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  flex-shrink: 0;
}
.cp-image-viewer__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 36px;
  height: 34px;
  padding: 0 0.65rem;
  border: 1px solid var(--border-default);
  border-radius: 8px;
  background: var(--bg-base);
  color: var(--text-secondary);
  font-size: 0.78rem;
  font-weight: 800;
}
.cp-image-viewer__btn:hover {
  border-color: color-mix(in srgb, #4C1BC9 45%, var(--border-default));
  color: var(--text-primary);
}
.cp-image-viewer__stage {
  display: grid;
  place-items: center;
  min-height: 0;
  overflow: auto;
  padding: 1rem;
  background:
    linear-gradient(45deg, color-mix(in srgb, var(--bg-surface) 65%, transparent) 25%, transparent 25%),
    linear-gradient(-45deg, color-mix(in srgb, var(--bg-surface) 65%, transparent) 25%, transparent 25%),
    var(--bg-base);
  background-size: 24px 24px;
}
.cp-image-viewer__stage:fullscreen {
  background: #05080a;
}
.cp-image-viewer__stage img {
  max-width: 100%;
  max-height: 100%;
  transform-origin: center center;
  transition: transform 160ms ease;
  border-radius: 4px;
  box-shadow: 0 18px 60px rgba(0,0,0,0.35);
}

/* Sidebar toggle (mobile) */
.cp-sidebar-toggle {
  display: none;
  position: fixed;
  bottom: 1.5rem;
  left: 1.5rem;
  z-index: 300;
  background: var(--bg-surface);
  border: 1px solid var(--border-default);
  border-radius: 50%;
  width: 44px;
  height: 44px;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  box-shadow: 0 2px 12px rgba(0,0,0,0.25);
  color: var(--text-secondary);
}

/* ── Main content: lesson panes ──────────────────────────────────────────── */
.cp-content {
  grid-area: content;
  overflow-y: auto;
  scrollbar-width: thin;
  background: var(--bg-base);
}

/* Pane */
.cp-pane {
  max-width: 880px;
  margin: 0 auto;
  padding: 0 2rem 4rem;
}
@media (max-width: 600px) { .cp-pane { padding: 0 1rem 3rem; } }

.cp-enrollment-gate {
  display: grid;
  align-content: start;
  gap: 1rem;
  padding-top: 2rem;
}
.cp-gate-hero {
  display: grid;
  grid-template-columns: 112px 1fr;
  gap: 1.25rem;
  align-items: center;
  padding-bottom: 1.5rem;
  border-bottom: 1px solid var(--border-default);
}
.cp-course-abstract {
  position: relative;
  display: grid;
  place-items: center;
  overflow: hidden;
  flex-shrink: 0;
  border: 1px solid color-mix(in srgb, var(--course-primary) 36%, var(--border-default));
  border-radius: 8px;
  background:
    radial-gradient(circle at 22% 20%, color-mix(in srgb, var(--course-secondary) 34%, transparent), transparent 32%),
    linear-gradient(135deg, color-mix(in srgb, var(--course-primary) 28%, transparent), transparent 54%),
    color-mix(in srgb, var(--bg-surface) 88%, transparent);
}
.cp-course-abstract::before {
  content: "";
  position: absolute;
  inset: 18%;
  background:
    linear-gradient(90deg, transparent 0 12px, color-mix(in srgb, var(--text-primary) 16%, transparent) 12px 13px, transparent 13px 24px),
    linear-gradient(180deg, color-mix(in srgb, var(--course-primary) 28%, transparent), color-mix(in srgb, var(--course-secondary) 18%, transparent));
  background-size: 24px 100%, 100% 100%;
  transform: skewX(-12deg);
  opacity: 0.8;
}
.cp-course-abstract span {
  position: relative;
  z-index: 1;
  display: inline-grid;
  place-items: center;
  width: 42%;
  aspect-ratio: 1.25;
  border: 1px solid color-mix(in srgb, var(--course-primary) 44%, var(--border-default));
  border-radius: 8px;
  background: color-mix(in srgb, var(--bg-base) 78%, transparent);
  color: var(--text-primary);
  font-family: var(--font-display);
  font-weight: 900;
  letter-spacing: 0;
}
.cp-course-abstract--mini {
  width: 48px;
  height: 36px;
}
.cp-course-abstract--hero {
  width: 112px;
  aspect-ratio: 1;
}
.cp-gate-hero__eyebrow {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: #7C3AED;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
.cp-gate-hero__title {
  margin: 0.35rem 0 0.5rem;
  font-size: clamp(1.6rem, 4vw, 2.45rem);
  line-height: 1.05;
  letter-spacing: 0;
}
.cp-gate-hero__desc {
  margin: 0;
  color: var(--text-secondary);
  line-height: 1.65;
}
.cp-gate-hero__meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.55rem;
  margin-top: 0.9rem;
  color: var(--text-muted);
  font: 0.75rem var(--font-mono);
}
.cp-enrollment-check {
  padding: 1rem;
  background: var(--bg-surface);
  border: 1px solid color-mix(in srgb, #4C1BC9 28%, var(--border-default));
  border-radius: 8px;
}
.cp-enrollment-check__label {
  display: block;
  margin-bottom: 0.45rem;
  color: var(--text-muted);
  font: 0.72rem var(--font-mono);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
.cp-enrollment-check__row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}
.cp-enrollment-check__input,
.cp-action-username {
  min-height: 36px;
  box-sizing: border-box;
  padding: 0 10px;
  background: var(--bg-base);
  border: 1px solid var(--border-default);
  border-radius: 8px;
  color: var(--text-primary);
  font: 0.82rem var(--font-mono);
}
.cp-enrollment-check__input {
  flex: 1 1 220px;
}
.cp-action-username {
  width: 100%;
  margin-bottom: 0.4rem;
}
.cp-enrollment-check__status,
.cp-action-modal__hint {
  margin: 0.65rem 0 0;
  color: var(--text-muted);
  font-size: 0.78rem;
  line-height: 1.5;
}
.cp-enrollment-check__status[data-tone="success"] { color: #34d399; }
.cp-enrollment-check__status[data-tone="loading"] { color: #4C1BC9; }
@media (max-width: 680px) {
  .cp-gate-hero { grid-template-columns: 1fr; }
  .cp-course-abstract--hero { width: 88px; }
}

.cp-pane__header {
  padding: 2rem 0 1.25rem;
  border-bottom: 1px solid color-mix(in srgb, #4C1BC9 18%, var(--border-default));
  margin-bottom: 1.5rem;
}
.cp-pane__breadcrumb {
  display: flex;
  align-items: center;
  gap: 6px;
  font-family: var(--font-mono);
  font-size: 0.7rem;
  color: var(--text-muted);
  margin-bottom: 0.75rem;
}
.cp-pane__ch-name { color: var(--text-muted); }
.cp-pane__lesson-type {
  background: var(--bg-surface);
  border: 1px solid var(--border-default);
  border-radius: 3px;
  padding: 1px 6px;
  color: var(--text-muted);
}
.cp-pane__title {
  font-size: 1.6rem;
  font-weight: 800;
  color: var(--text-primary);
  margin: 0 0 0.5rem;
  letter-spacing: -0.02em;
}
.cp-pane__desc {
  font-size: 0.9rem;
  color: var(--text-secondary);
  margin: 0 0 0.5rem;
  line-height: 1.6;
}
.cp-pane__dur {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--text-muted);
}
.cp-objective {
  display: grid;
  gap: 0.25rem;
  margin-top: 1rem;
  padding: 0.8rem;
  border: 1px solid color-mix(in srgb, #4C1BC9 24%, var(--border-default));
  border-radius: 8px;
  background: color-mix(in srgb, #4C1BC9 7%, var(--bg-surface));
}
.cp-objective span {
  color: #4C1BC9;
  font: 0.68rem var(--font-mono);
  text-transform: uppercase;
  letter-spacing: 0.07em;
}
.cp-objective strong {
  color: var(--text-primary);
  font-size: 0.9rem;
  line-height: 1.45;
}

/* Video */
.cp-learning-stage {
  margin-bottom: 1.15rem;
  border: 1px solid color-mix(in srgb, #4C1BC9 26%, var(--border-default));
  border-radius: 8px;
  overflow: hidden;
  background: var(--bg-surface);
  box-shadow: 0 10px 30px rgba(0,0,0,0.08);
}
.cp-learning-stage__bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  padding: 0.62rem 0.8rem;
  border-bottom: 1px solid var(--border-default);
  background:
    linear-gradient(90deg, color-mix(in srgb, #4C1BC9 12%, var(--bg-surface)), var(--bg-surface));
}
.cp-learning-stage__label {
  display: inline-flex;
  align-items: center;
  min-height: 22px;
  padding: 0 8px;
  border-radius: 6px;
  background: color-mix(in srgb, #4C1BC9 12%, var(--bg-base));
  color: #4C1BC9;
  font: 0.64rem var(--font-mono);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
.cp-learning-stage__source {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: var(--text-secondary);
  font-size: 0.78rem;
  font-weight: 700;
}
.cp-video-wrap {
  position: relative;
  padding-top: 56.25%; /* 16:9 */
  background:
    linear-gradient(135deg, color-mix(in srgb, #4C1BC9 10%, transparent), transparent 38%),
    var(--bg-surface);
  border: 1px solid var(--border-default);
  border-radius: 0;
  overflow: hidden;
  margin-bottom: 0;
}
.cp-video {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 100%;
  border: none;
}
.cp-video-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12px;
  padding: 0.62rem 0.8rem;
  border-top: 1px solid var(--border-default);
  font-size: 0.78rem;
}
.cp-video-meta__link {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  color: #4C1BC9;
  text-decoration: none;
}
.cp-video-meta__link:hover { text-decoration: underline; }
.cp-video-meta__channel, .cp-video-meta__subs { color: var(--text-muted); }
.cp-watch-plan {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 0.75rem;
  align-items: start;
  padding: 0.7rem 0.8rem;
  border-top: 1px solid var(--border-default);
  background: color-mix(in srgb, #7C3AED 5%, var(--bg-base));
}
.cp-watch-plan strong {
  color: #7C3AED;
  font: 0.68rem var(--font-mono);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
.cp-watch-plan ul {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
  margin: 0;
  padding: 0;
  list-style: none;
}
.cp-watch-plan li {
  padding: 0.28rem 0.5rem;
  border: 1px solid var(--border-default);
  border-radius: 999px;
  color: var(--text-secondary);
  background: var(--bg-surface);
  font-size: 0.75rem;
}

/* Timestamps */
.cp-timestamps {
  background: var(--bg-surface);
  border: 1px solid var(--border-default);
  border-radius: 8px;
  padding: 0.75rem 1rem;
  margin-bottom: 1.5rem;
}
.cp-timestamps__title {
  font-size: 0.72rem;
  font-weight: 700;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  font-family: var(--font-mono);
  margin-bottom: 0.5rem;
}
.cp-timestamps__list { display: flex; flex-direction: column; gap: 4px; }
.cp-timestamp { display: flex; align-items: center; gap: 10px; }
.cp-timestamp__time {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  color: #4C1BC9;
  min-width: 48px;
}
.cp-timestamp__label { font-size: 0.82rem; color: var(--text-secondary); }

/* Reading */
.cp-reading {
  background: var(--bg-surface);
  border: 1px solid color-mix(in srgb, #7C3AED 18%, var(--border-default));
  border-radius: 8px;
  padding: 1rem 1.25rem;
  margin-bottom: 1.5rem;
}
.cp-reading--with-player {
  margin-top: -0.25rem;
}
.cp-reading__source {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}
.cp-reading__link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  color: #4C1BC9;
  font-weight: 600;
  font-size: 0.9rem;
  text-decoration: none;
}
.cp-reading__link:hover { text-decoration: underline; }
.cp-reading__est { font-size: 0.78rem; color: var(--text-muted); font-family: var(--font-mono); }
.cp-reading__sections { margin-top: 0.75rem; font-size: 0.85rem; color: var(--text-secondary); }
.cp-reading__sections ul { margin: 0.3rem 0 0 1.2rem; padding: 0; }
.cp-reading__sections li { margin-bottom: 0.2rem; }

/* Curator notes */
.cp-notes {
  background: var(--bg-surface);
  border: 1px solid var(--border-default);
  border-radius: 8px;
  overflow: hidden;
  margin-bottom: 1.2rem;
}
.cp-notes__label {
  display: flex;
  align-items: center;
  gap: 7px;
  padding: 0.55rem 0.85rem;
  background: color-mix(in srgb, #7C3AED 7%, var(--bg-raised));
  border-bottom: 1px solid var(--border-default);
  font-size: 0.72rem;
  font-weight: 700;
  color: #7C3AED;
  font-family: var(--font-mono);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.cp-notes__body {
  padding: 0.9rem 1rem;
  font-size: 0.88rem;
  color: var(--text-secondary);
  line-height: 1.7;
  word-break: break-word;
}
.cp-notes__body p {
  margin: 0 0 1rem;
}
.cp-notes__body p:last-child {
  margin-bottom: 0;
}
.cp-notes__body h2,
.cp-notes__body h3 {
  margin: 1.1rem 0 0.55rem;
  color: var(--text-primary);
  letter-spacing: 0;
}
.cp-notes__body h2 {
  font-size: 1.05rem;
}
.cp-notes__body h3 {
  font-size: 0.92rem;
}
.cp-notes__body code {
  padding: 1px 5px;
  border-radius: 4px;
  background: var(--bg-base);
  border: 1px solid var(--border-default);
  color: #4C1BC9;
  font-family: var(--font-mono);
  font-size: 0.86em;
}
.cp-rich-bullet {
  position: relative;
  padding-left: 1rem;
  margin: 0.28rem 0;
}
.cp-rich-bullet::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0.72em;
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: #7C3AED;
}
.cp-rich-code {
  margin: 0.8rem 0;
  overflow: auto;
  border-radius: 8px;
  background: #050b0c;
}
.cp-rich-code code {
  display: block;
  padding: 0.9rem;
  border: 0;
  color: #dbeafe;
  background: transparent;
}
.cp-rich-list {
  margin: 0 0 1rem;
  padding-left: 1.2rem;
  color: var(--text-secondary);
}
.cp-rich-list li {
  margin: 0.28rem 0;
}
.cp-rich-table-wrap {
  width: 100%;
  margin: 0.9rem 0 1.2rem;
  overflow-x: auto;
  border: 1px solid var(--border-default);
  border-radius: 8px;
}
.cp-rich-table {
  width: 100%;
  min-width: 520px;
  border-collapse: collapse;
  background: color-mix(in srgb, var(--bg-base) 70%, transparent);
}
.cp-rich-table th,
.cp-rich-table td {
  padding: 0.7rem 0.85rem;
  border-bottom: 1px solid var(--border-default);
  border-right: 1px solid var(--border-default);
  text-align: left;
  vertical-align: top;
}
.cp-rich-table th:last-child,
.cp-rich-table td:last-child {
  border-right: 0;
}
.cp-rich-table tr:last-child td {
  border-bottom: 0;
}
.cp-rich-table th {
  color: var(--text-primary);
  background: color-mix(in srgb, #4C1BC9 8%, var(--bg-surface));
  font-weight: 800;
}
.cp-rich-table td {
  color: var(--text-secondary);
}

/* Native lesson resources */
.cp-resources {
  margin: 0 0 1.5rem;
}
.cp-resources__header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 1rem;
  margin-bottom: 0.7rem;
}
.cp-resources__header span {
  font-size: 0.72rem;
  font-weight: 800;
  color: var(--text-muted);
  font-family: var(--font-mono);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.cp-resources__header small {
  color: var(--text-muted);
  font: 0.68rem var(--font-mono);
}
.cp-resource-grid {
  display: grid;
  gap: 1rem;
}
.cp-resource-card {
  position: relative;
  background: var(--bg-surface);
  border: 1px solid var(--border-default);
  border-radius: 8px;
  overflow: hidden;
}
.cp-resource-card__media {
  position: relative;
  min-height: 180px;
  background:
    radial-gradient(circle at 12% 10%, color-mix(in srgb, #4C1BC9 12%, transparent), transparent 28%),
    color-mix(in srgb, var(--bg-surface) 78%, #0a1e1e);
}
.cp-resource-card__img,
.cp-resource-card__video,
.cp-resource-card__frame {
  display: block;
  width: 100%;
  border: 0;
}
.cp-resource-card__img {
  max-height: 620px;
  object-fit: contain;
  background: color-mix(in srgb, var(--bg-base) 88%, #4C1BC9);
  cursor: zoom-in;
}
.cp-resource-card__video,
.cp-resource-card__frame {
  aspect-ratio: 16 / 9;
  height: auto;
  background: var(--bg-base);
}
.cp-resource-card__placeholder {
  display: grid;
  place-items: center;
  min-height: 180px;
}
.cp-resource-card__placeholder span {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 76px;
  min-height: 34px;
  padding: 0 12px;
  border: 1px solid color-mix(in srgb, #4C1BC9 42%, var(--border-default));
  border-radius: 8px;
  color: #4C1BC9;
  background: color-mix(in srgb, #4C1BC9 8%, var(--bg-base));
  font: 0.72rem var(--font-mono);
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
.cp-resource-card__body {
  display: flex;
  justify-content: space-between;
  gap: 1rem;
  padding: 0.8rem 1rem;
  border-top: 1px solid var(--border-default);
}
.cp-resource-card__body h3 {
  margin: 0 0 0.2rem;
  color: var(--text-secondary);
  font-size: 0.85rem;
}
.cp-resource-card__body p {
  margin: 0;
  color: var(--text-muted);
  font: 0.7rem/1.45 var(--font-mono);
  word-break: break-word;
}
.cp-resource-card__open {
  align-self: center;
  flex-shrink: 0;
  color: #4C1BC9;
  text-decoration: none;
  font: 0.72rem var(--font-mono);
}
.cp-resource-card__zoom {
  position: absolute;
  top: 12px;
  right: 12px;
  display: inline-grid;
  place-items: center;
  width: 34px;
  height: 34px;
  border: 1px solid color-mix(in srgb, #4C1BC9 40%, var(--border-default));
  border-radius: 8px;
  background: color-mix(in srgb, var(--bg-base) 72%, transparent);
  color: #4C1BC9;
  backdrop-filter: blur(12px);
  box-shadow: 0 10px 26px rgba(0,0,0,0.18);
}
.cp-resource-card__zoom:hover {
  background: color-mix(in srgb, #4C1BC9 16%, var(--bg-base));
}
.cp-resource-card__required {
  position: absolute;
  top: 10px;
  right: 10px;
  padding: 3px 7px;
  border-radius: 6px;
  background: color-mix(in srgb, #fb923c 16%, var(--bg-base));
  border: 1px solid color-mix(in srgb, #fb923c 38%, var(--border-default));
  color: #fb923c;
  font: 0.65rem var(--font-mono);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}
.cp-resource-card--image .cp-resource-card__media {
  min-height: 0;
}

/* Code blocks */
.cp-code-section { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 1.5rem; }
.cp-code-block {
  background: var(--bg-surface);
  border: 1px solid var(--border-default);
  border-radius: 8px;
  overflow: hidden;
}
.cp-code-block__bar {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 7px 12px;
  background: var(--bg-raised);
  border-bottom: 1px solid var(--border-default);
}
.cp-code-block__dots { display: flex; gap: 5px; }
.cp-code-block__dots span {
  width: 10px; height: 10px; border-radius: 50%;
}
.cp-code-block__dots span:nth-child(1) { background: #ef4444; opacity: 0.7; }
.cp-code-block__dots span:nth-child(2) { background: #f59e0b; opacity: 0.7; }
.cp-code-block__dots span:nth-child(3) { background: #22c55e; opacity: 0.7; }
.cp-code-block__title {
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--text-secondary);
  flex: 1;
}
.cp-code-block__lang {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.06em;
}
.cp-code-block__copy {
  font-size: 0.7rem;
  padding: 2px 8px;
  background: var(--bg-base);
  border: 1px solid var(--border-default);
  border-radius: 4px;
  cursor: pointer;
  color: var(--text-muted);
  transition: color 0.15s;
}
.cp-code-block__copy:hover { color: var(--text-primary); }
.cp-code-block__pre {
  margin: 0;
  overflow-x: auto;
  font-size: 0.83rem;
  line-height: 1.5;
}
.cp-code-block__pre code {
  display: block;
  padding: 1rem 1.25rem;
  font-family: var(--font-mono);
}
.cp-code-block__explain {
  padding: 0.75rem 1.25rem;
  font-size: 0.83rem;
  color: var(--text-secondary);
  border-top: 1px solid var(--border-default);
  line-height: 1.6;
}
.cp-code-block__output {
  padding: 0.75rem 1.25rem;
  border-top: 1px solid var(--border-default);
  background: var(--bg-base);
}
.cp-code-block__output-label {
  display: block;
  font-size: 0.68rem;
  font-family: var(--font-mono);
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 0.4rem;
}
.cp-code-block__output pre {
  margin: 0;
  font-family: var(--font-mono);
  font-size: 0.8rem;
  color: #34d399;
}

/* Exercise */
.cp-exercise {
  background: var(--bg-surface);
  border: 1px solid var(--border-default);
  border-radius: 8px;
  overflow: hidden;
  margin-bottom: 1.5rem;
}
.cp-exercise__header {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 0.75rem 1.25rem;
  background: color-mix(in srgb, #a78bfa 8%, var(--bg-raised));
  border-bottom: 1px solid var(--border-default);
  font-size: 0.85rem;
  font-weight: 700;
  color: #a78bfa;
}
.cp-exercise__body {
  padding: 1rem 1.25rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}
.cp-exercise__repo {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 8px 14px;
  background: var(--bg-raised);
  border: 1px solid var(--border-default);
  border-radius: 6px;
  text-decoration: none;
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--text-primary);
  transition: border-color 0.15s;
}
.cp-exercise__repo:hover { border-color: #4C1BC9; }
.cp-exercise__cmd { display: flex; align-items: center; gap: 8px; font-size: 0.82rem; color: var(--text-muted); }
.cp-exercise__cmd code {
  font-family: var(--font-mono);
  font-size: 0.8rem;
  padding: 3px 8px;
  background: var(--bg-base);
  border-radius: 4px;
  color: #34d399;
}
.cp-exercise__submit { font-size: 0.8rem; color: var(--text-muted); }

/* Hints */
.cp-hints { border-top: 1px solid var(--border-default); }
.cp-hints__toggle {
  padding: 0.6rem 1.25rem;
  font-size: 0.8rem;
  color: var(--text-muted);
  cursor: pointer;
  list-style: none;
}
.cp-hints__list { padding: 0 1.25rem 1rem; display: flex; flex-direction: column; gap: 0.75rem; }
.cp-hint { font-size: 0.82rem; color: var(--text-secondary); }
.cp-hint__level { font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-muted); display: block; margin-bottom: 2px; }
.cp-hint p { margin: 0; }

/* Links */
.cp-links {
  background: var(--bg-surface);
  border: 1px solid var(--border-default);
  border-radius: 8px;
  overflow: hidden;
  margin-bottom: 1rem;
}
.cp-links__title {
  padding: 0.6rem 1rem;
  font-size: 0.72rem;
  font-weight: 700;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  font-family: var(--font-mono);
  background: var(--bg-raised);
  border-bottom: 1px solid var(--border-default);
}
.cp-links__list { list-style: none; padding: 0; margin: 0; }
.cp-link-item {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 6px;
  padding: 0;
  border-bottom: 1px solid var(--border-default);
}
.cp-link-item:last-child { border-bottom: none; }
.cp-link-item__a {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 12px;
  flex: 1;
  text-decoration: none;
  transition: background 0.12s;
}
.cp-link-item__a:hover { background: var(--bg-raised); }
.cp-link-item__label {
  font-size: 0.83rem;
  color: var(--text-secondary);
  font-weight: 500;
}
.cp-link-item__type {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: var(--text-muted);
  background: var(--bg-base);
  border: 1px solid var(--border-default);
  border-radius: 3px;
  padding: 1px 5px;
}
.cp-link-item__req {
  font-size: 0.65rem;
  color: #fb923c;
  font-family: var(--font-mono);
  padding-right: 8px;
}
.cp-link-item__note { font-size: 0.75rem; color: var(--text-muted); padding: 0 8px 6px; width: 100%; }

/* Pane prev/next nav */
.cp-pane__nav {
  display: flex;
  gap: 1rem;
  margin-top: 3rem;
  padding-top: 1.5rem;
  border-top: 1px solid var(--border-default);
}
.cp-pane__nav-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 10px 16px;
  background: var(--bg-surface);
  border: 1px solid var(--border-default);
  border-radius: 8px;
  cursor: pointer;
  font-size: 0.83rem;
  color: var(--text-secondary);
  font-weight: 500;
  transition: border-color 0.15s, color 0.15s;
  max-width: 220px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.cp-pane__nav-btn:hover { border-color: #4C1BC9; color: #4C1BC9; }
.cp-pane__nav-btn--next { margin-left: auto; }

/* ── Right info panel ────────────────────────────────────────────────────── */
.cp-infopanel {
  grid-area: infopanel;
  overflow-y: auto;
  scrollbar-width: thin;
  border-left: 1px solid var(--border-default);
  background: var(--bg-surface);
  padding: 1rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.cp-card {
  background: var(--bg-base);
  border: 1px solid var(--border-default);
  border-radius: 8px;
  padding: 0.875rem 1rem;
}
.cp-card--cert { border-color: color-mix(in srgb, #fb923c 30%, transparent); }
.cp-card__title {
  font-size: 0.72rem;
  font-weight: 700;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  font-family: var(--font-mono);
  margin-bottom: 0.6rem;
}
.cp-card__text { font-size: 0.82rem; color: var(--text-secondary); line-height: 1.6; margin: 0 0 0.5rem; }
.cp-card__pills { display: flex; flex-wrap: wrap; gap: 4px; }
.cp-tag {
  font-size: 0.68rem;
  padding: 2px 7px;
  background: var(--bg-raised);
  border: 1px solid var(--border-default);
  border-radius: 4px;
  color: var(--text-muted);
  font-family: var(--font-mono);
}

.cp-skills { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 5px; }
.cp-skill {
  display: flex;
  align-items: flex-start;
  gap: 6px;
  font-size: 0.78rem;
  color: var(--text-secondary);
  line-height: 1.4;
}
.cp-skill svg { flex-shrink: 0; margin-top: 2px; }

.cp-prereq-course {
  display: block;
  font-size: 0.8rem;
  color: #4C1BC9;
  text-decoration: none;
  padding: 4px 0;
}
.cp-prereq-course:hover { text-decoration: underline; }

.cp-curator {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 0.5rem;
}
.cp-curator__name { font-size: 0.85rem; font-weight: 700; color: var(--text-primary); }
.cp-curator__role { font-size: 0.72rem; color: var(--text-muted); font-family: var(--font-mono); }
