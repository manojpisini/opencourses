                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#4f9eff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                    {o}
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- Curator -->
          <div class="cp-card">
            <div class="cp-card__title">Curator</div>
            <div class="cp-curator">
              <Avatar login={detail.curator.github} size="sm" />
              <div>
                <div class="cp-curator__name">{detail.curator.name}</div>
                <div class="cp-curator__role">@{detail.curator.github} · {detail.curator.role}</div>
              </div>
            </div>
            {detail.curator.bio && <p class="cp-curator__bio">{detail.curator.bio}</p>}
          </div>

          <!-- Certificate -->
          {detail.certificate.enabled && (
            <div class="cp-card cp-card--cert">
              <div class="cp-card__title">Certificate</div>
              <div class="cp-cert-title">{detail.certificate.title}</div>
              {detail.certificate.subtitle && (
                <div class="cp-cert-sub">{detail.certificate.subtitle}</div>
              )}
              <div class="cp-cert-req">
                {detail.certificate.requirements.map(r => (
                  <div class="cp-cert-req__item">
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#fb923c" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                    {r.type.replace(/_/g, ' ')} ≥ {r.min_score}%
                  </div>
                ))}
              </div>
              <div class="cp-cert-badge">GPG-signed SVG · Open Badges 3.0</div>
            </div>
          )}

          <!-- Enroll -->
          <a
            href={`https://github.com/manojpisini/opencourses/issues/new?template=enroll.yml&title=[Enrolled]+@YOUR_USERNAME+—+${detail.id}&labels=enrollment-request`}
            class="cp-enroll-btn cp-enroll-btn--full"
            target="_blank"
            rel="noopener"
          >
            Enroll via GitHub Issues
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          </a>
        </aside>
      </div>
    </div>

  ) : (

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- FALLBACK: minimal course info page (no detail file yet)                -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <div class="container" style="padding-top:2rem;padding-bottom:4rem">
      <div style="display:flex;align-items:center;gap:6px;font-family:var(--font-mono);font-size:0.72rem;color:var(--text-muted);margin-bottom:1.5rem">
        <a href={`${base}/`} style="color:var(--text-muted)">~</a>
