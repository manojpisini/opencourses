---
import Base from '../layouts/Base.astro';
import CourseCard from '../components/CourseCard.astro';
import TrackBadge from '../components/TrackBadge.astro';
import Avatar from '../components/Avatar.astro';
import Heatmap from '../components/Heatmap.astro';
import GitStatus from '../components/GitStatus.astro';
import VersionTag from '../components/VersionTag.astro';
import OC from '../data/oc';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const featured = OC.COURSES.filter(c => c.featured);
const topContributors = OC.CONTRIBUTORS.slice(0, 6);
const recentChangelog = OC.CHANGELOG[0].entries.slice(0, 3);
const totalCommits = OC.activity.flat().reduce((a, b) => a + b, 0);
---

<Base title="OpenCourses" currentPath="/">
  <!-- HERO — Typographic variant -->
  <section class="hero">
    <div class="container hero__inner">
      <div>
        <div class="hero__eyebrow anim-up">
          <span class="hero__eyebrow__dot"></span>
          <span>v1.0 · 16 courses · 18 maintainers</span>
        </div>
        <h1 class="hero__title anim-up anim-up-d1">
          Learning,<br />in the <em>open</em>.
        </h1>
        <p class="hero__sub anim-up anim-up-d2">
          Open-source curriculum, version-controlled and community-built.
          Every course is a repo. Every contributor is a maintainer. Every update ships like software.
        </p>
        <div class="hero__ctas anim-up anim-up-d3">
          <a href={`${base}/courses`} class="btn btn-primary">
            Explore courses
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href={`${base}/tracks`} class="btn btn-secondary">View tracks</a>
          <button class="btn btn-ghost" id="hero-search-btn">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
            Search
            <span style="margin-left:6px;font-family:var(--font-mono);font-size:11px;padding:1px 5px;background:var(--bg-raised);border-radius:3px">⌘K</span>
          </button>
        </div>
      </div>
      <div class="hero__stats anim-up anim-up-d3">
        <div class="hero__stat">
          <span class="hero__stat__num">{OC.STATS.courses}</span>
          <span class="hero__stat__label">Courses</span>
          <span class="hero__stat__delta">+3 this month</span>
        </div>
        <div class="hero__stat">
          <span class="hero__stat__num">{OC.STATS.contributors}</span>
          <span class="hero__stat__label">Contributors</span>
          <span class="hero__stat__delta">+4 this month</span>
        </div>
        <div class="hero__stat">
          <span class="hero__stat__num">{(OC.STATS.stars / 1000).toFixed(1)}k</span>
          <span class="hero__stat__label">Stars</span>
          <span class="hero__stat__delta">+128 this week</span>
        </div>
      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <!-- FEATURED COURSES -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <div>
          <h2 class="section-head__title">Featured courses</h2>
          <div class="section-head__sub">Hand-picked from the catalog</div>
        </div>
        <a href={`${base}/courses`} class="section-head__link">
          View all
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
      <div class="courses-rail">
        {featured.map(c => <CourseCard course={c} />)}
      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <!-- TRACKS -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <div>
          <h2 class="section-head__title">Tracks</h2>
          <div class="section-head__sub">Curated learning paths</div>
        </div>
        <a href={`${base}/tracks`} class="section-head__link">
          Knowledge graph
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
      <div class="track-grid">
        {OC.TRACKS.map(t => {
          const count = OC.COURSES.filter(c => c.track === t.slug).length;
          const contributors = [...new Set(OC.COURSES.filter(c => c.track === t.slug).flatMap(c => c.contributors))];
          return (
            <a href={`${base}/tracks#${t.slug}`} class="track-card" data-track={t.slug}>
              <div class="track-card__head">
                <span class="track-card__icon">{t.icon}</span>
                <div>
                  <h3 class="track-card__name">{t.name}</h3>
                  <span class="track-card__count">{count} courses</span>
                </div>
              </div>
              <p class="track-card__desc">{t.description}</p>
              <div class="track-card__footer">
                <span style="font-family:var(--font-mono);font-size:11px;color:var(--text-muted)">{contributors.length} contributors</span>
                <span>Explore →</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <!-- ACTIVITY HEATMAP -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <div>
          <h2 class="section-head__title">Activity</h2>
          <div class="section-head__sub">Last 12 months of curriculum updates</div>
        </div>
        <span style="font-family:var(--font-mono);font-size:12px;color:var(--text-muted)">
          {totalCommits} commits · 52 weeks
        </span>
      </div>
      <div style="background:var(--bg-surface);border:1px solid var(--border-default);border-radius:8px;padding:24px">
        <Heatmap />
      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <!-- TOP CONTRIBUTORS -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <div>
          <h2 class="section-head__title">Top contributors</h2>
          <div class="section-head__sub">The people who ship the curriculum</div>
        </div>
        <a href={`${base}/contributors`} class="section-head__link">
          All contributors
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:16px">
        {topContributors.map(c => (
          <a href={`${base}/contributors`} class="contributor-card">
            <Avatar login={c.login} size="md" />
            <div class="contributor-card__name">@{c.login}</div>
            <div class="contributor-card__role">{c.role}</div>
            <div style="margin-top:8px;font-family:var(--font-mono);font-size:11px;color:var(--text-muted)">
              {c.commits} commits · {c.courses} courses
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <!-- RECENT CHANGELOG -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <div>
          <h2 class="section-head__title">Recent changes</h2>
          <div class="section-head__sub">From the curriculum changelog</div>
        </div>
        <a href={`${base}/changelog`} class="section-head__link">
          Full changelog
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:inline;vertical-align:middle"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
      <div style="display:flex;flex-direction:column;gap:12px">
        {recentChangelog.map(entry => (
          <a href={`${base}/courses/${entry.slug}`} class="changelog-entry">
            <div class="changelog-entry__head">
              <h3 class="changelog-entry__title">{entry.course}</h3>
              <VersionTag version={entry.version} />
              <span class="changelog-entry__date">{entry.date}</span>
            </div>
            <div>
              {entry.changes.slice(0, 3).map(ch => (
                <div class={`change-line change-line--${ch.type}`}>
                  <span class="change-line__marker">{ch.type === 'added' ? '+' : ch.type === 'removed' ? '-' : '~'}</span>
                  <span>{ch.text}</span>
                </div>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
