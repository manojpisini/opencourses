---
import Base from '../layouts/Base.astro';
import Avatar from '../components/Avatar.astro';
import OC from '../data/oc';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const { entries, stats, builtAt } = OC.LEADERBOARD;

const builtDate = new Date(builtAt);
const nextUpdate = new Date(builtDate.getTime() + 24 * 60 * 60 * 1000);
const nextUpdateStr = nextUpdate.toLocaleString('en-GB', {
  day: '2-digit', month: 'short', year: 'numeric',
  hour: '2-digit', minute: '2-digit', timeZone: 'UTC', timeZoneName: 'short',
});

function medal(rank: number): string {
  if (rank === 1) return '🥇';
  if (rank === 2) return '🥈';
  if (rank === 3) return '🥉';
  return `${rank}`;
}
---

<Base title="Leaderboard" description="Top students ranked by average score, courses completed, and total points.">
  <div class="container">
    <div class="page-head">
      <div class="page-head__crumbs">
        <a href={`${base}/`}>~</a>
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        <span>leaderboard</span>
      </div>
      <h1 class="page-head__title">Leaderboard</h1>
      <p class="page-head__sub">
        Ranked by average test score across all graded submissions.
        Ties broken by courses completed → total points earned → fastest completion.
      </p>
    </div>

    <!-- Stats bar -->
    <div class="lb-stats">
      <div class="lb-stat">
        <span class="lb-stat__num">{stats.totalEnrolled}</span>
        <span class="lb-stat__label">Enrolled</span>
      </div>
      <div class="lb-stat">
        <span class="lb-stat__num">{stats.totalCertified}</span>
        <span class="lb-stat__label">Certified</span>
      </div>
      <div class="lb-stat">
        <span class="lb-stat__num">{stats.totalCompletions}</span>
        <span class="lb-stat__label">Completions</span>
      </div>
      <div class="lb-stat">
        <span class="lb-stat__num">{stats.avgScore > 0 ? `${stats.avgScore}%` : '—'}</span>
        <span class="lb-stat__label">Avg Score</span>
      </div>
    </div>

    {entries.length === 0 ? (
      <!-- Empty state -->
      <div class="lb-empty">
        <div class="lb-empty__icon">🏆</div>
        <p class="lb-empty__title">No submissions yet</p>
        <p class="lb-empty__sub">
          Enroll in a course and pass a chapter test — your rank appears here automatically.
        </p>
        <a href={`${base}/courses`} class="btn btn-primary" style="margin-top:1.5rem">
          Browse Courses →
        </a>
      </div>
    ) : (
      <!-- Rankings table -->
      <div class="lb-table-wrap">
        <table class="lb-table">
          <thead>
            <tr>
              <th class="lb-th lb-th--rank">Rank</th>
              <th class="lb-th lb-th--student">Student</th>
              <th class="lb-th lb-th--score">Avg Score</th>
              <th class="lb-th lb-th--done">Done</th>
              <th class="lb-th lb-th--points">Points</th>
              <th class="lb-th lb-th--fastest">Fastest</th>
              <th class="lb-th lb-th--badge"></th>
            </tr>
          </thead>
          <tbody>
            {entries.map(e => (
              <tr class={`lb-row${e.rank <= 3 ? ` lb-row--top${e.rank}` : ''}`}>
                <td class="lb-td lb-td--rank">
                  <span class={`lb-rank${e.rank <= 3 ? ' lb-rank--medal' : ''}`}>
                    {medal(e.rank)}
                  </span>
                </td>
                <td class="lb-td lb-td--student">
                  <a href={`${base}/contributors/${e.login}`} class="lb-student">
                    <Avatar login={e.login} size="sm" />
                    <span class="lb-student__login">@{e.login}</span>
                  </a>
                </td>
                <td class="lb-td lb-td--score">
                  <div class="lb-score">
                    <div class="lb-bar">
                      <div class="lb-bar__fill" style={`width:${e.avgScore}%`}></div>
                    </div>
                    <span class="lb-score__num">{e.avgScore.toFixed(1)}%</span>
                  </div>
                </td>
                <td class="lb-td lb-td--done">{e.coursesCompleted}</td>
                <td class="lb-td lb-td--points">
                  <span class="lb-points">{e.totalPoints}</span>
                  <span class="lb-points__max">/{e.maxPoints}</span>
                </td>
                <td class="lb-td lb-td--fastest">
                  {e.fastestCourse !== null ? `${e.fastestCourse}h` : '—'}
                </td>
                <td class="lb-td lb-td--badge">
                  {e.certified && <span class="lb-cert" title="Certificate earned">🎓</span>}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}

    <!-- Legend / meta -->
    <div class="lb-meta">
      <span class="lb-meta__item">
        <strong>Ranked by:</strong>
        Avg Score → Courses Completed → Total Points → Fastest Completion
      </span>
      <span class="lb-meta__sep">·</span>
      <span class="lb-meta__item">
        Updates every 24 h · Next: {nextUpdateStr}
      </span>
      {entries.length > 0 && (
        <>
          <span class="lb-meta__sep">·</span>
          <span class="lb-meta__item">🎓 = certificate earned</span>
        </>
      )}
    </div>
  </div>
</Base>

<style>
  /* ── Stats bar ─────────────────────────────────────────────── */
  .lb-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 1px;
    margin-bottom: 2rem;
    background: var(--border-default);
    border: 1px solid var(--border-default);
    border-radius: 8px;
    overflow: hidden;
  }
  .lb-stat {
    flex: 1;
    min-width: 100px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    padding: 1.25rem 1rem;
    background: var(--bg-surface);
    text-align: center;
  }
  .lb-stat__num {
    font-family: var(--font-mono);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1;
  }
  .lb-stat__label {
    font-size: 11px;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* ── Empty state ───────────────────────────────────────────── */
  .lb-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 5rem 2rem;
    text-align: center;
  }
  .lb-empty__icon {
    font-size: 3rem;
    margin-bottom: 1rem;
    opacity: 0.4;
  }
  .lb-empty__title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 0 0 0.5rem;
  }
  .lb-empty__sub {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-muted);
    max-width: 420px;
    margin: 0;
  }

  /* ── Table ─────────────────────────────────────────────────── */
  .lb-table-wrap {
    overflow-x: auto;
    border: 1px solid var(--border-default);
    border-radius: 8px;
    margin-bottom: 1.5rem;
  }
  .lb-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }
  .lb-th {
    padding: 0.6rem 1rem;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    background: var(--bg-surface);
    border-bottom: 1px solid var(--border-default);
    white-space: nowrap;
    text-align: left;
  }
  .lb-th--rank   { width: 56px; text-align: center; }
  .lb-th--score  { min-width: 160px; }
  .lb-th--done   { width: 64px; text-align: center; }
  .lb-th--points { width: 90px; text-align: right; }
  .lb-th--fastest { width: 80px; text-align: right; }
  .lb-th--badge  { width: 36px; }

  .lb-row {
    border-bottom: 1px solid var(--border-subtle, var(--border-default));
    transition: background 0.1s;
  }
  .lb-row:last-child { border-bottom: none; }
  .lb-row:hover { background: var(--bg-raised); }
  .lb-row--top1 { background: color-mix(in srgb, #fbbf24 4%, var(--bg-base)); }
  .lb-row--top2 { background: color-mix(in srgb, #94a3b8 4%, var(--bg-base)); }
  .lb-row--top3 { background: color-mix(in srgb, #fb923c 4%, var(--bg-base)); }

  .lb-td {
    padding: 0.75rem 1rem;
    color: var(--text-secondary);
    vertical-align: middle;
  }
  .lb-td--rank   { text-align: center; }
  .lb-td--points { text-align: right; }
  .lb-td--fastest { text-align: right; font-family: var(--font-mono); font-size: 0.8rem; }
  .lb-td--done   { text-align: center; font-family: var(--font-mono); }

  .lb-rank {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .lb-rank--medal { font-size: 1.2rem; }

  /* Student cell */
  .lb-student {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: inherit;
  }
  .lb-student:hover .lb-student__login { color: var(--text-link, var(--accent-blue)); }
  .lb-student__login {
    font-weight: 500;
    color: var(--text-primary);
    transition: color 0.1s;
  }

  /* Score cell with inline bar */
  .lb-score {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .lb-bar {
    flex: 1;
    height: 5px;
    background: var(--border-default);
    border-radius: 3px;
    overflow: hidden;
    min-width: 60px;
  }
  .lb-bar__fill {
    height: 100%;
    background: var(--accent-blue, #38BDF8);
    border-radius: 3px;
    transition: width 0.3s;
  }
  .lb-score__num {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-primary);
    white-space: nowrap;
    min-width: 46px;
    text-align: right;
  }

  /* Points */
  .lb-points { color: var(--text-primary); font-family: var(--font-mono); font-size: 0.8rem; }
  .lb-points__max { color: var(--text-muted); font-family: var(--font-mono); font-size: 0.75rem; }

  /* Cert badge */
  .lb-cert { font-size: 1rem; }

  /* ── Meta / legend ─────────────────────────────────────────── */
  .lb-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.75rem;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-muted);
    padding: 0.5rem 0;
  }
  .lb-meta__sep { color: var(--border-default); }
</style>
