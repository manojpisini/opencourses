---
import Base from '../layouts/Base.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base
  title="Verify Credential"
  description="Verify an OpenCourses certificate, Open Badge, GPG signature, and GitHub Actions attestation."
  currentPath="/verify"
>
  <section class="verify-page">
    <div class="verify-shell">
      <div class="verify-hero">
        <div class="verify-mark" aria-hidden="true">
          <img src={`${base}/brand/Square.svg`} width="54" height="54" alt="" />
        </div>
        <div>
          <p class="verify-eyebrow">Credential verification</p>
          <h1>Verify an OpenCourses completion certificate</h1>
          <p>
            OpenCourses credentials are generated by GitHub Actions, published as GitHub Release assets,
            signed with GPG, packaged with Open Badges 3.0 metadata, and optionally verified with GitHub
            artifact attestations.
          </p>
        </div>
      </div>

      <div class="verify-grid">
        <article class="verify-card verify-card--primary">
          <h2>Credential</h2>
          <dl class="verify-fields">
            <div><dt>Certificate ID</dt><dd id="verify-cert-id">Missing</dd></div>
            <div><dt>Student</dt><dd id="verify-student">Missing</dd></div>
            <div><dt>Course</dt><dd id="verify-course">Missing</dd></div>
            <div><dt>Release</dt><dd><a id="verify-release" href="#" target="_blank" rel="noopener">Missing release URL</a></dd></div>
          </dl>
          <div class="verify-actions">
            <a class="verify-button verify-button--primary" id="verify-open-release" href="#" target="_blank" rel="noopener">Open GitHub Release</a>
            <button class="verify-button" id="verify-copy-url" type="button">Copy verification URL</button>
          </div>
        </article>

        <article class="verify-card">
          <h2>Trust stack</h2>
          <ol class="verify-steps">
            <li><strong>Permanent record:</strong> certificate assets live on the GitHub Release for this credential.</li>
            <li><strong>Open Badge:</strong> the release includes interoperable Open Badges 3.0 JSON.</li>
            <li><strong>Signature:</strong> the SVG certificate has a detached GPG signature.</li>
            <li><strong>Provenance:</strong> GitHub artifact attestation can prove the asset came from the workflow run.</li>
          </ol>
        </article>
      </div>

      <article class="verify-card verify-card--wide">
        <h2>Command-line verification</h2>
        <p>Download the release assets, then verify the detached signature and workflow provenance.</p>
        <pre><code id="verify-commands">Open a certificate release to generate verification commands.</code></pre>
      </article>

      <article class="verify-card verify-card--wide">
        <h2>How it was generated</h2>
        <p>
          The certificate workflow resolves the learner enrollment issue, renders the SVG/PDF from repository
          templates, writes Open Badge metadata, signs the SVG, uploads everything to a GitHub Release, and
          posts the release back to the learner's enrollment issue. The final credential files are not committed
          by hand; repository guards block generated credential artifacts from source control.
        </p>
      </article>
    </div>
  </section>

  <script is:inline>
    (function () {
      var params = new URLSearchParams(window.location.search);
      var certId = params.get('certId') || '';
      var student = params.get('student') || '';
      var course = params.get('course') || '';
      var release = params.get('release') || '';

      function setText(id, value) {
        var el = document.getElementById(id);
        if (el) el.textContent = value || 'Missing';
      }

      setText('verify-cert-id', certId);
      setText('verify-student', student ? '@' + student.replace(/^@+/, '') : '');
      setText('verify-course', course);

      ['verify-release', 'verify-open-release'].forEach(function (id) {
        var el = document.getElementById(id);
        if (!el) return;
        if (release) {
          el.href = release;
          if (id === 'verify-release') el.textContent = release;
        } else {
          el.removeAttribute('href');
        }
      });

      var downloadBase = release.replace('/releases/tag/', '/releases/download/');
      var commands = certId && release
        ? [
            'curl -sL ' + downloadBase + '/' + certId + '.svg -o certificate.svg',
            'curl -sL ' + downloadBase + '/' + certId + '.svg.asc -o certificate.svg.asc',
            'gpg --verify certificate.svg.asc certificate.svg',
            'gh attestation verify certificate.svg --repo manojpisini/opencourses',
          ].join('\n')
        : 'Open a certificate release to generate verification commands.';
      setText('verify-commands', commands);

      var copy = document.getElementById('verify-copy-url');
      if (copy) {
        copy.addEventListener('click', function () {
          navigator.clipboard?.writeText(window.location.href).then(function () {
            var old = copy.textContent;
            copy.textContent = 'Copied';
            setTimeout(function () { copy.textContent = old; }, 1200);
          });
        });
      }
    })();
  </script>
</Base>

<style>
.verify-page {
  min-height: calc(100vh - 120px);
  padding: 3rem 1rem 5rem;
  background:
    radial-gradient(circle at 20% 10%, color-mix(in srgb, #4C1BC9 14%, transparent), transparent 30%),
    var(--bg-base);
}
.verify-shell {
  width: min(1120px, 100%);
  margin: 0 auto;
}
.verify-hero {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 1rem;
  align-items: center;
  padding: 1.25rem 0 2rem;
}
.verify-mark {
  display: grid;
  place-items: center;
  width: 78px;
  height: 78px;
  border: 1px solid color-mix(in srgb, #4C1BC9 34%, var(--border-default));
  border-radius: 8px;
  background: var(--bg-surface);
}
.verify-eyebrow {
  margin: 0 0 0.4rem;
  color: #4C1BC9;
  font: 0.72rem var(--font-mono);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.verify-hero h1 {
  margin: 0;
  font-size: clamp(2rem, 5vw, 4rem);
  line-height: 0.95;
  letter-spacing: 0;
}
.verify-hero p {
  max-width: 760px;
  margin: 0.8rem 0 0;
  color: var(--text-secondary);
  line-height: 1.7;
}
.verify-grid {
  display: grid;
  grid-template-columns: minmax(0, 1.05fr) minmax(300px, 0.95fr);
  gap: 1rem;
  margin-bottom: 1rem;
}
.verify-card {
  padding: 1.2rem;
  border: 1px solid var(--border-default);
  border-radius: 8px;
  background: var(--bg-surface);
}
.verify-card--primary {
  border-color: color-mix(in srgb, #4C1BC9 40%, var(--border-default));
}
.verify-card--wide {
  margin-top: 1rem;
}
.verify-card h2 {
  margin: 0 0 1rem;
  font-size: 1rem;
  letter-spacing: 0;
}
.verify-fields {
  display: grid;
  gap: 0.7rem;
  margin: 0;
}
.verify-fields div {
  display: grid;
  grid-template-columns: 120px 1fr;
  gap: 1rem;
}
.verify-fields dt {
  color: var(--text-muted);
  font: 0.72rem var(--font-mono);
  text-transform: uppercase;
}
.verify-fields dd {
  min-width: 0;
  margin: 0;
  overflow-wrap: anywhere;
  color: var(--text-primary);
  font-weight: 700;
}
.verify-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.6rem;
  margin-top: 1.1rem;
}
.verify-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 38px;
  padding: 0 0.9rem;
  border: 1px solid var(--border-default);
  border-radius: 8px;
  background: var(--bg-base);
  color: var(--text-primary);
  font-weight: 800;
  text-decoration: none;
}
.verify-button--primary {
  border-color: #4C1BC9;
  background: #4C1BC9;
  color: white;
}
.verify-steps {
  display: grid;
  gap: 0.7rem;
  margin: 0;
  padding-left: 1.2rem;
  color: var(--text-secondary);
  line-height: 1.6;
}
.verify-card p {
  margin: 0;
  color: var(--text-secondary);
  line-height: 1.7;
}
.verify-card pre {
  margin: 0.9rem 0 0;
  overflow: auto;
  padding: 1rem;
  border-radius: 8px;
  background: #05080a;
  color: #d1d5db;
  font: 0.82rem/1.6 var(--font-mono);
}
@media (max-width: 800px) {
  .verify-hero,
  .verify-grid,
  .verify-fields div {
    grid-template-columns: 1fr;
  }
}
</style>
